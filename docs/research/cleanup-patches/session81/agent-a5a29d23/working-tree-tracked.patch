+
+
+class PluginEventResponse(BaseModel):
+    """A single lifecycle event response."""
+
+    event_type: str
+    plugin_name: str
+    version: str = ""
+    timestamp: str
+    details: dict[str, Any] = Field(default_factory=dict)
