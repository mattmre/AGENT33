+
+# ---------------------------------------------------------------------------
+# Track Phase 3: Plugin Lifecycle Control Plane
+# ---------------------------------------------------------------------------
+
+
+def _get_plugin_installer(request: Request) -> Any:
+    """Extract plugin installer from app state."""
+    installer = getattr(request.app.state, "plugin_installer", None)
+    if installer is None:
+        raise HTTPException(
+            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
+            detail="Plugin installer not initialized",
+        )
+    return installer
+
+
+def _get_plugin_doctor(request: Request) -> Any:
+    """Extract plugin doctor from app state."""
+    doctor = getattr(request.app.state, "plugin_doctor", None)
+    if doctor is None:
+        raise HTTPException(
+            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
+            detail="Plugin doctor not initialized",
+        )
+    return doctor
+
+
+def _get_plugin_event_emitter(request: Request) -> Any:
+    """Extract plugin event emitter from app state."""
+    return getattr(request.app.state, "plugin_event_emitter", None)
+
+
+def _get_plugin_config_store(request: Request) -> Any:
+    """Extract plugin config store from app state."""
+    return getattr(request.app.state, "plugin_config_store", None)
+
+
+@router.post(
+    "/install",
+    response_model=PluginInstallResponse,
+    status_code=status.HTTP_201_CREATED,
+    dependencies=[require_scope("plugins:write")],
+)
+async def install_plugin(
+    request: Request, body: PluginInstallRequest
+) -> PluginInstallResponse:
+    """Install a plugin from a local path, archive, or registry spec."""
+    installer = _get_plugin_installer(request)
+
+    if body.source_type == "local":
+        result = installer.install_from_local(
+            Path(body.path), version_pin=body.version_pin
+        )
+    elif body.source_type == "archive":
+        result = installer.install_from_archive(Path(body.path))
+    elif body.source_type == "registry":
+        result = installer.install_from_registry(body.registry_spec)
+    else:
+        raise HTTPException(
+            status_code=status.HTTP_400_BAD_REQUEST,
+            detail=f"Unsupported source type: {body.source_type}",
+        )
+
+    if not result.success:
+        raise HTTPException(
+            status_code=status.HTTP_400_BAD_REQUEST,
+            detail={"errors": result.errors},
+        )
+
+    # Emit lifecycle event
+    emitter = _get_plugin_event_emitter(request)
+    if emitter is not None:
+        emitter.emit(
+            "installed",
+            result.plugin_name,
+            version=result.version,
+            details={"source_type": body.source_type},
+        )
+
+    return PluginInstallResponse(
+        success=result.success,
+        plugin_name=result.plugin_name,
+        version=result.version,
+        warnings=result.warnings,
+    )
+
+
+@router.post(
+    "/{name}/update",
+    response_model=PluginInstallResponse,
+    dependencies=[require_scope("plugins:write")],
+)
+async def update_plugin(
+    request: Request, name: str, body: PluginUpdateRequest
+) -> PluginInstallResponse:
+    """Update an installed plugin to a new version from a source directory."""
+    installer = _get_plugin_installer(request)
+
+    # Unload first if needed
+    registry = _get_plugin_registry(request)
+    entry = registry.get(name)
+    if entry is not None and entry.state.value not in ("discovered", "unloaded"):
+        try:
+            await registry.unload(name)
+        except Exception as exc:
+            raise HTTPException(
+                status_code=status.HTTP_409_CONFLICT,
+                detail=f"Failed to unload plugin before update: {exc}",
+            ) from exc
+
+    result = installer.update(
+        name, Path(body.source_path), target_version=body.target_version
+    )
+
+    if not result.success:
+        raise HTTPException(
+            status_code=status.HTTP_400_BAD_REQUEST,
+            detail={"errors": result.errors},
+        )
+
+    emitter = _get_plugin_event_emitter(request)
+    if emitter is not None:
+        emitter.emit("updated", name, version=result.version)
+
+    return PluginInstallResponse(
+        success=result.success,
+        plugin_name=result.plugin_name,
+        version=result.version,
+        warnings=result.warnings,
+    )
+
+
+@router.delete(
+    "/{name}",
+    response_model=PluginInstallResponse,
+    dependencies=[require_scope("plugins:write")],
+)
+async def uninstall_plugin(request: Request, name: str) -> PluginInstallResponse:
+    """Uninstall a plugin and remove it from disk."""
+    registry = _get_plugin_registry(request)
+    entry = registry.get(name)
+    if entry is None:
+        raise HTTPException(
+            status_code=status.HTTP_404_NOT_FOUND,
+            detail=f"Plugin '{name}' not found",
+        )
+
+    # Unload first if needed
+    if entry.state.value not in ("discovered", "unloaded"):
+        try:
+            await registry.unload(name)
+        except Exception as exc:
+            raise HTTPException(
+                status_code=status.HTTP_409_CONFLICT,
+                detail=f"Failed to unload plugin before uninstall: {exc}",
+            ) from exc
+
+    installer = _get_plugin_installer(request)
+    result = installer.uninstall(name)
+
+    if not result.success:
+        raise HTTPException(
+            status_code=status.HTTP_400_BAD_REQUEST,
+            detail={"errors": result.errors},
+        )
+
+    # Clean up config
+    config_store = _get_plugin_config_store(request)
+    if config_store is not None:
+        config_store.delete(name)
+
+    emitter = _get_plugin_event_emitter(request)
+    if emitter is not None:
+        emitter.emit("uninstalled", name)
+
+    return PluginInstallResponse(
+        success=True,
+        plugin_name=name,
+    )
+
+
+@router.get(
+    "/{name}/doctor",
+    response_model=PluginDoctorResponse,
+    dependencies=[require_scope("plugins:read")],
+)
+async def doctor_plugin(request: Request, name: str) -> PluginDoctorResponse:
+    """Run diagnostic checks on a specific plugin."""
+    doctor = _get_plugin_doctor(request)
+
+    try:
+        report = doctor.diagnose(name)
+    except KeyError:
+        raise HTTPException(
+            status_code=status.HTTP_404_NOT_FOUND,
+            detail=f"Plugin '{name}' not found",
+        )
+
+    return PluginDoctorResponse(
+        plugin_name=report.plugin_name,
+        checks=[
+            PluginDoctorCheckResponse(
+                name=c.name,
+                status=c.status,
+                message=c.message,
+                remediation=c.remediation,
+            )
+            for c in report.checks
+        ],
+        overall_status=report.overall_status,
+    )
+
+
+@router.get(
+    "/doctor/all",
+    response_model=list[PluginDoctorResponse],
+    dependencies=[require_scope("plugins:read")],
+)
+async def doctor_all_plugins(
+    request: Request,
+) -> list[PluginDoctorResponse]:
+    """Run diagnostics across all discovered plugins."""
+    doctor = _get_plugin_doctor(request)
+    reports = doctor.diagnose_all()
+
+    return [
+        PluginDoctorResponse(
+            plugin_name=r.plugin_name,
+            checks=[
+                PluginDoctorCheckResponse(
+                    name=c.name,
+                    status=c.status,
+                    message=c.message,
+                    remediation=c.remediation,
+                )
+                for c in r.checks
+            ],
+            overall_status=r.overall_status,
+        )
+        for r in reports
+    ]
+
+
+@router.get(
+    "/{name}/events",
+    response_model=list[PluginEventResponse],
+    dependencies=[require_scope("plugins:read")],
+)
+async def get_plugin_events(
+    request: Request, name: str, limit: int = 50
+) -> list[PluginEventResponse]:
+    """Get lifecycle events for a plugin."""
+    # Verify plugin exists
+    registry = _get_plugin_registry(request)
+    entry = registry.get(name)
+    if entry is None:
+        raise HTTPException(
+            status_code=status.HTTP_404_NOT_FOUND,
+            detail=f"Plugin '{name}' not found",
+        )
+
+    emitter = _get_plugin_event_emitter(request)
+    if emitter is None:
+        return []
+
+    events = emitter.get_events(plugin_name=name, limit=limit)
+    return [
+        PluginEventResponse(
+            event_type=e.event_type,
+            plugin_name=e.plugin_name,
+            version=e.version,
+            timestamp=e.timestamp.isoformat(),
+            details=e.details,
+        )
+        for e in events
+    ]
