+"""Tests for plugin lifecycle event recording."""
+
+from __future__ import annotations
+
+from agent33.plugins.events import PluginEventEmitter
+
+
+class TestPluginEventEmitter:
+    """Tests for PluginEventEmitter."""
+
+    def test_emit_creates_event(self) -> None:
+        emitter = PluginEventEmitter()
+        event = emitter.emit("installed", "test-plugin", version="1.0.0")
+
+        assert event.event_type == "installed"
+        assert event.plugin_name == "test-plugin"
+        assert event.version == "1.0.0"
+        assert event.timestamp is not None
+
+    def test_emit_with_details(self) -> None:
+        emitter = PluginEventEmitter()
+        event = emitter.emit(
+            "error",
+            "broken-plugin",
+            details={"error": "something failed"},
+        )
+
+        assert event.details == {"error": "something failed"}
+
+    def test_get_events_returns_newest_first(self) -> None:
+        emitter = PluginEventEmitter()
+        emitter.emit("installed", "plugin-a")
+        emitter.emit("enabled", "plugin-a")
+        emitter.emit("disabled", "plugin-a")
+
+        events = emitter.get_events()
+
+        assert len(events) == 3
+        assert events[0].event_type == "disabled"
+        assert events[1].event_type == "enabled"
+        assert events[2].event_type == "installed"
+
+    def test_get_events_filter_by_plugin(self) -> None:
+        emitter = PluginEventEmitter()
+        emitter.emit("installed", "plugin-a")
+        emitter.emit("installed", "plugin-b")
+        emitter.emit("enabled", "plugin-a")
+
+        events = emitter.get_events(plugin_name="plugin-a")
+
+        assert len(events) == 2
+        assert all(e.plugin_name == "plugin-a" for e in events)
+
+    def test_get_events_filter_by_type(self) -> None:
+        emitter = PluginEventEmitter()
+        emitter.emit("installed", "plugin-a")
+        emitter.emit("installed", "plugin-b")
+        emitter.emit("enabled", "plugin-a")
+
+        events = emitter.get_events(event_type="installed")
+
+        assert len(events) == 2
+        assert all(e.event_type == "installed" for e in events)
+
+    def test_get_events_with_limit(self) -> None:
+        emitter = PluginEventEmitter()
+        for i in range(10):
+            emitter.emit("installed", f"plugin-{i}")
+
+        events = emitter.get_events(limit=3)
+        assert len(events) == 3
+
+    def test_clear_all_events(self) -> None:
+        emitter = PluginEventEmitter()
+        emitter.emit("installed", "plugin-a")
+        emitter.emit("installed", "plugin-b")
+
+        removed = emitter.clear()
+        assert removed == 2
+        assert emitter.count == 0
+
+    def test_clear_filtered_by_plugin(self) -> None:
+        emitter = PluginEventEmitter()
+        emitter.emit("installed", "plugin-a")
+        emitter.emit("installed", "plugin-b")
+        emitter.emit("enabled", "plugin-a")
+
+        removed = emitter.clear(plugin_name="plugin-a")
+        assert removed == 2
+        assert emitter.count == 1
+
+        events = emitter.get_events()
+        assert events[0].plugin_name == "plugin-b"
+
+    def test_max_events_trimming(self) -> None:
+        emitter = PluginEventEmitter(max_events=5)
+
+        for i in range(10):
+            emitter.emit("installed", f"plugin-{i}")
+
+        assert emitter.count == 5
+
+        events = emitter.get_events()
+        # Should have the 5 most recent (plugin-5 through plugin-9)
+        assert events[0].plugin_name == "plugin-9"
+        assert events[4].plugin_name == "plugin-5"
+
+    def test_count_property(self) -> None:
+        emitter = PluginEventEmitter()
+        assert emitter.count == 0
+
+        emitter.emit("installed", "test")
+        assert emitter.count == 1
+
+        emitter.emit("enabled", "test")
+        assert emitter.count == 2
+
+    def test_combined_filters(self) -> None:
+        emitter = PluginEventEmitter()
+        emitter.emit("installed", "plugin-a")
+        emitter.emit("installed", "plugin-b")
+        emitter.emit("enabled", "plugin-a")
+        emitter.emit("enabled", "plugin-b")
+
+        events = emitter.get_events(
+            plugin_name="plugin-a", event_type="enabled"
+        )
+
+        assert len(events) == 1
+        assert events[0].plugin_name == "plugin-a"
+        assert events[0].event_type == "enabled"
