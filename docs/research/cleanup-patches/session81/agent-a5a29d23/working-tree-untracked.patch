@@ -0,0 +1,110 @@
+"""Pack health checks: validate installed packs are functioning correctly.
+
+Runs smoke checks on pack skills and dependencies to surface issues
+before they impact agents.
+"""
+
+from __future__ import annotations
+
+from datetime import UTC, datetime
+from typing import TYPE_CHECKING
+
+import structlog
+from pydantic import BaseModel, Field
+
+if TYPE_CHECKING:
+    from agent33.packs.registry import PackRegistry
+
+logger = structlog.get_logger()
+
+
+class PackHealthStatus(BaseModel):
+    """Health status for a single installed pack."""
+
+    pack_name: str
+    healthy: bool
+    last_smoke_check: datetime | None = None
+    skill_load_errors: list[str] = Field(default_factory=list)
+    dependency_issues: list[str] = Field(default_factory=list)
+    details: dict[str, str] = Field(default_factory=dict)
+
+
+class PackHealthChecker:
+    """Runs health checks on installed packs.
+
+    Checks include:
+    1. Pack is installed and has a valid status
+    2. All declared skills were loaded successfully
+    3. Pack dependencies are satisfied
+    4. Pack directory still exists on disk
+    """
+
+    def __init__(self, pack_registry: PackRegistry) -> None:
+        self._registry = pack_registry
+
+    def check(self, pack_name: str) -> PackHealthStatus:
+        """Run health checks on a single pack.
+
+        Args:
+            pack_name: Name of the pack to check.
+
+        Raises:
+            KeyError: If the pack is not installed.
+        """
+        pack = self._registry.get(pack_name)
+        if pack is None:
+            raise KeyError(f"Pack '{pack_name}' is not installed")
+
+        skill_errors: list[str] = []
+        dep_issues: list[str] = []
+        details: dict[str, str] = {}
+
+        # Check skill loading
+        declared_skill_count = len(pack.skills)
+        loaded_skill_count = len(pack.loaded_skill_names)
+        if loaded_skill_count < declared_skill_count:
+            skill_errors.append(
+                f"Only {loaded_skill_count}/{declared_skill_count} skills loaded"
+            )
+            details["skills_declared"] = str(declared_skill_count)
+            details["skills_loaded"] = str(loaded_skill_count)
+
+        # Check pack directory
+        if not pack.pack_dir.is_dir():
+            skill_errors.append(f"Pack directory missing: {pack.pack_dir}")
+
+        # Check dependencies
+        for dep in pack.pack_dependencies:
+            dep_pack = self._registry.get(dep.name)
+            if dep_pack is None:
+                dep_issues.append(f"Required pack '{dep.name}' not installed")
+
+        healthy = not skill_errors and not dep_issues
+        details["status"] = pack.status.value
+        details["version"] = pack.version
+
+        return PackHealthStatus(
+            pack_name=pack_name,
+            healthy=healthy,
+            last_smoke_check=datetime.now(UTC),
+            skill_load_errors=skill_errors,
+            dependency_issues=dep_issues,
+            details=details,
+        )
+
+    def check_all(self) -> list[PackHealthStatus]:
+        """Run health checks on all installed packs."""
+        results: list[PackHealthStatus] = []
+        for pack in self._registry.list_installed():
+            try:
+                result = self.check(pack.name)
+                results.append(result)
+            except Exception as exc:
+                results.append(
+                    PackHealthStatus(
+                        pack_name=pack.name,
+                        healthy=False,
+                        skill_load_errors=[f"Health check failed: {exc}"],
+                    )
+                )
+        return results
