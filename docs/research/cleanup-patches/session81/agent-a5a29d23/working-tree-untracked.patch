@@ -0,0 +1,157 @@
+"""Pack trust policy management with persistence.
+
+Manages the trust policy that governs which packs are allowed for
+installation based on their provenance metadata. Provides CRUD
+operations for trusted signers and minimum trust level configuration.
+"""
+
+from __future__ import annotations
+
+import json
+import logging
+from pathlib import Path
+from typing import Any
+
+from agent33.packs.provenance import PackTrustPolicy, TrustLevel
+
+logger = logging.getLogger(__name__)
+
+
+class TrustPolicyManager:
+    """Manages pack trust policies with persistence.
+
+    The trust policy is stored as JSON on disk and loaded on initialization.
+    Changes are persisted atomically via temp file + rename.
+    """
+
+    def __init__(self, config_path: Path) -> None:
+        self._config_path = config_path
+        self._policy = self._load_or_default()
+
+    def _load_or_default(self) -> PackTrustPolicy:
+        """Load the trust policy from disk, or create a default."""
+        if self._config_path.is_file():
+            try:
+                data = json.loads(self._config_path.read_text(encoding="utf-8"))
+                return PackTrustPolicy(**data)
+            except Exception:
+                logger.warning(
+                    "Failed to load trust policy from %s, using defaults",
+                    self._config_path,
+                    exc_info=True,
+                )
+        return PackTrustPolicy()
+
+    def _persist(self) -> None:
+        """Write the current policy to disk atomically."""
+        self._config_path.parent.mkdir(parents=True, exist_ok=True)
+        tmp_path = self._config_path.with_suffix(".json.tmp")
+        try:
+            tmp_path.write_text(
+                self._policy.model_dump_json(indent=2),
+                encoding="utf-8",
+            )
+            tmp_path.replace(self._config_path)
+        except Exception:
+            if tmp_path.exists():
+                tmp_path.unlink()
+            raise
+
+    def get_policy(self) -> PackTrustPolicy:
+        """Return the current trust policy."""
+        return self._policy.model_copy()
+
+    def update_policy(self, updates: dict[str, Any]) -> PackTrustPolicy:
+        """Update trust policy fields.
+
+        Supports updating: require_signature, min_trust_level, allowed_signers.
+
+        Args:
+            updates: Dict of field names to new values.
+
+        Returns:
+            The updated policy.
+
+        Raises:
+            ValueError: If an invalid field or value is provided.
+        """
+        policy_data = self._policy.model_dump()
+
+        for key, value in updates.items():
+            if key not in policy_data:
+                raise ValueError(f"Unknown trust policy field: {key}")
+            policy_data[key] = value
+
+        self._policy = PackTrustPolicy(**policy_data)
+        self._persist()
+
+        logger.info("trust_policy_updated", updates=list(updates.keys()))
+        return self._policy.model_copy()
+
+    def add_trusted_signer(self, signer_id: str) -> bool:
+        """Add a signer to the trusted signers list.
+
+        Returns True if the signer was added, False if already present.
+        """
+        if signer_id in self._policy.allowed_signers:
+            return False
+
+        signers = list(self._policy.allowed_signers)
+        signers.append(signer_id)
+        self._policy = self._policy.model_copy(
+            update={"allowed_signers": signers}
+        )
+        self._persist()
+
+        logger.info("trusted_signer_added", signer_id=signer_id)
+        return True
+
+    def remove_trusted_signer(self, signer_id: str) -> bool:
+        """Remove a signer from the trusted signers list.
+
+        Returns True if the signer was removed, False if not found.
+        """
+        if signer_id not in self._policy.allowed_signers:
+            return False
+
+        signers = [s for s in self._policy.allowed_signers if s != signer_id]
+        self._policy = self._policy.model_copy(
+            update={"allowed_signers": signers}
+        )
+        self._persist()
+
+        logger.info("trusted_signer_removed", signer_id=signer_id)
+        return True
+
+    def set_min_trust_level(self, level: TrustLevel) -> None:
+        """Set the minimum required trust level for pack installation."""
+        self._policy = self._policy.model_copy(
+            update={"min_trust_level": level}
+        )
+        self._persist()
+
+        logger.info("min_trust_level_updated", level=level.value)
+
+    def set_require_signature(self, require: bool) -> None:
+        """Set whether pack signatures are required."""
+        self._policy = self._policy.model_copy(
+            update={"require_signature": require}
+        )
+        self._persist()
+
+        logger.info("require_signature_updated", require=require)
+
+    @property
+    def trusted_signers(self) -> list[str]:
+        """Return the current list of trusted signers."""
+        return list(self._policy.allowed_signers)
+
+    @property
+    def min_trust_level(self) -> TrustLevel:
+        """Return the current minimum trust level."""
+        return self._policy.min_trust_level
+
+    @property
+    def requires_signature(self) -> bool:
+        """Return whether signatures are required."""
+        return self._policy.require_signature
