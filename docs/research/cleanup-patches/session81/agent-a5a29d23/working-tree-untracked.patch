+"""Tests for pack trust policy manager: CRUD, signer management, persistence."""
+
+from __future__ import annotations
+
+import json
+from pathlib import Path
+
+import pytest
+
+from agent33.packs.provenance import TrustLevel
+from agent33.packs.trust_manager import TrustPolicyManager
+
+
+class TestTrustPolicyManager:
+    """Tests for TrustPolicyManager."""
+
+    def test_default_policy(self, tmp_path: Path) -> None:
+        config_path = tmp_path / "trust-policy.json"
+        mgr = TrustPolicyManager(config_path)
+
+        policy = mgr.get_policy()
+
+        assert policy.require_signature is False
+        assert policy.min_trust_level == TrustLevel.UNTRUSTED
+        assert policy.allowed_signers == []
+
+    def test_get_policy_returns_copy(self, tmp_path: Path) -> None:
+        config_path = tmp_path / "trust-policy.json"
+        mgr = TrustPolicyManager(config_path)
+
+        p1 = mgr.get_policy()
+        p2 = mgr.get_policy()
+
+        # Should be equal but not the same object
+        assert p1 == p2
+        assert p1 is not p2
+
+    def test_update_policy(self, tmp_path: Path) -> None:
+        config_path = tmp_path / "trust-policy.json"
+        mgr = TrustPolicyManager(config_path)
+
+        updated = mgr.update_policy({"require_signature": True})
+
+        assert updated.require_signature is True
+        # Verify persistence
+        assert config_path.is_file()
+
+    def test_update_policy_invalid_field(self, tmp_path: Path) -> None:
+        config_path = tmp_path / "trust-policy.json"
+        mgr = TrustPolicyManager(config_path)
+
+        with pytest.raises(ValueError, match="Unknown trust policy field"):
+            mgr.update_policy({"nonexistent_field": True})
+
+    def test_add_trusted_signer(self, tmp_path: Path) -> None:
+        config_path = tmp_path / "trust-policy.json"
+        mgr = TrustPolicyManager(config_path)
+
+        added = mgr.add_trusted_signer("signer-1")
+        assert added is True
+        assert "signer-1" in mgr.trusted_signers
+
+    def test_add_duplicate_signer_returns_false(self, tmp_path: Path) -> None:
+        config_path = tmp_path / "trust-policy.json"
+        mgr = TrustPolicyManager(config_path)
+
+        mgr.add_trusted_signer("signer-1")
+        added = mgr.add_trusted_signer("signer-1")
+        assert added is False
+        assert mgr.trusted_signers.count("signer-1") == 1
+
+    def test_remove_trusted_signer(self, tmp_path: Path) -> None:
+        config_path = tmp_path / "trust-policy.json"
+        mgr = TrustPolicyManager(config_path)
+
+        mgr.add_trusted_signer("signer-1")
+        removed = mgr.remove_trusted_signer("signer-1")
+
+        assert removed is True
+        assert "signer-1" not in mgr.trusted_signers
+
+    def test_remove_nonexistent_signer_returns_false(self, tmp_path: Path) -> None:
+        config_path = tmp_path / "trust-policy.json"
+        mgr = TrustPolicyManager(config_path)
+
+        removed = mgr.remove_trusted_signer("nonexistent")
+        assert removed is False
+
+    def test_set_min_trust_level(self, tmp_path: Path) -> None:
+        config_path = tmp_path / "trust-policy.json"
+        mgr = TrustPolicyManager(config_path)
+
+        mgr.set_min_trust_level(TrustLevel.VERIFIED)
+
+        assert mgr.min_trust_level == TrustLevel.VERIFIED
+
+    def test_set_require_signature(self, tmp_path: Path) -> None:
+        config_path = tmp_path / "trust-policy.json"
+        mgr = TrustPolicyManager(config_path)
+
+        assert mgr.requires_signature is False
+
+        mgr.set_require_signature(True)
+        assert mgr.requires_signature is True
+
+    def test_persistence_survives_reload(self, tmp_path: Path) -> None:
+        config_path = tmp_path / "trust-policy.json"
+
+        mgr1 = TrustPolicyManager(config_path)
+        mgr1.add_trusted_signer("signer-1")
+        mgr1.set_min_trust_level(TrustLevel.OFFICIAL)
+        mgr1.set_require_signature(True)
+
+        # Create new instance from same path
+        mgr2 = TrustPolicyManager(config_path)
+
+        assert mgr2.trusted_signers == ["signer-1"]
+        assert mgr2.min_trust_level == TrustLevel.OFFICIAL
+        assert mgr2.requires_signature is True
+
+    def test_corrupt_config_uses_defaults(self, tmp_path: Path) -> None:
+        config_path = tmp_path / "trust-policy.json"
+        config_path.write_text("invalid json{", encoding="utf-8")
+
+        mgr = TrustPolicyManager(config_path)
+        policy = mgr.get_policy()
+
+        # Should fall back to defaults
+        assert policy.require_signature is False
+        assert policy.min_trust_level == TrustLevel.UNTRUSTED
+
+    def test_multiple_signers(self, tmp_path: Path) -> None:
+        config_path = tmp_path / "trust-policy.json"
+        mgr = TrustPolicyManager(config_path)
+
+        mgr.add_trusted_signer("signer-a")
+        mgr.add_trusted_signer("signer-b")
+        mgr.add_trusted_signer("signer-c")
+
+        assert len(mgr.trusted_signers) == 3
+        assert set(mgr.trusted_signers) == {"signer-a", "signer-b", "signer-c"}
+
+        mgr.remove_trusted_signer("signer-b")
+        assert len(mgr.trusted_signers) == 2
+        assert "signer-b" not in mgr.trusted_signers
