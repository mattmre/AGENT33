+++ b/engine/src/agent33/api/routes/packs_marketplace.py
@@ -0,0 +1,493 @@
+"""FastAPI router for pack marketplace, provenance, rollback, and tenant enablement.
+
+Extends the existing packs and marketplace routers with Track Phase 4
+features: trust policy management, tenant enablement matrix, rollback,
+health checks, and audit trails.
+"""
+
+# NOTE: no ``from __future__ import annotations`` -- Pydantic needs these
+# types at runtime for request-body validation.
+
+from typing import Any
+
+import structlog
+from fastapi import APIRouter, HTTPException, Query, Request
+from pydantic import BaseModel, Field
+
+from agent33.security.permissions import require_scope
+
+logger = structlog.get_logger()
+
+router = APIRouter(prefix="/v1/packs", tags=["packs-marketplace"])
+
+
+# ---------------------------------------------------------------------------
+# Request / Response models
+# ---------------------------------------------------------------------------
+
+
+class TrustPolicyUpdateRequest(BaseModel):
+    """Request body for trust policy updates."""
+
+    require_signature: bool | None = None
+    min_trust_level: str | None = None
+    allowed_signers: list[str] | None = None
+
+
+class TrustPolicyResponse(BaseModel):
+    """Trust policy state."""
+
+    require_signature: bool
+    min_trust_level: str
+    allowed_signers: list[str]
+
+
+class TenantEnablementEntry(BaseModel):
+    """Single entry in the tenant enablement matrix."""
+
+    pack_name: str
+    tenant_id: str
+    enabled: bool
+
+
+class TenantEnablementMatrix(BaseModel):
+    """Matrix of pack enablement across tenants."""
+
+    packs: list[str] = Field(default_factory=list)
+    tenants: list[str] = Field(default_factory=list)
+    matrix: dict[str, dict[str, bool]] = Field(default_factory=dict)
+
+
+class BulkEnablementRequest(BaseModel):
+    """Request to bulk-update enablement."""
+
+    entries: list[TenantEnablementEntry] = Field(default_factory=list)
+
+
+class ProvenanceResponse(BaseModel):
+    """Provenance chain for a pack."""
+
+    pack_name: str
+    version: str = ""
+    signer_id: str = ""
+    trust_level: str = ""
+    signed_at: str = ""
+    checksum: str = ""
+
+
+class PackHealthResponse(BaseModel):
+    """Health check response for a pack."""
+
+    pack_name: str
+    healthy: bool
+    skill_load_errors: list[str] = Field(default_factory=list)
+    dependency_issues: list[str] = Field(default_factory=list)
+    details: dict[str, str] = Field(default_factory=dict)
+
+
+class PackAuditEntryResponse(BaseModel):
+    """Audit trail entry response."""
+
+    pack_name: str
+    action: str
+    version: str = ""
+    tenant_id: str = ""
+    timestamp: str
+    actor: str = ""
+    details: dict[str, Any] = Field(default_factory=dict)
+
+
+class RollbackResponse(BaseModel):
+    """Result of a rollback operation."""
+
+    success: bool
+    pack_name: str
+    version: str = ""
+    errors: list[str] = Field(default_factory=list)
+    skills_loaded: int = 0
+
+
+# ---------------------------------------------------------------------------
+# Helper extractors
+# ---------------------------------------------------------------------------
+
+
+def _get_pack_registry(request: Request) -> Any:
+    registry = getattr(request.app.state, "pack_registry", None)
+    if registry is None:
+        raise HTTPException(status_code=503, detail="Pack registry not initialized")
+    return registry
+
+
+def _get_trust_manager(request: Request) -> Any:
+    mgr = getattr(request.app.state, "pack_trust_manager", None)
+    if mgr is None:
+        raise HTTPException(status_code=503, detail="Trust policy manager not initialized")
+    return mgr
+
+
+def _get_rollback_manager(request: Request) -> Any:
+    mgr = getattr(request.app.state, "pack_rollback_manager", None)
+    if mgr is None:
+        raise HTTPException(status_code=503, detail="Rollback manager not initialized")
+    return mgr
+
+
+def _get_health_checker(request: Request) -> Any:
+    checker = getattr(request.app.state, "pack_health_checker", None)
+    if checker is None:
+        raise HTTPException(status_code=503, detail="Pack health checker not initialized")
+    return checker
+
+
+def _get_audit_log(request: Request) -> Any:
+    log = getattr(request.app.state, "pack_audit_log", None)
+    if log is None:
+        raise HTTPException(status_code=503, detail="Pack audit log not initialized")
+    return log
+
+
+def _tenant_id(request: Request) -> str:
+    user = getattr(request.state, "user", None)
+    if user is None:
+        return "default"
+    return getattr(user, "tenant_id", None) or "default"
+
+
+# ---------------------------------------------------------------------------
+# Trust Policy Endpoints
+# ---------------------------------------------------------------------------
+
+
+@router.get(
+    "/trust-policy",
+    response_model=TrustPolicyResponse,
+    dependencies=[require_scope("agents:read")],
+)
+async def get_trust_policy(request: Request) -> TrustPolicyResponse:
+    """Get the current pack trust policy."""
+    mgr = _get_trust_manager(request)
+    policy = mgr.get_policy()
+    return TrustPolicyResponse(
+        require_signature=policy.require_signature,
+        min_trust_level=policy.min_trust_level.value,
+        allowed_signers=list(policy.allowed_signers),
+    )
+
+
+@router.put(
+    "/trust-policy",
+    response_model=TrustPolicyResponse,
+    dependencies=[require_scope("agents:write")],
+)
+async def update_trust_policy(
+    request: Request, body: TrustPolicyUpdateRequest
+) -> TrustPolicyResponse:
+    """Update the pack trust policy."""
+    mgr = _get_trust_manager(request)
+
+    updates: dict[str, Any] = {}
+    if body.require_signature is not None:
+        updates["require_signature"] = body.require_signature
+    if body.min_trust_level is not None:
+        updates["min_trust_level"] = body.min_trust_level
+    if body.allowed_signers is not None:
+        updates["allowed_signers"] = body.allowed_signers
+
+    if not updates:
+        raise HTTPException(status_code=400, detail="No updates provided")
+
+    try:
+        policy = mgr.update_policy(updates)
+    except ValueError as exc:
+        raise HTTPException(status_code=400, detail=str(exc)) from exc
+
+    return TrustPolicyResponse(
+        require_signature=policy.require_signature,
+        min_trust_level=policy.min_trust_level.value,
+        allowed_signers=list(policy.allowed_signers),
+    )
+
+
+# ---------------------------------------------------------------------------
+# Tenant Enablement Matrix
+# ---------------------------------------------------------------------------
+
+
+@router.get(
+    "/enablement-matrix",
+    response_model=TenantEnablementMatrix,
+    dependencies=[require_scope("agents:read")],
+)
+async def get_enablement_matrix(request: Request) -> TenantEnablementMatrix:
+    """Get the full tenant enablement matrix."""
+    registry = _get_pack_registry(request)
+
+    packs = [p.name for p in registry.list_installed()]
+    tenants = sorted(registry._enabled.keys())
+
+    matrix: dict[str, dict[str, bool]] = {}
+    for pack_name in packs:
+        matrix[pack_name] = {}
+        for tenant_id in tenants:
+            matrix[pack_name][tenant_id] = registry.is_enabled(
+                pack_name, tenant_id
+            )
+
+    return TenantEnablementMatrix(
+        packs=packs,
+        tenants=tenants,
+        matrix=matrix,
+    )
+
+
+@router.put(
+    "/enablement-matrix",
+    response_model=TenantEnablementMatrix,
+    dependencies=[require_scope("agents:write")],
+)
+async def update_enablement_matrix(
+    request: Request, body: BulkEnablementRequest
+) -> TenantEnablementMatrix:
+    """Bulk update pack enablement across tenants."""
+    registry = _get_pack_registry(request)
+    audit_log = getattr(request.app.state, "pack_audit_log", None)
+
+    errors: list[str] = []
+    for entry in body.entries:
+        try:
+            if entry.enabled:
+                registry.enable(entry.pack_name, entry.tenant_id)
+            else:
+                registry.disable(entry.pack_name, entry.tenant_id)
+
+            if audit_log is not None:
+                audit_log.record(
+                    entry.pack_name,
+                    "enabled" if entry.enabled else "disabled",
+                    tenant_id=entry.tenant_id,
+                )
+        except ValueError as exc:
+            errors.append(f"{entry.pack_name}/{entry.tenant_id}: {exc}")
+
+    if errors:
+        raise HTTPException(
+            status_code=400,
+            detail={"message": "Some enablement updates failed", "errors": errors},
+        )
+
+    # Return updated matrix
+    return await get_enablement_matrix(request)
+
+
+# ---------------------------------------------------------------------------
+# Provenance
+# ---------------------------------------------------------------------------
+
+
+@router.get(
+    "/{name}/provenance",
+    response_model=ProvenanceResponse,
+    dependencies=[require_scope("agents:read")],
+)
+async def get_pack_provenance(
+    request: Request, name: str
+) -> ProvenanceResponse:
+    """Get provenance information for an installed pack."""
+    registry = _get_pack_registry(request)
+    pack = registry.get(name)
+    if pack is None:
+        raise HTTPException(status_code=404, detail=f"Pack '{name}' not found")
+
+    return ProvenanceResponse(
+        pack_name=pack.name,
+        version=pack.version,
+        checksum=pack.checksum,
+        signer_id="",
+        trust_level="",
+        signed_at="",
+    )
+
+
+# ---------------------------------------------------------------------------
+# Rollback
+# ---------------------------------------------------------------------------
+
+
+@router.post(
+    "/{name}/rollback",
+    response_model=RollbackResponse,
+    dependencies=[require_scope("agents:write")],
+)
+async def rollback_pack(request: Request, name: str) -> RollbackResponse:
+    """Rollback a pack to its previously archived version."""
+    rollback_mgr = _get_rollback_manager(request)
+
+    if not rollback_mgr.has_archive(name):
+        raise HTTPException(
+            status_code=404,
+            detail=f"No archived versions available for pack '{name}'",
+        )
+
+    result = rollback_mgr.rollback(name)
+
+    audit_log = getattr(request.app.state, "pack_audit_log", None)
+    if audit_log is not None:
+        audit_log.record(
+            name,
+            "rollback",
+            version=result.version,
+            details={"success": result.success},
+        )
+
+    if not result.success:
+        raise HTTPException(
+            status_code=400,
+            detail={"errors": result.errors},
+        )
+
+    return RollbackResponse(
+        success=True,
+        pack_name=name,
+        version=result.version,
+        skills_loaded=result.skills_loaded,
+    )
+
+
+@router.get(
+    "/{name}/rollback-versions",
+    dependencies=[require_scope("agents:read")],
+)
+async def list_rollback_versions(
+    request: Request, name: str
+) -> dict[str, Any]:
+    """List available rollback versions for a pack."""
+    rollback_mgr = _get_rollback_manager(request)
+    versions = rollback_mgr.list_archived_versions(name)
+    return {"pack_name": name, "versions": versions, "count": len(versions)}
+
+
+# ---------------------------------------------------------------------------
+# Health
+# ---------------------------------------------------------------------------
+
+
+@router.get(
+    "/{name}/health",
+    response_model=PackHealthResponse,
+    dependencies=[require_scope("agents:read")],
+)
+async def get_pack_health(request: Request, name: str) -> PackHealthResponse:
+    """Run health checks on a specific pack."""
+    checker = _get_health_checker(request)
+
+    try:
+        status_result = checker.check(name)
+    except KeyError:
+        raise HTTPException(status_code=404, detail=f"Pack '{name}' not found")
+
+    return PackHealthResponse(
+        pack_name=status_result.pack_name,
+        healthy=status_result.healthy,
+        skill_load_errors=status_result.skill_load_errors,
+        dependency_issues=status_result.dependency_issues,
+        details=status_result.details,
+    )
+
+
+# ---------------------------------------------------------------------------
+# Audit
+# ---------------------------------------------------------------------------
+
+
+@router.get(
+    "/{name}/audit",
+    response_model=list[PackAuditEntryResponse],
+    dependencies=[require_scope("agents:read")],
+)
+async def get_pack_audit(
+    request: Request,
+    name: str,
+    limit: int = Query(default=50, ge=1, le=500),
+) -> list[PackAuditEntryResponse]:
+    """Get audit trail for a specific pack."""
+    audit_log = _get_audit_log(request)
+    entries = audit_log.query(pack_name=name, limit=limit)
+
+    return [
+        PackAuditEntryResponse(
+            pack_name=e.pack_name,
+            action=e.action,
+            version=e.version,
+            tenant_id=e.tenant_id,
+            timestamp=e.timestamp.isoformat(),
+            actor=e.actor,
+            details=e.details,
+        )
+        for e in entries
+    ]
+
+
+# ---------------------------------------------------------------------------
+# Tenant Pack Enablement (per-tenant view)
+# ---------------------------------------------------------------------------
+
+
+@router.get(
+    "/tenants/{tenant_id}/enabled",
+    dependencies=[require_scope("agents:read")],
+)
+async def get_tenant_packs(
+    request: Request, tenant_id: str
+) -> dict[str, Any]:
+    """List packs enabled for a specific tenant."""
+    registry = _get_pack_registry(request)
+    packs = registry.list_enabled(tenant_id)
+    return {
+        "tenant_id": tenant_id,
+        "packs": [
+            {
+                "name": p.name,
+                "version": p.version,
+                "description": p.description,
+            }
+            for p in packs
+        ],
+        "count": len(packs),
+    }
+
+
+@router.put(
+    "/tenants/{tenant_id}/packs/{pack_name}",
+    dependencies=[require_scope("agents:write")],
+)
+async def set_tenant_pack_enablement(
+    request: Request,
+    tenant_id: str,
+    pack_name: str,
+    enabled: bool = Query(..., description="Enable or disable the pack"),
+) -> dict[str, Any]:
+    """Enable or disable a specific pack for a tenant."""
+    registry = _get_pack_registry(request)
+
+    try:
+        if enabled:
+            registry.enable(pack_name, tenant_id)
+        else:
+            registry.disable(pack_name, tenant_id)
+    except ValueError as exc:
+        raise HTTPException(status_code=404, detail=str(exc)) from exc
+
+    audit_log = getattr(request.app.state, "pack_audit_log", None)
+    if audit_log is not None:
+        audit_log.record(
+            pack_name,
+            "enabled" if enabled else "disabled",
+            tenant_id=tenant_id,
+        )
+
+    return {
+        "pack_name": pack_name,
+        "tenant_id": tenant_id,
+        "enabled": enabled,
+    }
diff --git a/engine/src/agent33/packs/audit.py b/engine/src/agent33/packs/audit.py
new file mode 100644
index 0000000..963e036
--- /dev/null
+++ b/engine/src/agent33/packs/audit.py
@@ -0,0 +1,126 @@
+"""Pack audit trail recording.
+
+Records all lifecycle actions (install, upgrade, downgrade, uninstall,
+enable, disable, rollback) for compliance and debugging.
+"""
+
+from __future__ import annotations
+
+from datetime import UTC, datetime
+from typing import Any
+
+import structlog
+from pydantic import BaseModel, Field
+
+logger = structlog.get_logger()
+
+
+class PackAuditEntry(BaseModel):
+    """A single audit trail entry for a pack action."""
+
+    pack_name: str
+    action: str  # installed, upgraded, downgraded, uninstalled, enabled, disabled, rollback
+    version: str = ""
+    tenant_id: str = ""
+    timestamp: datetime = Field(default_factory=lambda: datetime.now(UTC))
+    actor: str = ""
+    details: dict[str, Any] = Field(default_factory=dict)
+
+
+class PackAuditLog:
+    """In-memory audit log for pack lifecycle actions.
+
+    Stores entries in a bounded buffer. When the buffer exceeds
+    max_entries, the oldest entries are dropped.
+    """
+
+    def __init__(self, *, max_entries: int = 5000) -> None:
+        self._entries: list[PackAuditEntry] = []
+        self._max_entries = max_entries
+
+    def record(
+        self,
+        pack_name: str,
+        action: str,
+        *,
+        version: str = "",
+        tenant_id: str = "",
+        actor: str = "",
+        details: dict[str, Any] | None = None,
+    ) -> PackAuditEntry:
+        """Record an audit entry.
+
+        Args:
+            pack_name: Name of the pack.
+            action: Action performed.
+            version: Pack version at the time of action.
+            tenant_id: Tenant that performed the action.
+            actor: Identity of the actor (user, system, etc.).
+            details: Optional additional context.
+
+        Returns:
+            The recorded PackAuditEntry.
+        """
+        entry = PackAuditEntry(
+            pack_name=pack_name,
+            action=action,
+            version=version,
+            tenant_id=tenant_id,
+            actor=actor,
+            details=details or {},
+        )
+        self._entries.append(entry)
+
+        if len(self._entries) > self._max_entries:
+            overflow = len(self._entries) - self._max_entries
+            self._entries = self._entries[overflow:]
+
+        logger.info(
+            "pack_audit",
+            pack_name=pack_name,
+            action=action,
+            version=version,
+            tenant_id=tenant_id,
+        )
+
+        return entry
+
+    def query(
+        self,
+        *,
+        pack_name: str = "",
+        action: str = "",
+        tenant_id: str = "",
+        limit: int = 50,
+    ) -> list[PackAuditEntry]:
+        """Query audit entries with optional filters.
+
+        Args:
+            pack_name: Filter by pack name (empty = all).
+            action: Filter by action type (empty = all).
+            tenant_id: Filter by tenant (empty = all).
+            limit: Maximum results to return.
+
+        Returns:
+            Entries in reverse chronological order (newest first).
+        """
+        filtered = self._entries
+        if pack_name:
+            filtered = [e for e in filtered if e.pack_name == pack_name]
+        if action:
+            filtered = [e for e in filtered if e.action == action]
+        if tenant_id:
+            filtered = [e for e in filtered if e.tenant_id == tenant_id]
+
+        return list(reversed(filtered))[:limit]
+
+    @property
+    def count(self) -> int:
+        """Total number of stored audit entries."""
+        return len(self._entries)
+
+    def clear(self) -> int:
+        """Clear all audit entries. Returns the number removed."""
+        count = len(self._entries)
+        self._entries.clear()
+        return count
