@@ -0,0 +1,128 @@
+"""Plugin configuration persistence to disk.
+
+Stores per-plugin configuration as JSON files under a config directory.
+The PluginRegistry loads persisted config on startup and merges it with
+defaults from the plugin manifest's configSchema.
+"""
+
+from __future__ import annotations
+
+import json
+import logging
+from pathlib import Path
+from typing import Any
+
+logger = logging.getLogger(__name__)
+
+
+class PluginConfigStore:
+    """Persists plugin configuration to disk as JSON files.
+
+    Config layout::
+
+        {config_dir}/{plugin_name}/config.json
+
+    Thread-safety: this class performs synchronous file I/O and is not
+    safe for concurrent writes to the same plugin name.
+    """
+
+    def __init__(self, config_dir: Path) -> None:
+        self._config_dir = config_dir
+        self._config_dir.mkdir(parents=True, exist_ok=True)
+
+    def _plugin_config_path(self, plugin_name: str) -> Path:
+        """Return the config file path for a plugin."""
+        return self._config_dir / plugin_name / "config.json"
+
+    def load(self, plugin_name: str) -> dict[str, Any]:
+        """Load persisted config for a plugin.
+
+        Returns an empty dict if no config has been saved.
+        Raises ValueError if the saved config is malformed JSON.
+        """
+        path = self._plugin_config_path(plugin_name)
+        if not path.is_file():
+            return {}
+
+        try:
+            data = json.loads(path.read_text(encoding="utf-8"))
+        except json.JSONDecodeError as exc:
+            raise ValueError(
+                f"Malformed config for plugin '{plugin_name}': {exc}"
+            ) from exc
+
+        if not isinstance(data, dict):
+            raise ValueError(
+                f"Config for plugin '{plugin_name}' must be a JSON object, "
+                f"got {type(data).__name__}"
+            )
+
+        logger.info("Loaded config for plugin '%s'", plugin_name)
+        return data
+
+    def save(self, plugin_name: str, config: dict[str, Any]) -> None:
+        """Persist config updates to disk.
+
+        Creates the plugin config directory if it does not exist.
+        Overwrites any existing config file.
+
+        Args:
+            plugin_name: The plugin to save config for.
+            config: The configuration dictionary to persist.
+
+        Raises:
+            TypeError: If config is not a dict.
+        """
+        if not isinstance(config, dict):
+            raise TypeError(
+                f"Config must be a dict, got {type(config).__name__}"
+            )
+
+        path = self._plugin_config_path(plugin_name)
+        path.parent.mkdir(parents=True, exist_ok=True)
+
+        # Write atomically via temp file
+        tmp_path = path.with_suffix(".json.tmp")
+        try:
+            tmp_path.write_text(
+                json.dumps(config, indent=2, sort_keys=True),
+                encoding="utf-8",
+            )
+            tmp_path.replace(path)
+        except Exception:
+            if tmp_path.exists():
+                tmp_path.unlink()
+            raise
+
+        logger.info("Saved config for plugin '%s'", plugin_name)
+
+    def delete(self, plugin_name: str) -> bool:
+        """Remove persisted config on uninstall.
+
+        Returns True if config was found and removed, False if
+        no config existed.
+        """
+        plugin_dir = self._config_dir / plugin_name
+        if not plugin_dir.exists():
+            return False
+
+        import shutil
+
+        shutil.rmtree(plugin_dir)
+        logger.info("Deleted config for plugin '%s'", plugin_name)
+        return True
+
+    def list_configured_plugins(self) -> list[str]:
+        """Return names of all plugins that have persisted config."""
+        if not self._config_dir.is_dir():
+            return []
+
+        return sorted(
+            entry.name
+            for entry in self._config_dir.iterdir()
+            if entry.is_dir() and (entry / "config.json").is_file()
+        )
+
+    def has_config(self, plugin_name: str) -> bool:
+        """Check if a plugin has persisted config."""
+        return self._plugin_config_path(plugin_name).is_file()
