+        mock_registry.get.return_value = None
+
+        app.state.plugin_registry = mock_registry
+        app.state.plugin_installer = MagicMock()
+
+        client = TestClient(app)
+        resp = client.delete("/v1/plugins/nonexistent")
+
+        assert resp.status_code == 404
+
+
+class TestPluginDoctorRoute:
+    """Tests for GET /v1/plugins/{name}/doctor."""
+
+    def test_doctor_healthy(self) -> None:
+        app = _make_app()
+        mock_registry = MagicMock()
+
+        mock_doctor = MagicMock()
+        mock_doctor.diagnose.return_value = PluginDoctorReport(
+            plugin_name="healthy-plugin",
+            checks=[
+                PluginDoctorCheck(
+                    name="manifest_validity",
