index 0000000..60c4db5
--- /dev/null
+++ b/engine/src/agent33/plugins/doctor.py
@@ -0,0 +1,309 @@
+"""Plugin diagnostic checks: identify broken plugins and suggest remediations.
+
+The PluginDoctor runs a battery of checks on installed plugins and produces
+structured reports that operators can use to debug issues.
+"""
+
+from __future__ import annotations
+
+from typing import TYPE_CHECKING, Any
+
+import structlog
+from pydantic import BaseModel, Field
+
+from agent33.plugins.models import PluginState
+from agent33.plugins.version import satisfies_constraint
+
+if TYPE_CHECKING:
+    from agent33.plugins.config_store import PluginConfigStore
+    from agent33.plugins.registry import PluginRegistry
+
+logger = structlog.get_logger()
+
+
+class PluginDoctorCheck(BaseModel):
+    """A single diagnostic check result."""
+
+    name: str
+    status: str  # "ok", "warn", "error"
+    message: str
+    remediation: str = ""
+
+
+class PluginDoctorReport(BaseModel):
+    """Aggregated doctor report for a single plugin."""
+
+    plugin_name: str
+    checks: list[PluginDoctorCheck] = Field(default_factory=list)
+    overall_status: str = "healthy"  # "healthy", "degraded", "broken"
+
+
+def _compute_overall_status(checks: list[PluginDoctorCheck]) -> str:
+    """Determine overall status from a list of checks."""
+    statuses = {c.status for c in checks}
+    if "error" in statuses:
+        return "broken"
+    if "warn" in statuses:
+        return "degraded"
+    return "healthy"
+
+
+class PluginDoctor:
+    """Runs diagnostic checks on installed plugins.
+
+    Checks:
+    1. Manifest validity: plugin has a parseable manifest
+    2. State check: plugin is not in ERROR state
+    3. Dependencies: all required deps are discovered and version-compatible
+    4. Config schema: persisted config is valid JSON
+    5. Health check: if plugin implements health_check(), call it
+    6. Version conflicts: no conflicting versions with other plugins
+    """
+
+    def __init__(
+        self,
+        plugin_registry: PluginRegistry,
+        config_store: PluginConfigStore | None = None,
+    ) -> None:
+        self._registry = plugin_registry
+        self._config_store = config_store
+
+    def diagnose(self, plugin_name: str) -> PluginDoctorReport:
+        """Run all diagnostic checks for a single plugin.
+
+        Args:
+            plugin_name: Name of the plugin to diagnose.
+
+        Returns:
+            PluginDoctorReport with all check results.
+
+        Raises:
+            KeyError: If the plugin is not discovered.
+        """
+        entry = self._registry.get(plugin_name)
+        if entry is None:
+            raise KeyError(f"Plugin '{plugin_name}' not found")
+
+        checks: list[PluginDoctorCheck] = []
+
+        # 1. Manifest check
+        checks.append(self._check_manifest(entry))
+
+        # 2. State check
+        checks.append(self._check_state(entry))
+
+        # 3. Dependency checks
+        checks.extend(self._check_dependencies(entry))
+
+        # 4. Config check
+        if self._config_store is not None:
+            checks.append(self._check_config(plugin_name))
+
+        # 5. Version conflict check
+        checks.extend(self._check_version_conflicts(entry))
+
+        overall = _compute_overall_status(checks)
+        return PluginDoctorReport(
+            plugin_name=plugin_name,
+            checks=checks,
+            overall_status=overall,
+        )
+
+    def diagnose_all(self) -> list[PluginDoctorReport]:
+        """Run diagnostics across all discovered plugins."""
+        reports: list[PluginDoctorReport] = []
+        for manifest in self._registry.list_all():
+            try:
+                report = self.diagnose(manifest.name)
+                reports.append(report)
+            except Exception as exc:
+                reports.append(
+                    PluginDoctorReport(
+                        plugin_name=manifest.name,
+                        checks=[
+                            PluginDoctorCheck(
+                                name="diagnostic_error",
+                                status="error",
+                                message=f"Failed to run diagnostics: {exc}",
+                            )
+                        ],
+                        overall_status="broken",
+                    )
+                )
+        return reports
+
+    def _check_manifest(self, entry: Any) -> PluginDoctorCheck:
+        """Verify the manifest is present and valid."""
+        try:
+            manifest = entry.manifest
+            if not manifest.name or not manifest.version:
+                return PluginDoctorCheck(
+                    name="manifest_validity",
+                    status="error",
+                    message="Manifest is missing required fields (name or version)",
+                    remediation="Ensure plugin.yaml has 'name' and 'version' fields.",
+                )
+            return PluginDoctorCheck(
+                name="manifest_validity",
+                status="ok",
+                message=f"Manifest valid: {manifest.name} v{manifest.version}",
+            )
+        except Exception as exc:
+            return PluginDoctorCheck(
+                name="manifest_validity",
+                status="error",
+                message=f"Manifest parse error: {exc}",
+                remediation="Fix manifest syntax and re-discover.",
+            )
+
+    def _check_state(self, entry: Any) -> PluginDoctorCheck:
+        """Check if the plugin is in an error state."""
+        state = entry.state
+        if state == PluginState.ERROR:
+            error_msg = entry.error or "Unknown error"
+            return PluginDoctorCheck(
+                name="state_check",
+                status="error",
+                message=f"Plugin is in ERROR state: {error_msg}",
+                remediation="Check plugin logs, fix the issue, and reload.",
+            )
+        if state == PluginState.UNLOADED:
+            return PluginDoctorCheck(
+                name="state_check",
+                status="warn",
+                message="Plugin is unloaded",
+                remediation="Load the plugin with the registry.load() method.",
+            )
+        return PluginDoctorCheck(
+            name="state_check",
+            status="ok",
+            message=f"Plugin state: {state.value}",
+        )
+
+    def _check_dependencies(self, entry: Any) -> list[PluginDoctorCheck]:
+        """Check that all required dependencies are available and compatible."""
+        checks: list[PluginDoctorCheck] = []
+        manifest = entry.manifest
+
+        for dep in manifest.dependencies:
+            dep_entry = self._registry.get(dep.name)
+
+            if dep_entry is None:
+                if dep.optional:
+                    checks.append(
+                        PluginDoctorCheck(
+                            name=f"dependency_{dep.name}",
+                            status="warn",
+                            message=f"Optional dependency '{dep.name}' is not installed",
+                            remediation=f"Install plugin '{dep.name}' for full functionality.",
+                        )
+                    )
+                else:
+                    checks.append(
+                        PluginDoctorCheck(
+                            name=f"dependency_{dep.name}",
+                            status="error",
+                            message=f"Required dependency '{dep.name}' is not installed",
+                            remediation=f"Install plugin '{dep.name}' before using this plugin.",
+                        )
+                    )
+                continue
+
+            # Check version constraint
+            if dep.version_constraint != "*" and not satisfies_constraint(
+                dep_entry.manifest.version, dep.version_constraint
+            ):
+                checks.append(
+                    PluginDoctorCheck(
+                        name=f"dependency_{dep.name}",
+                        status="error",
+                        message=(
+                            f"Dependency '{dep.name}' v{dep_entry.manifest.version} "
+                            f"does not satisfy constraint {dep.version_constraint}"
+                        ),
+                        remediation=(
+                            f"Update '{dep.name}' to a version matching "
+                            f"{dep.version_constraint}."
+                        ),
+                    )
+                )
+            else:
+                checks.append(
+                    PluginDoctorCheck(
+                        name=f"dependency_{dep.name}",
+                        status="ok",
+                        message=f"Dependency '{dep.name}' v{dep_entry.manifest.version} OK",
+                    )
+                )
+
+        if not manifest.dependencies:
+            checks.append(
+                PluginDoctorCheck(
+                    name="dependencies",
+                    status="ok",
+                    message="No dependencies declared",
+                )
+            )
+
+        return checks
+
+    def _check_config(self, plugin_name: str) -> PluginDoctorCheck:
+        """Check that persisted config is valid."""
+        if self._config_store is None:
+            return PluginDoctorCheck(
+                name="config_check",
+                status="warn",
+                message="Config store not available",
+            )
+
+        try:
+            config = self._config_store.load(plugin_name)
+            if config:
+                return PluginDoctorCheck(
+                    name="config_check",
+                    status="ok",
+                    message=f"Config loaded: {len(config)} keys",
+                )
+            return PluginDoctorCheck(
+                name="config_check",
+                status="ok",
+                message="No persisted config (using defaults)",
+            )
+        except ValueError as exc:
+            return PluginDoctorCheck(
+                name="config_check",
+                status="error",
+                message=f"Config is malformed: {exc}",
+                remediation="Fix or delete the config file and reconfigure.",
+            )
+
+    def _check_version_conflicts(self, entry: Any) -> list[PluginDoctorCheck]:
+        """Check for version conflicts with other installed plugins."""
+        checks: list[PluginDoctorCheck] = []
+        violations = self._registry.check_version_constraints()
+
+        # Filter to violations relevant to this plugin
+        plugin_violations = [
+            v for v in violations if entry.manifest.name in v
+        ]
+
+        if plugin_violations:
+            for v in plugin_violations:
+                checks.append(
+                    PluginDoctorCheck(
+                        name="version_conflict",
+                        status="error",
+                        message=v,
+                        remediation="Update the conflicting plugin to a compatible version.",
+                    )
+                )
+        else:
+            checks.append(
+                PluginDoctorCheck(
+                    name="version_conflicts",
+                    status="ok",
+                    message="No version conflicts detected",
+                )
+            )
+
+        return checks
diff --git a/engine/src/agent33/plugins/events.py b/engine/src/agent33/plugins/events.py
new file mode 100644
index 0000000..07d2c33
--- /dev/null
+++ b/engine/src/agent33/plugins/events.py
@@ -0,0 +1,126 @@
+"""Plugin lifecycle event recording.
+
+Events are emitted during plugin lifecycle transitions and stored
+in-memory for audit and debugging. Can be wired to the hook framework
+for external consumers.
+"""
+
+from __future__ import annotations
+
+from datetime import UTC, datetime
+from typing import Any
+
+import structlog
+from pydantic import BaseModel, Field
+
+logger = structlog.get_logger()
+
+
+class PluginLifecycleEvent(BaseModel):
+    """A single plugin lifecycle event."""
+
+    event_type: str  # "installed", "enabled", "disabled", "updated", "uninstalled", "error"
+    plugin_name: str
+    version: str = ""
+    timestamp: datetime = Field(default_factory=lambda: datetime.now(UTC))
+    details: dict[str, Any] = Field(default_factory=dict)
+
+
+class PluginEventEmitter:
+    """Records and provides access to plugin lifecycle events.
+
+    Events are stored in a bounded in-memory buffer. When the buffer
+    exceeds max_events, the oldest events are dropped.
+    """
+
+    def __init__(self, *, max_events: int = 1000) -> None:
+        self._events: list[PluginLifecycleEvent] = []
+        self._max_events = max_events
+
+    def emit(
+        self,
+        event_type: str,
+        plugin_name: str,
+        *,
+        version: str = "",
+        details: dict[str, Any] | None = None,
+    ) -> PluginLifecycleEvent:
+        """Record a lifecycle event.
+
+        Args:
+            event_type: Type of the event (installed, enabled, etc.).
+            plugin_name: Name of the plugin.
+            version: Plugin version at the time of the event.
+            details: Optional additional context.
+
+        Returns:
+            The created PluginLifecycleEvent.
+        """
+        event = PluginLifecycleEvent(
+            event_type=event_type,
+            plugin_name=plugin_name,
+            version=version,
+            details=details or {},
+        )
+        self._events.append(event)
+
+        # Trim oldest events if over capacity
+        if len(self._events) > self._max_events:
+            overflow = len(self._events) - self._max_events
+            self._events = self._events[overflow:]
+
+        logger.info(
+            "plugin_lifecycle_event",
+            event_type=event_type,
+            plugin_name=plugin_name,
+            version=version,
+        )
+
+        return event
+
+    def get_events(
+        self,
+        *,
+        plugin_name: str = "",
+        event_type: str = "",
+        limit: int = 50,
+    ) -> list[PluginLifecycleEvent]:
+        """Query events with optional filters.
+
+        Args:
+            plugin_name: Filter by plugin name (empty = all).
+            event_type: Filter by event type (empty = all).
+            limit: Maximum number of events to return.
+
+        Returns:
+            Events in reverse chronological order (newest first).
+        """
+        filtered = self._events
+        if plugin_name:
+            filtered = [e for e in filtered if e.plugin_name == plugin_name]
+        if event_type:
+            filtered = [e for e in filtered if e.event_type == event_type]
+
+        # Return newest first, limited
+        return list(reversed(filtered))[:limit]
+
+    def clear(self, *, plugin_name: str = "") -> int:
+        """Clear events, optionally filtered by plugin name.
+
+        Returns the number of events removed.
+        """
+        if plugin_name:
+            before = len(self._events)
+            self._events = [
+                e for e in self._events if e.plugin_name != plugin_name
+            ]
+            return before - len(self._events)
+        else:
+            count = len(self._events)
+            self._events.clear()
+            return count
+
+    @property
+    def count(self) -> int:
+        """Total number of stored events."""
+        return len(self._events)
