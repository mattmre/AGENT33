+"""API route tests for Track Phase 3 plugin lifecycle endpoints.
+
+Tests use a TestClient with a minimal app that has mocked plugin
+services on app.state.
+"""
+
+from __future__ import annotations
+
+from pathlib import Path
+from typing import Any
+from unittest.mock import MagicMock
+
+import pytest
+from fastapi import FastAPI
+from fastapi.testclient import TestClient
+
+from agent33.api.routes.plugins import router as plugin_router
+from agent33.plugins.api_models import (
+    PluginDoctorCheckResponse,
+    PluginDoctorResponse,
+    PluginInstallResponse,
+)
+from agent33.plugins.doctor import PluginDoctorCheck, PluginDoctorReport
+from agent33.plugins.events import PluginEventEmitter
+from agent33.plugins.installer import PluginInstallResult
+from agent33.plugins.models import PluginState
+from agent33.security.auth import create_access_token
+
+
+def _make_app() -> FastAPI:
+    """Create a minimal FastAPI app with plugin routes and mock services."""
+    test_app = FastAPI()
+    test_app.include_router(plugin_router)
+
+    # Auth middleware bypass: set user on request state
+    from starlette.middleware.base import BaseHTTPMiddleware
+
+    class FakeAuthMiddleware(BaseHTTPMiddleware):
+        async def dispatch(self, request: Any, call_next: Any) -> Any:
+            request.state.user = MagicMock(
+                scopes=["admin", "plugins:read", "plugins:write"],
+                tenant_id="test-tenant",
+            )
+            return await call_next(request)
+
+    test_app.add_middleware(FakeAuthMiddleware)
+    return test_app
+
+
+def _make_mock_entry(
+    name: str = "test-plugin", version: str = "1.0.0", state: str = "discovered"
+) -> MagicMock:
+    """Create a mock plugin entry."""
+    entry = MagicMock()
+    entry.manifest.name = name
+    entry.manifest.version = version
+    entry.manifest.description = f"Test {name}"
+    entry.manifest.author = "test"
+    entry.manifest.tags = ["test"]
+    entry.manifest.contributions.skills = []
+    entry.manifest.contributions.tools = []
+    entry.manifest.contributions.agents = []
+    entry.manifest.contributions.hooks = []
+    entry.manifest.license = "MIT"
+    entry.manifest.homepage = ""
+    entry.manifest.repository = ""
+    entry.manifest.status.value = "active"
+    entry.manifest.permissions = []
+    entry.manifest.dependencies = []
+    entry.state = PluginState(state)
+    entry.error = None
+    entry.instance = None
+    return entry
+
+
+class TestPluginInstallRoute:
+    """Tests for POST /v1/plugins/install."""
+
+    def test_install_success(self) -> None:
+        app = _make_app()
+        mock_installer = MagicMock()
+        mock_installer.install_from_local.return_value = PluginInstallResult(
+            success=True,
+            plugin_name="new-plugin",
+            version="1.0.0",
+        )
+
+        mock_registry = MagicMock()
+        app.state.plugin_registry = mock_registry
+        app.state.plugin_installer = mock_installer
+        app.state.plugin_event_emitter = PluginEventEmitter()
+
+        client = TestClient(app)
+        resp = client.post(
+            "/v1/plugins/install",
+            json={"source_type": "local", "path": "/some/path"},
+        )
+
+        assert resp.status_code == 201
+        data = resp.json()
+        assert data["success"] is True
+        assert data["plugin_name"] == "new-plugin"
+        assert data["version"] == "1.0.0"
+
+    def test_install_failure_returns_400(self) -> None:
+        app = _make_app()
+        mock_installer = MagicMock()
+        mock_installer.install_from_local.return_value = PluginInstallResult(
+            success=False,
+            plugin_name="bad-plugin",
+            errors=["Directory not found"],
+        )
+
+        app.state.plugin_registry = MagicMock()
+        app.state.plugin_installer = mock_installer
+        app.state.plugin_event_emitter = None
+
+        client = TestClient(app)
+        resp = client.post(
+            "/v1/plugins/install",
+            json={"source_type": "local", "path": "/bad/path"},
+        )
+
+        assert resp.status_code == 400
+
+    def test_install_invalid_source_type(self) -> None:
+        app = _make_app()
+        app.state.plugin_registry = MagicMock()
+        app.state.plugin_installer = MagicMock()
+
+        client = TestClient(app)
+        resp = client.post(
+            "/v1/plugins/install",
+            json={"source_type": "unknown", "path": "/some/path"},
+        )
+
+        assert resp.status_code == 400
+        assert "Unsupported source type" in resp.json()["detail"]
+
+    def test_install_emits_lifecycle_event(self) -> None:
+        app = _make_app()
+        mock_installer = MagicMock()
+        mock_installer.install_from_local.return_value = PluginInstallResult(
+            success=True,
+            plugin_name="evented",
+            version="1.0.0",
+        )
+
+        emitter = PluginEventEmitter()
+        app.state.plugin_registry = MagicMock()
+        app.state.plugin_installer = mock_installer
+        app.state.plugin_event_emitter = emitter
+
+        client = TestClient(app)
+        client.post(
+            "/v1/plugins/install",
+            json={"source_type": "local", "path": "/some/path"},
+        )
+
+        events = emitter.get_events(plugin_name="evented")
+        assert len(events) == 1
+        assert events[0].event_type == "installed"
+
+
+class TestPluginUpdateRoute:
+    """Tests for POST /v1/plugins/{name}/update."""
