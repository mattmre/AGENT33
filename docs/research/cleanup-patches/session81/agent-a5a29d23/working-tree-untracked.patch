+"""Tests for pack audit trail recording."""
+
+from __future__ import annotations
+
+from agent33.packs.audit import PackAuditLog
+
+
+class TestPackAuditLog:
+    """Tests for PackAuditLog."""
+
+    def test_record_creates_entry(self) -> None:
+        log = PackAuditLog()
+        entry = log.record("test-pack", "installed", version="1.0.0")
+
+        assert entry.pack_name == "test-pack"
+        assert entry.action == "installed"
+        assert entry.version == "1.0.0"
+        assert entry.timestamp is not None
+
+    def test_record_with_all_fields(self) -> None:
+        log = PackAuditLog()
+        entry = log.record(
+            "test-pack",
+            "enabled",
+            version="1.0.0",
+            tenant_id="tenant-a",
+            actor="admin-user",
+            details={"source": "marketplace"},
+        )
+
+        assert entry.tenant_id == "tenant-a"
+        assert entry.actor == "admin-user"
+        assert entry.details == {"source": "marketplace"}
+
+    def test_query_all(self) -> None:
+        log = PackAuditLog()
+        log.record("pack-a", "installed")
+        log.record("pack-b", "installed")
+        log.record("pack-a", "enabled")
+
+        entries = log.query()
+
+        assert len(entries) == 3
+        # Newest first
+        assert entries[0].action == "enabled"
+        assert entries[1].pack_name == "pack-b"
+        assert entries[2].pack_name == "pack-a"
+
+    def test_query_by_pack_name(self) -> None:
+        log = PackAuditLog()
+        log.record("pack-a", "installed")
+        log.record("pack-b", "installed")
+        log.record("pack-a", "enabled")
+
+        entries = log.query(pack_name="pack-a")
+
+        assert len(entries) == 2
+        assert all(e.pack_name == "pack-a" for e in entries)
+
+    def test_query_by_action(self) -> None:
+        log = PackAuditLog()
+        log.record("pack-a", "installed")
+        log.record("pack-b", "installed")
+        log.record("pack-a", "enabled")
+
+        entries = log.query(action="installed")
+
+        assert len(entries) == 2
+        assert all(e.action == "installed" for e in entries)
+
+    def test_query_by_tenant(self) -> None:
+        log = PackAuditLog()
+        log.record("pack-a", "enabled", tenant_id="t1")
+        log.record("pack-a", "enabled", tenant_id="t2")
+
+        entries = log.query(tenant_id="t1")
+
+        assert len(entries) == 1
+        assert entries[0].tenant_id == "t1"
+
+    def test_query_with_limit(self) -> None:
+        log = PackAuditLog()
+        for i in range(10):
+            log.record(f"pack-{i}", "installed")
+
+        entries = log.query(limit=3)
+        assert len(entries) == 3
+
+    def test_max_entries_trimming(self) -> None:
+        log = PackAuditLog(max_entries=5)
+
+        for i in range(10):
+            log.record(f"pack-{i}", "installed")
+
+        assert log.count == 5
+
+        entries = log.query()
+        # Should have the 5 most recent
+        assert entries[0].pack_name == "pack-9"
+        assert entries[4].pack_name == "pack-5"
+
+    def test_clear(self) -> None:
+        log = PackAuditLog()
+        log.record("pack-a", "installed")
+        log.record("pack-b", "installed")
+
+        removed = log.clear()
+        assert removed == 2
+        assert log.count == 0
+
+    def test_count_property(self) -> None:
+        log = PackAuditLog()
+        assert log.count == 0
+
+        log.record("pack-a", "installed")
+        assert log.count == 1
+
+    def test_combined_filters(self) -> None:
+        log = PackAuditLog()
+        log.record("pack-a", "installed", tenant_id="t1")
+        log.record("pack-a", "enabled", tenant_id="t1")
+        log.record("pack-b", "installed", tenant_id="t1")
+        log.record("pack-a", "installed", tenant_id="t2")
+
+        entries = log.query(pack_name="pack-a", action="installed")
+
+        assert len(entries) == 2
+        assert all(e.pack_name == "pack-a" for e in entries)
+        assert all(e.action == "installed" for e in entries)
