+++ b/engine/src/agent33/plugins/installer.py
@@ -0,0 +1,487 @@
+"""Plugin installation pipeline: install from local path, archive, or registry.
+
+Handles extracting archives, validating manifests, copying to the plugins
+directory, and recording provenance for each installation.
+"""
+
+from __future__ import annotations
+
+import hashlib
+import shutil
+import tarfile
+import zipfile
+from datetime import UTC, datetime
+from pathlib import Path
+from typing import TYPE_CHECKING
+
+import structlog
+from pydantic import BaseModel, Field
+
+from agent33.plugins.loader import load_manifest
+from agent33.plugins.version import satisfies_constraint
+
+if TYPE_CHECKING:
+    from agent33.plugins.registry import PluginRegistry
+
+logger = structlog.get_logger()
+
+
+class PluginInstallProvenance(BaseModel):
+    """Records how and when a plugin was installed."""
+
+    source_type: str
+    source_path: str
+    version: str
+    installed_at: datetime = Field(default_factory=lambda: datetime.now(UTC))
+    integrity_hash: str = ""
+    installer_identity: str = ""
+
+
+class PluginInstallResult(BaseModel):
+    """Result of a plugin installation attempt."""
+
+    success: bool
+    plugin_name: str
+    version: str = ""
+    errors: list[str] = Field(default_factory=list)
+    warnings: list[str] = Field(default_factory=list)
+    provenance: PluginInstallProvenance | None = None
+
+
+def _compute_dir_hash(path: Path) -> str:
+    """Compute a sha256 hash of a directory's contents for integrity tracking."""
+    h = hashlib.sha256()
+    for file_path in sorted(path.rglob("*")):
+        if file_path.is_file():
+            h.update(str(file_path.relative_to(path)).encode("utf-8"))
+            h.update(file_path.read_bytes())
+    return h.hexdigest()
+
+
+def _extract_archive(archive_path: Path, dest_dir: Path) -> Path:
+    """Extract a tar.gz or zip archive to dest_dir.
+
+    Returns the path to the extracted plugin directory (the single
+    top-level directory inside the archive, or dest_dir itself if
+    the archive extracts flat files).
+
+    Raises:
+        ValueError: If the archive format is unsupported or extraction fails.
+    """
+    if archive_path.suffixes[-2:] == [".tar", ".gz"] or archive_path.suffix == ".tgz":
+        with tarfile.open(archive_path, "r:gz") as tf:
+            # Security: check for path traversal
+            for member in tf.getmembers():
+                member_path = Path(member.name)
+                if member_path.is_absolute() or ".." in member_path.parts:
+                    raise ValueError(
+                        f"Archive contains unsafe path: {member.name}"
+                    )
+            tf.extractall(dest_dir)  # noqa: S202
+    elif archive_path.suffix == ".zip":
+        with zipfile.ZipFile(archive_path, "r") as zf:
+            for name in zf.namelist():
+                member_path = Path(name)
+                if member_path.is_absolute() or ".." in member_path.parts:
+                    raise ValueError(f"Archive contains unsafe path: {name}")
+            zf.extractall(dest_dir)
+    else:
+        raise ValueError(
+            f"Unsupported archive format: {archive_path.suffix}. "
+            f"Supported formats: .tar.gz, .tgz, .zip"
+        )
+
+    # Find the top-level directory
+    entries = [e for e in dest_dir.iterdir() if e.is_dir()]
+    if len(entries) == 1:
+        return entries[0]
+    return dest_dir
+
+
+class PluginInstaller:
+    """Handles plugin installation from multiple source types.
+
+    Supports:
+    - Local directory copy
+    - Archive extraction (.tar.gz, .zip)
+    - Registry spec resolution (stub for future remote registry)
+    - Symlink-based dev linking
+    """
+
+    def __init__(self, plugin_registry: PluginRegistry, plugins_dir: Path) -> None:
+        self._registry = plugin_registry
+        self._plugins_dir = plugins_dir
+        self._plugins_dir.mkdir(parents=True, exist_ok=True)
+        self._provenance: dict[str, PluginInstallProvenance] = {}
+
+    @property
+    def provenance_store(self) -> dict[str, PluginInstallProvenance]:
+        """Access recorded provenance entries."""
+        return dict(self._provenance)
+
+    def install_from_local(
+        self, path: Path, *, version_pin: str = ""
+    ) -> PluginInstallResult:
+        """Install a plugin from a local directory by copying it.
+
+        Args:
+            path: Path to the plugin source directory.
+            version_pin: If set, validate that the manifest version matches.
+
+        Returns:
+            PluginInstallResult describing the outcome.
+        """
+        if not path.is_dir():
+            return PluginInstallResult(
+                success=False,
+                plugin_name="unknown",
+                errors=[f"Plugin directory not found: {path}"],
+            )
+
+        try:
+            manifest = load_manifest(path)
+        except FileNotFoundError:
+            return PluginInstallResult(
+                success=False,
+                plugin_name="unknown",
+                errors=[f"No plugin manifest found in {path}"],
+            )
+        except Exception as exc:
+            return PluginInstallResult(
+                success=False,
+                plugin_name="unknown",
+                errors=[f"Failed to parse manifest: {exc}"],
+            )
+
+        if version_pin and manifest.version != version_pin:
+            return PluginInstallResult(
+                success=False,
+                plugin_name=manifest.name,
+                version=manifest.version,
+                errors=[
+                    f"Version mismatch: expected '{version_pin}' "
+                    f"but manifest declares '{manifest.version}'"
+                ],
+            )
+
+        # Check if already registered
+        existing = self._registry.get(manifest.name)
+        if existing is not None:
+            return PluginInstallResult(
+                success=False,
+                plugin_name=manifest.name,
+                version=manifest.version,
+                errors=[
+                    f"Plugin '{manifest.name}' is already installed. "
+                    f"Use update to change versions."
+                ],
+            )
+
+        # Check version constraints against existing plugins
+        warnings = self._check_dependency_compatibility(manifest)
+
+        # Copy to plugins dir
+        dest = self._plugins_dir / manifest.name
+        if dest.exists():
+            shutil.rmtree(dest)
+        shutil.copytree(path, dest)
+
+        # Discover the newly installed plugin
+        integrity = _compute_dir_hash(dest)
+        self._registry.discover(self._plugins_dir)
+
+        provenance = PluginInstallProvenance(
+            source_type="local",
+            source_path=str(path),
+            version=manifest.version,
+            integrity_hash=integrity,
+        )
+        self._provenance[manifest.name] = provenance
+
+        logger.info(
+            "plugin_installed",
+            name=manifest.name,
+            version=manifest.version,
+            source="local",
+        )
+
+        return PluginInstallResult(
+            success=True,
+            plugin_name=manifest.name,
+            version=manifest.version,
+            warnings=warnings,
+            provenance=provenance,
+        )
+
+    def install_from_archive(self, archive_path: Path) -> PluginInstallResult:
+        """Install a plugin from a .tar.gz or .zip archive.
+
+        The archive is extracted to a temporary directory, validated,
+        then copied to the plugins directory.
+        """
+        if not archive_path.is_file():
+            return PluginInstallResult(
+                success=False,
+                plugin_name="unknown",
+                errors=[f"Archive not found: {archive_path}"],
+            )
+
+        import tempfile
+
+        tmp_dir = Path(tempfile.mkdtemp(prefix="agent33_plugin_"))
+        try:
+            extracted = _extract_archive(archive_path, tmp_dir)
+            result = self.install_from_local(extracted)
+            if result.success and result.provenance is not None:
+                # Update provenance to reflect archive source
+                result.provenance.source_type = "archive"
+                result.provenance.source_path = str(archive_path)
+                self._provenance[result.plugin_name] = result.provenance
+            return result
+        except ValueError as exc:
+            return PluginInstallResult(
+                success=False,
+                plugin_name="unknown",
+                errors=[str(exc)],
+            )
+        finally:
+            shutil.rmtree(tmp_dir, ignore_errors=True)
+
+    def install_from_registry(
+        self, spec: str, *, prerelease: bool = False
+    ) -> PluginInstallResult:
+        """Install a plugin from a registry spec (e.g., 'my-plugin@1.2.0').
+
+        Currently a stub -- returns an error indicating no remote registry
+        is configured. The interface is preserved for future HTTP registry
+        implementation.
+        """
+        parts = spec.split("@", 1)
+        name = parts[0]
+        version = parts[1] if len(parts) > 1 else ""
+
+        return PluginInstallResult(
+            success=False,
+            plugin_name=name,
+            version=version,
+            errors=[
+                "Remote plugin registry is not configured. "
+                "Use install_from_local or install_from_archive instead."
+            ],
+        )
+
+    def update(
+        self, name: str, new_source: Path, *, target_version: str = ""
+    ) -> PluginInstallResult:
+        """Update an installed plugin to a new version.
+
+        Unloads the old plugin, copies the new source, and re-discovers.
+
+        Args:
+            name: Name of the installed plugin to update.
+            new_source: Path to the new version source directory.
+            target_version: If set, validate the new version matches.
+        """
+        existing = self._registry.get(name)
+        if existing is None:
+            return PluginInstallResult(
+                success=False,
+                plugin_name=name,
+                errors=[f"Plugin '{name}' is not installed"],
+            )
+
+        if not new_source.is_dir():
+            return PluginInstallResult(
+                success=False,
+                plugin_name=name,
+                errors=[f"Update source directory not found: {new_source}"],
+            )
+
+        try:
+            new_manifest = load_manifest(new_source)
+        except Exception as exc:
+            return PluginInstallResult(
+                success=False,
+                plugin_name=name,
+                errors=[f"Failed to parse new manifest: {exc}"],
+            )
+
+        if new_manifest.name != name:
+            return PluginInstallResult(
+                success=False,
+                plugin_name=name,
+                errors=[
+                    f"Name mismatch: expected '{name}' but "
+                    f"new source declares '{new_manifest.name}'"
+                ],
+            )
+
+        if target_version and new_manifest.version != target_version:
+            return PluginInstallResult(
+                success=False,
+                plugin_name=name,
+                errors=[
+                    f"Version mismatch: expected '{target_version}' "
+                    f"but new source declares '{new_manifest.version}'"
+                ],
+            )
+
+        old_version = existing.manifest.version
+
+        # Remove old entry from registry so install_from_local succeeds
+        if existing.state.value not in ("discovered", "unloaded"):
+            # Must unload first -- but we can't await here since this is sync.
+            # Remove the entry directly so re-discovery works.
+            self._registry.remove(name)
+        else:
+            self._registry.remove(name)
+
+        # Copy new source over
+        dest = self._plugins_dir / name
+        if dest.exists():
+            shutil.rmtree(dest)
+        shutil.copytree(new_source, dest)
+
+        integrity = _compute_dir_hash(dest)
+        self._registry.discover(self._plugins_dir)
+
+        provenance = PluginInstallProvenance(
+            source_type="update",
+            source_path=str(new_source),
+            version=new_manifest.version,
+            integrity_hash=integrity,
+        )
+        self._provenance[name] = provenance
+
+        logger.info(
+            "plugin_updated",
+            name=name,
+            old_version=old_version,
+            new_version=new_manifest.version,
+        )
+
+        return PluginInstallResult(
+            success=True,
+            plugin_name=name,
+            version=new_manifest.version,
+            provenance=provenance,
+        )
+
+    def uninstall(self, name: str) -> PluginInstallResult:
+        """Uninstall a plugin by removing it from the plugins directory.
+
+        The plugin must be in DISCOVERED or UNLOADED state (caller is
+        responsible for unloading first).
+        """
+        existing = self._registry.get(name)
+        if existing is None:
+            return PluginInstallResult(
+                success=False,
+                plugin_name=name,
+                errors=[f"Plugin '{name}' is not installed"],
+            )
+
+        try:
+            self._registry.remove(name)
+        except RuntimeError as exc:
+            return PluginInstallResult(
+                success=False,
+                plugin_name=name,
+                errors=[str(exc)],
+            )
+
+        # Remove from disk
+        dest = self._plugins_dir / name
+        if dest.exists():
+            shutil.rmtree(dest)
+
+        # Remove provenance
+        self._provenance.pop(name, None)
+
+        logger.info("plugin_uninstalled", name=name)
+
+        return PluginInstallResult(
+            success=True,
+            plugin_name=name,
+        )
+
+    def link(self, name: str, local_path: Path) -> PluginInstallResult:
+        """Create a symlink from plugins_dir/name to a local dev directory.
+
+        This allows developing a plugin in-place without copying.
+        """
+        if not local_path.is_dir():
+            return PluginInstallResult(
+                success=False,
+                plugin_name=name,
+                errors=[f"Link target not found: {local_path}"],
+            )
+
+        try:
+            manifest = load_manifest(local_path)
+        except Exception as exc:
+            return PluginInstallResult(
+                success=False,
+                plugin_name=name,
+                errors=[f"Failed to parse manifest at link target: {exc}"],
+            )
+
+        dest = self._plugins_dir / name
+        if dest.exists():
+            if dest.is_symlink():
+                dest.unlink()
+            else:
+                return PluginInstallResult(
+                    success=False,
+                    plugin_name=name,
+                    errors=[
+                        f"Plugin '{name}' already exists as a regular directory. "
+                        f"Uninstall it first."
+                    ],
+                )
+
+        dest.symlink_to(local_path.resolve(), target_is_directory=True)
+        self._registry.discover(self._plugins_dir)
+
+        provenance = PluginInstallProvenance(
+            source_type="link",
+            source_path=str(local_path),
+            version=manifest.version,
+        )
+        self._provenance[name] = provenance
+
+        return PluginInstallResult(
+            success=True,
+            plugin_name=manifest.name,
+            version=manifest.version,
+            provenance=provenance,
+        )
+
+    def get_provenance(self, name: str) -> PluginInstallProvenance | None:
+        """Retrieve provenance for an installed plugin."""
+        return self._provenance.get(name)
+
+    def _check_dependency_compatibility(self, manifest: object) -> list[str]:
+        """Check if the manifest's dependencies are compatible with installed plugins."""
+        from agent33.plugins.manifest import PluginManifest
+
+        warnings: list[str] = []
+        if not isinstance(manifest, PluginManifest):
+            return warnings
+
+        for dep in manifest.dependencies:
+            dep_entry = self._registry.get(dep.name)
+            if dep_entry is None:
+                if not dep.optional:
+                    warnings.append(
+                        f"Required dependency '{dep.name}' is not installed"
+                    )
+            elif dep.version_constraint != "*" and not satisfies_constraint(
+                dep_entry.manifest.version, dep.version_constraint
+            ):
+                warnings.append(
+                    f"Dependency '{dep.name}' version {dep_entry.manifest.version} "
+                    f"does not satisfy constraint {dep.version_constraint}"
+                )
+
+        return warnings
