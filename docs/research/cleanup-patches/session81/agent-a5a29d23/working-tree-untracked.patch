+"""Pack rollback manager: revert to previous pack versions.
+
+Manages archiving of current pack versions before upgrades and restoring
+them when rollback is requested. Tenant enablement is preserved across
+rollback operations.
+"""
+
+from __future__ import annotations
+
+import shutil
+from datetime import UTC, datetime
+from pathlib import Path
+from typing import TYPE_CHECKING
+
+import structlog
+from pydantic import BaseModel, Field
+
+if TYPE_CHECKING:
+    from agent33.packs.models import InstallResult
+    from agent33.packs.registry import PackRegistry
+
+logger = structlog.get_logger()
+
+
+class ArchivedPackVersion(BaseModel):
+    """Metadata for an archived pack version."""
+
+    pack_name: str
+    version: str
+    archive_dir: str
+    archived_at: datetime = Field(default_factory=lambda: datetime.now(UTC))
+    enablement_snapshot: dict[str, bool] = Field(default_factory=dict)
+
+
+class PackRollbackManager:
+    """Manages rollback to previous pack versions.
+
+    Archives the current version before upgrade and restores it on
+    rollback, preserving tenant enablement state.
+    """
+
+    def __init__(self, pack_registry: PackRegistry, archive_dir: Path) -> None:
+        self._registry = pack_registry
+        self._archive_dir = archive_dir
+        self._archive_dir.mkdir(parents=True, exist_ok=True)
+        self._archives: dict[str, list[ArchivedPackVersion]] = {}
+
+    def archive_current(self, pack_name: str) -> ArchivedPackVersion | None:
+        """Archive the current version of a pack before upgrade.
+
+        Returns the archive record, or None if the pack is not installed.
+        """
+        pack = self._registry.get(pack_name)
+        if pack is None:
+            return None
+
+        # Snapshot tenant enablement
+        enablement: dict[str, bool] = {}
+        for tenant_id, enabled_set in self._registry._enabled.items():
+            enablement[tenant_id] = pack_name in enabled_set
+
+        # Copy pack directory to archive
+        timestamp = datetime.now(UTC).strftime("%Y%m%d_%H%M%S")
+        archive_dest = self._archive_dir / pack_name / f"{pack.version}_{timestamp}"
+        archive_dest.mkdir(parents=True, exist_ok=True)
+
+        if pack.pack_dir.is_dir():
+            shutil.copytree(pack.pack_dir, archive_dest / "pack", dirs_exist_ok=True)
+
+        record = ArchivedPackVersion(
+            pack_name=pack_name,
+            version=pack.version,
+            archive_dir=str(archive_dest),
+            enablement_snapshot=enablement,
+        )
+
+        self._archives.setdefault(pack_name, []).append(record)
+
+        logger.info(
+            "pack_archived",
+            name=pack_name,
+            version=pack.version,
+            archive_dir=str(archive_dest),
+        )
+
+        return record
+
+    def rollback(self, pack_name: str) -> InstallResult:
+        """Rollback to the most recently archived version.
+
+        Steps:
+        1. Find the latest archive
+        2. Uninstall current version
+        3. Install archived version
+        4. Restore tenant enablement from the snapshot
+
+        Raises:
+            ValueError: If no archive is available for the pack.
+        """
+        from agent33.packs.models import InstallResult, PackSource
+
+        archives = self._archives.get(pack_name, [])
+        if not archives:
+            return InstallResult(
+                success=False,
+                pack_name=pack_name,
+                errors=[f"No archived versions available for pack '{pack_name}'"],
+            )
+
+        archive = archives[-1]
+        archived_pack_dir = Path(archive.archive_dir) / "pack"
+
+        if not archived_pack_dir.is_dir():
+            return InstallResult(
+                success=False,
+                pack_name=pack_name,
+                errors=[
+                    f"Archived pack directory not found: {archived_pack_dir}"
+                ],
+            )
+
+        # Uninstall current version if installed
+        current = self._registry.get(pack_name)
+        if current is not None:
+            try:
+                self._registry.uninstall(pack_name)
+            except ValueError as exc:
+                return InstallResult(
+                    success=False,
+                    pack_name=pack_name,
+                    errors=[f"Failed to uninstall current version: {exc}"],
+                )
+
+        # Install from archived directory
+        result = self._registry.install(
+            PackSource(source_type="local", path=str(archived_pack_dir), name=pack_name)
+        )
+
+        if not result.success:
+            return result
+
+        # Restore tenant enablement
+        for tenant_id, was_enabled in archive.enablement_snapshot.items():
+            if was_enabled:
+                try:
+                    self._registry.enable(pack_name, tenant_id)
+                except ValueError:
+                    pass  # Pack might not be installed -- skip silently
+
+        # Remove the used archive from the list
+        archives.pop()
+
+        logger.info(
+            "pack_rolled_back",
+            name=pack_name,
+            restored_version=archive.version,
+        )
+
+        return InstallResult(
+            success=True,
+            pack_name=pack_name,
+            version=archive.version,
+            skills_loaded=result.skills_loaded,
+        )
+
+    def list_archived_versions(self, pack_name: str) -> list[str]:
+        """List available rollback versions for a pack, newest first."""
+        archives = self._archives.get(pack_name, [])
+        return [a.version for a in reversed(archives)]
+
+    def has_archive(self, pack_name: str) -> bool:
+        """Check if at least one archived version exists."""
+        return bool(self._archives.get(pack_name))
