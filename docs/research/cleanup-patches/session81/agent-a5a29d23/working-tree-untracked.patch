+
+        result = installer.update("test-plugin", source / "test-plugin")
+        assert result.success is False
+        assert "not installed" in result.errors[0]
+
+    def test_update_name_mismatch(self, tmp_path: Path) -> None:
+        source_v1 = tmp_path / "source_v1"
+        source_v2 = tmp_path / "source_v2"
+        plugins_dir = tmp_path / "plugins"
+        plugins_dir.mkdir()
+
+        _create_plugin_dir(source_v1, "test-plugin", "1.0.0")
+        _create_plugin_dir(source_v2, "other-plugin", "2.0.0")
+
+        registry = PluginRegistry()
+        installer = PluginInstaller(registry, plugins_dir)
+
+        installer.install_from_local(source_v1 / "test-plugin")
+        result = installer.update("test-plugin", source_v2 / "other-plugin")
+
+        assert result.success is False
+        assert "Name mismatch" in result.errors[0]
+
+    def test_update_version_pin(self, tmp_path: Path) -> None:
+        source_v1 = tmp_path / "source_v1"
+        source_v2 = tmp_path / "source_v2"
+        plugins_dir = tmp_path / "plugins"
+        plugins_dir.mkdir()
+
+        _create_plugin_dir(source_v1, "test-plugin", "1.0.0")
+        _create_plugin_dir(source_v2, "test-plugin", "2.0.0")
