+"""Tests for pack rollback manager: archiving, rollback, enablement preservation."""
+
+from __future__ import annotations
+
+from pathlib import Path
+from unittest.mock import MagicMock, PropertyMock
+
+import pytest
+import yaml
+
+from agent33.packs.models import InstalledPack, InstallResult, PackSource, PackStatus
+from agent33.packs.rollback import PackRollbackManager
+
+
+def _make_mock_registry(
+    installed: dict[str, InstalledPack] | None = None,
+    enabled: dict[str, set[str]] | None = None,
+) -> MagicMock:
+    """Create a mock PackRegistry."""
+    registry = MagicMock()
+    installed = installed or {}
+    enabled = enabled or {}
+
+    registry._installed = installed
+    registry._enabled = enabled
+
+    def get_side_effect(name: str) -> InstalledPack | None:
+        return installed.get(name)
+
+    registry.get.side_effect = get_side_effect
+
+    def uninstall_side_effect(name: str) -> bool:
+        if name not in installed:
+            raise ValueError(f"Pack '{name}' is not installed")
+        del installed[name]
+        return True
+
+    registry.uninstall.side_effect = uninstall_side_effect
+
+    def install_side_effect(source: PackSource) -> InstallResult:
+        return InstallResult(
+            success=True,
+            pack_name=source.name or "unknown",
+            version="1.0.0",
+            skills_loaded=2,
+        )
+
+    registry.install.side_effect = install_side_effect
+
+    def enable_side_effect(name: str, tenant_id: str) -> bool:
+        if name not in installed and name not in [
+            s.name for s in [source for source in []]
+        ]:
+            # After install from rollback, mock won't have it in installed
+            pass
+        enabled.setdefault(tenant_id, set()).add(name)
+        return True
+
+    registry.enable.side_effect = enable_side_effect
+
+    return registry
+
+
+def _make_installed_pack(
+    name: str, version: str, pack_dir: Path
+) -> InstalledPack:
+    """Create an InstalledPack for testing."""
+    return InstalledPack(
+        name=name,
+        version=version,
+        description=f"Test pack {name}",
+        pack_dir=pack_dir,
+        status=PackStatus.INSTALLED,
+    )
+
+
+class TestPackRollbackManager:
+    """Tests for PackRollbackManager."""
+
+    def test_archive_current(self, tmp_path: Path) -> None:
+        pack_dir = tmp_path / "packs" / "test-pack"
+        pack_dir.mkdir(parents=True)
+        (pack_dir / "PACK.yaml").write_text("name: test-pack\nversion: 1.0.0")
+
+        pack = _make_installed_pack("test-pack", "1.0.0", pack_dir)
+        registry = _make_mock_registry(
+            installed={"test-pack": pack},
+            enabled={"tenant-a": {"test-pack"}, "tenant-b": set()},
+        )
+
+        archive_dir = tmp_path / "archives"
+        manager = PackRollbackManager(registry, archive_dir)
+
+        record = manager.archive_current("test-pack")
+
+        assert record is not None
+        assert record.pack_name == "test-pack"
+        assert record.version == "1.0.0"
+        assert record.enablement_snapshot["tenant-a"] is True
+        assert record.enablement_snapshot["tenant-b"] is False
+        assert Path(record.archive_dir).is_dir()
+
+    def test_archive_nonexistent_returns_none(self, tmp_path: Path) -> None:
+        registry = _make_mock_registry()
+        manager = PackRollbackManager(registry, tmp_path / "archives")
+
+        record = manager.archive_current("nonexistent")
+        assert record is None
+
+    def test_rollback_no_archive(self, tmp_path: Path) -> None:
+        registry = _make_mock_registry()
+        manager = PackRollbackManager(registry, tmp_path / "archives")
+
+        result = manager.rollback("test-pack")
+
+        assert result.success is False
+        assert "No archived versions" in result.errors[0]
+
+    def test_rollback_restores_version(self, tmp_path: Path) -> None:
+        pack_dir = tmp_path / "packs" / "test-pack"
+        pack_dir.mkdir(parents=True)
+        (pack_dir / "PACK.yaml").write_text(
+            yaml.dump({"name": "test-pack", "version": "1.0.0"})
+        )
+
+        pack = _make_installed_pack("test-pack", "2.0.0", pack_dir)
+        installed: dict[str, InstalledPack] = {"test-pack": pack}
+        enabled: dict[str, set[str]] = {"tenant-a": {"test-pack"}}
+
+        registry = _make_mock_registry(installed=installed, enabled=enabled)
+
+        archive_dir = tmp_path / "archives"
+        manager = PackRollbackManager(registry, archive_dir)
+
+        # Archive v2.0.0
+        manager.archive_current("test-pack")
+
+        # Rollback
+        result = manager.rollback("test-pack")
+
+        assert result.success is True
+        assert result.version == "2.0.0"
+
+    def test_rollback_preserves_enablement(self, tmp_path: Path) -> None:
+        pack_dir = tmp_path / "packs" / "test-pack"
+        pack_dir.mkdir(parents=True)
+        (pack_dir / "PACK.yaml").write_text(
+            yaml.dump({"name": "test-pack", "version": "1.0.0"})
+        )
+
+        pack = _make_installed_pack("test-pack", "1.0.0", pack_dir)
+        installed: dict[str, InstalledPack] = {"test-pack": pack}
+        enabled: dict[str, set[str]] = {
+            "tenant-a": {"test-pack"},
+            "tenant-b": set(),
+        }
+
+        registry = _make_mock_registry(installed=installed, enabled=enabled)
+
+        archive_dir = tmp_path / "archives"
+        manager = PackRollbackManager(registry, archive_dir)
+
+        manager.archive_current("test-pack")
+        manager.rollback("test-pack")
+
+        # Verify enable was called for tenant-a (which had pack enabled)
+        enable_calls = registry.enable.call_args_list
+        enabled_tenants = {call.args[1] for call in enable_calls}
+        assert "tenant-a" in enabled_tenants
+
+    def test_list_archived_versions(self, tmp_path: Path) -> None:
+        pack_dir = tmp_path / "packs" / "test-pack"
+        pack_dir.mkdir(parents=True)
+        (pack_dir / "file.txt").write_text("content")
+
+        pack_v1 = _make_installed_pack("test-pack", "1.0.0", pack_dir)
+        pack_v2 = _make_installed_pack("test-pack", "2.0.0", pack_dir)
+
+        installed: dict[str, InstalledPack] = {"test-pack": pack_v1}
+        registry = _make_mock_registry(installed=installed)
+
+        archive_dir = tmp_path / "archives"
+        manager = PackRollbackManager(registry, archive_dir)
+
+        manager.archive_current("test-pack")
+
+        installed["test-pack"] = pack_v2
+        manager.archive_current("test-pack")
+
+        versions = manager.list_archived_versions("test-pack")
+        assert versions == ["2.0.0", "1.0.0"]
+
+    def test_has_archive(self, tmp_path: Path) -> None:
+        registry = _make_mock_registry()
+        manager = PackRollbackManager(registry, tmp_path / "archives")
+
+        assert manager.has_archive("test-pack") is False
+
+    def test_rollback_consumes_archive(self, tmp_path: Path) -> None:
+        pack_dir = tmp_path / "packs" / "test-pack"
+        pack_dir.mkdir(parents=True)
+        (pack_dir / "PACK.yaml").write_text(
+            yaml.dump({"name": "test-pack", "version": "1.0.0"})
+        )
+
+        pack = _make_installed_pack("test-pack", "1.0.0", pack_dir)
+        installed: dict[str, InstalledPack] = {"test-pack": pack}
+        registry = _make_mock_registry(installed=installed)
+
+        manager = PackRollbackManager(registry, tmp_path / "archives")
+        manager.archive_current("test-pack")
+
+        assert len(manager.list_archived_versions("test-pack")) == 1
+
+        manager.rollback("test-pack")
+
+        assert len(manager.list_archived_versions("test-pack")) == 0
