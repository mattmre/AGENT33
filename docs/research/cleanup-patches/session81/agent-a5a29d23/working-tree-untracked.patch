+
+def _make_app() -> FastAPI:
+    """Create a minimal FastAPI app with pack marketplace routes."""
+    test_app = FastAPI()
+    test_app.include_router(router)
+
+    from starlette.middleware.base import BaseHTTPMiddleware
+
+    class FakeAuthMiddleware(BaseHTTPMiddleware):
+        async def dispatch(self, request: Any, call_next: Any) -> Any:
+            request.state.user = MagicMock(
+                scopes=["admin", "agents:read", "agents:write"],
+                tenant_id="test-tenant",
+            )
+            return await call_next(request)
+
+    test_app.add_middleware(FakeAuthMiddleware)
+    return test_app
+
+
+def _make_pack(name: str, version: str = "1.0.0") -> InstalledPack:
+    return InstalledPack(
+        name=name,
+        version=version,
+        pack_dir=Path("/tmp/packs") / name,
+        status=PackStatus.INSTALLED,
+        checksum="abc123",
+    )
+
+
+class TestTrustPolicyRoutes:
