@@ -0,0 +1,236 @@
+"""Tests for plugin doctor: diagnostic checks on installed plugins."""
+
+from __future__ import annotations
+
+from pathlib import Path
+from unittest.mock import MagicMock
+
+import pytest
+import yaml
+
+from agent33.plugins.config_store import PluginConfigStore
+from agent33.plugins.doctor import PluginDoctor, _compute_overall_status, PluginDoctorCheck
+from agent33.plugins.models import PluginState
+from agent33.plugins.registry import PluginRegistry
+
+
+def _create_plugin_dir(
+    base: Path,
+    name: str,
+    version: str = "1.0.0",
+    *,
+    dependencies: list[dict] | None = None,
+) -> Path:
+    """Create a minimal plugin directory."""
+    plugin_dir = base / name
+    plugin_dir.mkdir(parents=True, exist_ok=True)
+
+    manifest: dict = {
+        "name": name,
+        "version": version,
+        "description": f"Test {name}",
+        "author": "test",
+        "entry_point": "plugin:Plugin",
+    }
+    if dependencies:
+        manifest["dependencies"] = dependencies
+
+    (plugin_dir / "plugin.yaml").write_text(
+        yaml.dump(manifest), encoding="utf-8"
+    )
+    (plugin_dir / "plugin.py").write_text(
+        "class Plugin:\n    pass\n", encoding="utf-8"
+    )
+    return plugin_dir
+
+
+class TestComputeOverallStatus:
+    """Tests for the status computation helper."""
+
+    def test_all_ok_is_healthy(self) -> None:
+        checks = [
+            PluginDoctorCheck(name="a", status="ok", message="good"),
+            PluginDoctorCheck(name="b", status="ok", message="fine"),
+        ]
+        assert _compute_overall_status(checks) == "healthy"
+
+    def test_warn_is_degraded(self) -> None:
+        checks = [
+            PluginDoctorCheck(name="a", status="ok", message="good"),
+            PluginDoctorCheck(name="b", status="warn", message="warning"),
+        ]
+        assert _compute_overall_status(checks) == "degraded"
+
+    def test_error_is_broken(self) -> None:
+        checks = [
+            PluginDoctorCheck(name="a", status="ok", message="good"),
+            PluginDoctorCheck(name="b", status="error", message="broken"),
+        ]
+        assert _compute_overall_status(checks) == "broken"
+
+    def test_error_overrides_warn(self) -> None:
+        checks = [
+            PluginDoctorCheck(name="a", status="warn", message="warning"),
+            PluginDoctorCheck(name="b", status="error", message="broken"),
+        ]
+        assert _compute_overall_status(checks) == "broken"
+
+
+class TestPluginDoctor:
+    """Tests for PluginDoctor.diagnose."""
+
+    def test_healthy_plugin(self, tmp_path: Path) -> None:
+        plugins_dir = tmp_path / "plugins"
+        _create_plugin_dir(plugins_dir, "healthy-plugin")
+
+        registry = PluginRegistry()
+        registry.discover(plugins_dir)
+
+        doctor = PluginDoctor(registry)
+        report = doctor.diagnose("healthy-plugin")
+
+        assert report.plugin_name == "healthy-plugin"
+        assert report.overall_status == "healthy"
+        assert all(c.status == "ok" for c in report.checks)
+
+    def test_plugin_not_found_raises(self, tmp_path: Path) -> None:
+        registry = PluginRegistry()
+        doctor = PluginDoctor(registry)
+
+        with pytest.raises(KeyError, match="not found"):
+            doctor.diagnose("nonexistent")
+
+    def test_error_state_detected(self, tmp_path: Path) -> None:
+        plugins_dir = tmp_path / "plugins"
+        _create_plugin_dir(plugins_dir, "error-plugin")
+
+        registry = PluginRegistry()
+        registry.discover(plugins_dir)
+
+        # Manually set error state
+        entry = registry.get("error-plugin")
+        assert entry is not None
+        entry.state = PluginState.ERROR
+        entry.error = "Something went wrong"
+
+        doctor = PluginDoctor(registry)
+        report = doctor.diagnose("error-plugin")
+
+        assert report.overall_status == "broken"
+        state_checks = [c for c in report.checks if c.name == "state_check"]
+        assert len(state_checks) == 1
+        assert state_checks[0].status == "error"
+        assert "Something went wrong" in state_checks[0].message
+
+    def test_missing_required_dependency(self, tmp_path: Path) -> None:
+        plugins_dir = tmp_path / "plugins"
+        _create_plugin_dir(
+            plugins_dir,
+            "dependent-plugin",
+            dependencies=[
+                {"name": "required-dep", "version_constraint": ">=1.0.0"}
+            ],
+        )
+
+        registry = PluginRegistry()
+        registry.discover(plugins_dir)
+
+        doctor = PluginDoctor(registry)
+        report = doctor.diagnose("dependent-plugin")
+
+        assert report.overall_status == "broken"
+        dep_checks = [c for c in report.checks if "required-dep" in c.name]
+        assert len(dep_checks) == 1
+        assert dep_checks[0].status == "error"
+        assert "not installed" in dep_checks[0].message
+
+    def test_optional_missing_dependency_warns(self, tmp_path: Path) -> None:
+        plugins_dir = tmp_path / "plugins"
+        _create_plugin_dir(
+            plugins_dir,
+            "opt-plugin",
+            dependencies=[
+                {
+                    "name": "optional-dep",
+                    "version_constraint": "*",
+                    "optional": True,
+                }
+            ],
+        )
+
+        registry = PluginRegistry()
+        registry.discover(plugins_dir)
+
+        doctor = PluginDoctor(registry)
+        report = doctor.diagnose("opt-plugin")
+
+        assert report.overall_status == "degraded"
+        dep_checks = [c for c in report.checks if "optional-dep" in c.name]
+        assert len(dep_checks) == 1
+        assert dep_checks[0].status == "warn"
+
+    def test_config_check_with_malformed_config(self, tmp_path: Path) -> None:
+        plugins_dir = tmp_path / "plugins"
+        config_dir = tmp_path / "config"
+
+        _create_plugin_dir(plugins_dir, "config-test")
+
+        # Create malformed config
+        plugin_config_dir = config_dir / "config-test"
+        plugin_config_dir.mkdir(parents=True)
+        (plugin_config_dir / "config.json").write_text("bad json{")
+
+        registry = PluginRegistry()
+        registry.discover(plugins_dir)
+
+        config_store = PluginConfigStore(config_dir)
+        doctor = PluginDoctor(registry, config_store=config_store)
+        report = doctor.diagnose("config-test")
+
+        config_checks = [c for c in report.checks if c.name == "config_check"]
+        assert len(config_checks) == 1
+        assert config_checks[0].status == "error"
+        assert "malformed" in config_checks[0].message.lower()
+
+    def test_config_check_no_config(self, tmp_path: Path) -> None:
+        plugins_dir = tmp_path / "plugins"
+        config_dir = tmp_path / "config"
+
+        _create_plugin_dir(plugins_dir, "no-config")
+
+        registry = PluginRegistry()
+        registry.discover(plugins_dir)
+
+        config_store = PluginConfigStore(config_dir)
+        doctor = PluginDoctor(registry, config_store=config_store)
+        report = doctor.diagnose("no-config")
+
+        config_checks = [c for c in report.checks if c.name == "config_check"]
+        assert len(config_checks) == 1
+        assert config_checks[0].status == "ok"
+        assert "defaults" in config_checks[0].message.lower()
+
+
+class TestPluginDoctorDiagnoseAll:
+    """Tests for diagnose_all."""
+
+    def test_diagnose_all_multiple_plugins(self, tmp_path: Path) -> None:
+        plugins_dir = tmp_path / "plugins"
+        _create_plugin_dir(plugins_dir, "alpha")
+        _create_plugin_dir(plugins_dir, "beta")
+
+        registry = PluginRegistry()
+        registry.discover(plugins_dir)
+
+        doctor = PluginDoctor(registry)
+        reports = doctor.diagnose_all()
+
+        assert len(reports) == 2
+        names = {r.plugin_name for r in reports}
+        assert names == {"alpha", "beta"}
+
+    def test_diagnose_all_empty_registry(self) -> None:
+        registry = PluginRegistry()
+        doctor = PluginDoctor(registry)
+        reports = doctor.diagnose_all()
+        assert reports == []
