+        assert r1.version == "1.0.0"
+
+        r2 = installer.update("test-plugin", source_v2 / "test-plugin")
+        assert r2.success is True
+        assert r2.version == "2.0.0"
+
+    def test_update_not_installed(self, tmp_path: Path) -> None:
