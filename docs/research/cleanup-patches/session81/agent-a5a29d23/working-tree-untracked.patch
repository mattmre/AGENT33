+"""Tests for plugin installer: install from local, archive, update, uninstall, link."""
+
+from __future__ import annotations
+
+from pathlib import Path
+
+import pytest
+import yaml
+
+from agent33.plugins.installer import (
+    PluginInstaller,
+    _compute_dir_hash,
+    _extract_archive,
+)
+from agent33.plugins.registry import PluginRegistry
+
+
+def _create_plugin_dir(base: Path, name: str, version: str = "1.0.0") -> Path:
+    """Create a minimal plugin directory with a valid manifest."""
+    plugin_dir = base / name
+    plugin_dir.mkdir(parents=True, exist_ok=True)
+
+    manifest = {
+        "name": name,
+        "version": version,
+        "description": f"Test plugin {name}",
+        "author": "test",
+        "entry_point": "plugin:Plugin",
+    }
+    (plugin_dir / "plugin.yaml").write_text(
+        yaml.dump(manifest), encoding="utf-8"
+    )
+
+    # Create a minimal plugin.py
+    (plugin_dir / "plugin.py").write_text(
+        "class Plugin:\n    pass\n", encoding="utf-8"
+    )
+
+    return plugin_dir
+
+
+class TestPluginInstallerLocal:
+    """Tests for install_from_local."""
+
+    def test_install_from_local_success(self, tmp_path: Path) -> None:
+        source_dir = tmp_path / "source"
+        plugins_dir = tmp_path / "plugins"
+        plugins_dir.mkdir()
+
+        plugin_dir = _create_plugin_dir(source_dir, "test-plugin")
+
+        registry = PluginRegistry()
+        installer = PluginInstaller(registry, plugins_dir)
+
+        result = installer.install_from_local(plugin_dir)
+
+        assert result.success is True
+        assert result.plugin_name == "test-plugin"
+        assert result.version == "1.0.0"
+        assert result.errors == []
+        assert result.provenance is not None
+        assert result.provenance.source_type == "local"
+
+    def test_install_from_local_nonexistent_dir(self, tmp_path: Path) -> None:
+        plugins_dir = tmp_path / "plugins"
+        plugins_dir.mkdir()
+        registry = PluginRegistry()
+        installer = PluginInstaller(registry, plugins_dir)
+
+        result = installer.install_from_local(tmp_path / "does-not-exist")
+
+        assert result.success is False
+        assert "not found" in result.errors[0]
+
+    def test_install_from_local_no_manifest(self, tmp_path: Path) -> None:
+        source_dir = tmp_path / "source" / "no-manifest"
+        source_dir.mkdir(parents=True)
+        plugins_dir = tmp_path / "plugins"
+        plugins_dir.mkdir()
+
+        registry = PluginRegistry()
+        installer = PluginInstaller(registry, plugins_dir)
+
+        result = installer.install_from_local(source_dir)
+
+        assert result.success is False
+        assert "manifest" in result.errors[0].lower()
+
+    def test_install_from_local_version_pin_mismatch(self, tmp_path: Path) -> None:
+        source_dir = tmp_path / "source"
+        plugins_dir = tmp_path / "plugins"
+        plugins_dir.mkdir()
+
+        plugin_dir = _create_plugin_dir(source_dir, "test-plugin", "1.0.0")
+
+        registry = PluginRegistry()
+        installer = PluginInstaller(registry, plugins_dir)
+
+        result = installer.install_from_local(plugin_dir, version_pin="2.0.0")
+
+        assert result.success is False
+        assert "Version mismatch" in result.errors[0]
+        assert "2.0.0" in result.errors[0]
+
+    def test_install_from_local_version_pin_match(self, tmp_path: Path) -> None:
+        source_dir = tmp_path / "source"
+        plugins_dir = tmp_path / "plugins"
+        plugins_dir.mkdir()
+
+        plugin_dir = _create_plugin_dir(source_dir, "test-plugin", "1.0.0")
+
+        registry = PluginRegistry()
+        installer = PluginInstaller(registry, plugins_dir)
+
+        result = installer.install_from_local(plugin_dir, version_pin="1.0.0")
+
+        assert result.success is True
+        assert result.version == "1.0.0"
+
+    def test_install_from_local_duplicate(self, tmp_path: Path) -> None:
+        source_dir = tmp_path / "source"
+        plugins_dir = tmp_path / "plugins"
+        plugins_dir.mkdir()
+
+        plugin_dir = _create_plugin_dir(source_dir, "test-plugin")
+
+        registry = PluginRegistry()
+        installer = PluginInstaller(registry, plugins_dir)
+
+        result1 = installer.install_from_local(plugin_dir)
+        assert result1.success is True
+
+        result2 = installer.install_from_local(plugin_dir)
+        assert result2.success is False
+        assert "already installed" in result2.errors[0]
+
+    def test_install_copies_files_to_plugins_dir(self, tmp_path: Path) -> None:
+        source_dir = tmp_path / "source"
+        plugins_dir = tmp_path / "plugins"
+        plugins_dir.mkdir()
+
+        plugin_dir = _create_plugin_dir(source_dir, "test-plugin")
+
+        registry = PluginRegistry()
+        installer = PluginInstaller(registry, plugins_dir)
+
+        result = installer.install_from_local(plugin_dir)
+        assert result.success is True
+
+        installed_dir = plugins_dir / "test-plugin"
+        assert installed_dir.is_dir()
+        assert (installed_dir / "plugin.yaml").is_file()
+        assert (installed_dir / "plugin.py").is_file()
+
+    def test_install_records_provenance(self, tmp_path: Path) -> None:
+        source_dir = tmp_path / "source"
+        plugins_dir = tmp_path / "plugins"
+        plugins_dir.mkdir()
+
+        plugin_dir = _create_plugin_dir(source_dir, "test-plugin")
+
+        registry = PluginRegistry()
+        installer = PluginInstaller(registry, plugins_dir)
+        installer.install_from_local(plugin_dir)
+
+        provenance = installer.get_provenance("test-plugin")
+        assert provenance is not None
+        assert provenance.source_type == "local"
+        assert provenance.source_path == str(plugin_dir)
+        assert provenance.integrity_hash != ""
+
+
+class TestPluginInstallerArchive:
+    """Tests for install_from_archive."""
+
+    def test_install_from_archive_zip(self, tmp_path: Path) -> None:
+        import zipfile
+
+        source_dir = tmp_path / "source"
+        plugins_dir = tmp_path / "plugins"
+        plugins_dir.mkdir()
+
+        plugin_dir = _create_plugin_dir(source_dir, "test-plugin")
+
+        # Create zip archive
+        archive_path = tmp_path / "test-plugin.zip"
+        with zipfile.ZipFile(archive_path, "w") as zf:
+            for file in plugin_dir.rglob("*"):
+                if file.is_file():
+                    zf.write(file, f"test-plugin/{file.relative_to(plugin_dir)}")
+
+        registry = PluginRegistry()
+        installer = PluginInstaller(registry, plugins_dir)
+
+        result = installer.install_from_archive(archive_path)
+
+        assert result.success is True
+        assert result.plugin_name == "test-plugin"
+        assert result.provenance is not None
+        assert result.provenance.source_type == "archive"
+
+    def test_install_from_archive_tar_gz(self, tmp_path: Path) -> None:
+        import tarfile
+
+        source_dir = tmp_path / "source"
+        plugins_dir = tmp_path / "plugins"
+        plugins_dir.mkdir()
+
+        plugin_dir = _create_plugin_dir(source_dir, "test-plugin")
+
+        archive_path = tmp_path / "test-plugin.tar.gz"
+        with tarfile.open(archive_path, "w:gz") as tf:
+            for file in plugin_dir.rglob("*"):
+                if file.is_file():
+                    tf.add(file, f"test-plugin/{file.relative_to(plugin_dir)}")
+
+        registry = PluginRegistry()
+        installer = PluginInstaller(registry, plugins_dir)
+
+        result = installer.install_from_archive(archive_path)
+
+        assert result.success is True
+        assert result.plugin_name == "test-plugin"
+
+    def test_install_from_archive_nonexistent(self, tmp_path: Path) -> None:
+        plugins_dir = tmp_path / "plugins"
+        plugins_dir.mkdir()
+
+        registry = PluginRegistry()
+        installer = PluginInstaller(registry, plugins_dir)
+
+        result = installer.install_from_archive(tmp_path / "noexist.zip")
+        assert result.success is False
+        assert "not found" in result.errors[0].lower()
+
+
+class TestPluginInstallerUpdate:
+    """Tests for plugin update."""
+
+    def test_update_success(self, tmp_path: Path) -> None:
+        source_v1 = tmp_path / "source_v1"
+        source_v2 = tmp_path / "source_v2"
+        plugins_dir = tmp_path / "plugins"
+        plugins_dir.mkdir()
+
+        _create_plugin_dir(source_v1, "test-plugin", "1.0.0")
