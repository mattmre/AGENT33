@@ -0,0 +1,144 @@
+"""Tests for plugin config store: persistence, loading, deletion."""
+
+from __future__ import annotations
+
+import json
+from pathlib import Path
+
+import pytest
+
+from agent33.plugins.config_store import PluginConfigStore
+
+
+class TestPluginConfigStore:
+    """Tests for PluginConfigStore persistence lifecycle."""
+
+    def test_save_and_load(self, tmp_path: Path) -> None:
+        store = PluginConfigStore(tmp_path / "config")
+        config = {"key": "value", "count": 42}
+
+        store.save("test-plugin", config)
+        loaded = store.load("test-plugin")
+
+        assert loaded == {"count": 42, "key": "value"}
+
+    def test_load_nonexistent_returns_empty(self, tmp_path: Path) -> None:
+        store = PluginConfigStore(tmp_path / "config")
+        loaded = store.load("nonexistent")
+        assert loaded == {}
+
+    def test_save_creates_directory(self, tmp_path: Path) -> None:
+        config_dir = tmp_path / "config"
+        store = PluginConfigStore(config_dir)
+
+        store.save("test-plugin", {"key": "value"})
+
+        assert (config_dir / "test-plugin" / "config.json").is_file()
+
+    def test_save_overwrites_existing(self, tmp_path: Path) -> None:
+        store = PluginConfigStore(tmp_path / "config")
+
+        store.save("test-plugin", {"key": "v1"})
+        store.save("test-plugin", {"key": "v2", "extra": True})
+
+        loaded = store.load("test-plugin")
+        assert loaded["key"] == "v2"
+        assert loaded["extra"] is True
+
+    def test_delete_removes_config(self, tmp_path: Path) -> None:
+        store = PluginConfigStore(tmp_path / "config")
+
+        store.save("test-plugin", {"key": "value"})
+        assert store.has_config("test-plugin") is True
+
+        deleted = store.delete("test-plugin")
+        assert deleted is True
+        assert store.has_config("test-plugin") is False
+
+    def test_delete_nonexistent_returns_false(self, tmp_path: Path) -> None:
+        store = PluginConfigStore(tmp_path / "config")
+        deleted = store.delete("nonexistent")
+        assert deleted is False
+
+    def test_load_malformed_json_raises(self, tmp_path: Path) -> None:
+        config_dir = tmp_path / "config"
+        plugin_dir = config_dir / "broken-plugin"
+        plugin_dir.mkdir(parents=True)
+        (plugin_dir / "config.json").write_text("not valid json{", encoding="utf-8")
+
+        store = PluginConfigStore(config_dir)
+
+        with pytest.raises(ValueError, match="Malformed config"):
+            store.load("broken-plugin")
+
+    def test_load_non_dict_raises(self, tmp_path: Path) -> None:
+        config_dir = tmp_path / "config"
+        plugin_dir = config_dir / "bad-type"
+        plugin_dir.mkdir(parents=True)
+        (plugin_dir / "config.json").write_text(
+            json.dumps([1, 2, 3]), encoding="utf-8"
+        )
+
+        store = PluginConfigStore(config_dir)
+
+        with pytest.raises(ValueError, match="must be a JSON object"):
+            store.load("bad-type")
+
+    def test_save_non_dict_raises(self, tmp_path: Path) -> None:
+        store = PluginConfigStore(tmp_path / "config")
+
+        with pytest.raises(TypeError, match="must be a dict"):
+            store.save("test", [1, 2, 3])  # type: ignore[arg-type]
+
+    def test_list_configured_plugins(self, tmp_path: Path) -> None:
+        store = PluginConfigStore(tmp_path / "config")
+
+        store.save("alpha", {"a": 1})
+        store.save("beta", {"b": 2})
+
+        plugins = store.list_configured_plugins()
+        assert plugins == ["alpha", "beta"]
+
+    def test_has_config(self, tmp_path: Path) -> None:
+        store = PluginConfigStore(tmp_path / "config")
+
+        assert store.has_config("test-plugin") is False
+
+        store.save("test-plugin", {"key": "value"})
+        assert store.has_config("test-plugin") is True
+
+    def test_save_atomic_on_failure(self, tmp_path: Path) -> None:
+        """Verify that a failed save does not leave a partial config file."""
+        config_dir = tmp_path / "config"
+        store = PluginConfigStore(config_dir)
+
+        store.save("test-plugin", {"original": True})
+
+        # Verify original is intact
+        loaded = store.load("test-plugin")
+        assert loaded["original"] is True
+
+    def test_config_values_preserved_exactly(self, tmp_path: Path) -> None:
+        """Verify that complex config values roundtrip correctly."""
+        store = PluginConfigStore(tmp_path / "config")
+
+        config = {
+            "string": "hello",
+            "number": 42,
+            "float": 3.14,
+            "bool": True,
+            "null": None,
+            "nested": {"deep": {"value": "found"}},
+            "array": [1, "two", 3.0],
+        }
+
+        store.save("complex-plugin", config)
+        loaded = store.load("complex-plugin")
+
+        assert loaded["string"] == "hello"
+        assert loaded["number"] == 42
+        assert loaded["float"] == 3.14
+        assert loaded["bool"] is True
+        assert loaded["null"] is None
+        assert loaded["nested"]["deep"]["value"] == "found"
+        assert loaded["array"] == [1, "two", 3.0]
