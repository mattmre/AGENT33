+"""Tests for discover_tools and resolve_workflow builtin tools (Phase 46)."""
+
+from __future__ import annotations
+
+import json
+from typing import Any
+from unittest.mock import AsyncMock, MagicMock
+
+import pytest
+
+from agent33.skills.definition import SkillDefinition
+from agent33.skills.registry import SkillRegistry
+from agent33.skills.semantic_resolver import ResolvedSkill, SemanticSkillResolver
+from agent33.tools.activation import ToolActivationManager
+from agent33.tools.base import ToolContext
+from agent33.tools.builtin.discover_tools import DiscoverToolsTool
+from agent33.tools.builtin.resolve_workflow import ResolveWorkflowTool
+from agent33.tools.catalog import ToolCatalogEntry, ToolCatalogGroup, ToolCatalogResponse
+from agent33.tools.catalog_service import ToolCatalogService
+from agent33.tools.registry import ToolRegistry
+
+
+# -- Helpers ------------------------------------------------------------------
+
+
+def _ctx(**kwargs: Any) -> ToolContext:
+    return ToolContext(**kwargs)
+
+
+class FakeTool:
+    def __init__(self, name: str, description: str = "fake") -> None:
+        self._name = name
+        self._description = description
+
+    @property
+    def name(self) -> str:
+        return self._name
+
+    @property
+    def description(self) -> str:
+        return self._description
+
+    async def execute(self, params: dict[str, Any], context: Any) -> Any:
+        pass
+
+
+# -- DiscoverToolsTool tests --------------------------------------------------
+
+
+class TestDiscoverToolsTool:
+    def test_metadata(self) -> None:
+        tool = DiscoverToolsTool()
+        assert tool.name == "discover_tools"
+        assert "search" in tool.description.lower() or "discover" in tool.description.lower()
+        assert tool.parameters_schema["required"] == ["query"]
+
+    async def test_search_finds_tools(self) -> None:
+        tool = DiscoverToolsTool()
+        registry = ToolRegistry()
+        registry.register(FakeTool("shell", "Run shell commands"))
+        registry.register(FakeTool("file_ops", "File operations"))
+        catalog = ToolCatalogService(registry)
+        tool.set_catalog_service(catalog)
+
+        result = await tool.execute({"query": "shell"}, _ctx())
+        assert result.success
+        parsed = json.loads(result.output)
+        assert len(parsed) == 1
+        assert parsed[0]["name"] == "shell"
+        assert parsed[0]["description"] == "Run shell commands"
+
+    async def test_search_by_category(self) -> None:
+        tool = DiscoverToolsTool()
+        registry = ToolRegistry()
+        registry.register(FakeTool("shell", "Run commands"))
+        registry.register(FakeTool("web_fetch", "Fetch web pages"))
+        catalog = ToolCatalogService(registry)
+        tool.set_catalog_service(catalog)
+
+        result = await tool.execute({"query": "", "category": "web"}, _ctx())
+        assert result.success
+        parsed = json.loads(result.output)
+        assert len(parsed) == 1
+        assert parsed[0]["name"] == "web_fetch"
+
+    async def test_empty_query_and_category_fails(self) -> None:
+        tool = DiscoverToolsTool()
+        result = await tool.execute({"query": ""}, _ctx())
+        assert not result.success
+        assert "must be provided" in result.error
+
+    async def test_no_catalog_service_fails(self) -> None:
+        tool = DiscoverToolsTool()
+        result = await tool.execute({"query": "anything"}, _ctx())
+        assert not result.success
+        assert "not available" in result.error
+
+    async def test_no_results(self) -> None:
+        tool = DiscoverToolsTool()
+        registry = ToolRegistry()
+        catalog = ToolCatalogService(registry)
+        tool.set_catalog_service(catalog)
+
+        result = await tool.execute({"query": "nonexistent"}, _ctx())
+        assert result.success
+        assert "no tools found" in result.output.lower()
+
+    async def test_auto_activates_in_dynamic_mode(self) -> None:
+        tool = DiscoverToolsTool()
+        registry = ToolRegistry()
+        registry.register(FakeTool("web_fetch", "Fetch web"))
+        catalog = ToolCatalogService(registry)
+        tool.set_catalog_service(catalog)
+
+        mgr = ToolActivationManager(core_tools=["shell"])
+        mgr.get_or_create("session-1")
+        tool.set_activation_manager(mgr)
+
+        result = await tool.execute(
+            {"query": "web"},
+            _ctx(requested_by="session-1"),
+        )
+        assert result.success
+        # web_fetch should now be activated.
+        assert mgr.is_visible("session-1", "web_fetch")
+
+
+# -- ResolveWorkflowTool tests ------------------------------------------------
+
+
+class TestResolveWorkflowTool:
+    def test_metadata(self) -> None:
+        tool = ResolveWorkflowTool()
+        assert tool.name == "resolve_workflow"
+        assert "objective" in tool.parameters_schema["required"]
+
+    async def test_resolve_succeeds(self) -> None:
+        tool = ResolveWorkflowTool()
+
+        # Create a real resolver with a real registry.
+        registry = SkillRegistry()
+        registry.register(
+            SkillDefinition(
+                name="deploy-k8s",
+                description="Deploy to Kubernetes",
+                tags=["devops"],
+            )
+        )
+        resolver = SemanticSkillResolver(registry, embedding_index=None)
+        tool.set_resolver(resolver)
+
+        result = await tool.execute(
+            {"objective": "deploy to kubernetes"},
+            _ctx(),
+        )
+        assert result.success
+        parsed = json.loads(result.output)
+        assert len(parsed) >= 1
+        assert parsed[0]["name"] == "deploy-k8s"
+        assert parsed[0]["score"] > 0
+        assert "devops" in parsed[0]["tags"]
+
+    async def test_resolve_with_instructions(self) -> None:
+        tool = ResolveWorkflowTool()
+        registry = SkillRegistry()
+        registry.register(
+            SkillDefinition(
+                name="deploy-k8s",
+                description="Deploy to Kubernetes",
+                instructions="Step 1: kubectl apply",
+            )
+        )
+        resolver = SemanticSkillResolver(registry)
+        tool.set_resolver(resolver)
+
+        result = await tool.execute(
+            {"objective": "deploy", "include_instructions": True},
+            _ctx(),
+        )
+        assert result.success
+        parsed = json.loads(result.output)
+        assert "kubectl apply" in parsed[0]["instructions"]
+
+    async def test_resolve_empty_objective_fails(self) -> None:
+        tool = ResolveWorkflowTool()
+        result = await tool.execute({"objective": ""}, _ctx())
+        assert not result.success
+        assert "required" in result.error.lower()
+
+    async def test_resolve_no_resolver_fails(self) -> None:
+        tool = ResolveWorkflowTool()
+        result = await tool.execute({"objective": "test"}, _ctx())
+        assert not result.success
+        assert "not available" in result.error
+
+    async def test_resolve_no_matches(self) -> None:
+        tool = ResolveWorkflowTool()
+        registry = SkillRegistry()
+        resolver = SemanticSkillResolver(registry)
+        tool.set_resolver(resolver)
+
+        result = await tool.execute(
+            {"objective": "completely unrelated query"},
+            _ctx(),
+        )
+        assert result.success
+        assert "no matching skills" in result.output.lower()
+
+    async def test_resolve_max_results(self) -> None:
+        tool = ResolveWorkflowTool()
+        registry = SkillRegistry()
+        for i in range(10):
+            registry.register(
+                SkillDefinition(name=f"skill-{i}", description=f"Skill number {i}")
+            )
+        resolver = SemanticSkillResolver(registry)
+        tool.set_resolver(resolver)
+
+        result = await tool.execute(
+            {"objective": "skill", "max_results": 2},
+            _ctx(),
+        )
+        assert result.success
+        parsed = json.loads(result.output)
+        assert len(parsed) <= 2
+
+    async def test_resolve_excludes_deprecated(self) -> None:
+        from agent33.skills.definition import SkillStatus
+
+        tool = ResolveWorkflowTool()
+        registry = SkillRegistry()
+        registry.register(
+            SkillDefinition(
+                name="old-skill",
+                description="Old deprecated skill about deploying",
+                status=SkillStatus.DEPRECATED,
+            )
+        )
+        registry.register(
+            SkillDefinition(
+                name="new-skill",
+                description="New skill about deploying",
+            )
+        )
+        resolver = SemanticSkillResolver(registry)
+        tool.set_resolver(resolver)
+
+        result = await tool.execute({"objective": "deploy"}, _ctx())
+        assert result.success
+        parsed = json.loads(result.output)
+        names = [r["name"] for r in parsed]
+        assert "old-skill" not in names
