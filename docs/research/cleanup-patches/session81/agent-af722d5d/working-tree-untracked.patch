+++ b/engine/src/agent33/skills/semantic_resolver.py
@@ -0,0 +1,207 @@
+"""Semantic skill resolver: hybrid BM25 + embedding search for skill discovery."""
+
+from __future__ import annotations
+
+import logging
+from dataclasses import dataclass, field
+from typing import TYPE_CHECKING
+
+from agent33.memory.bm25 import BM25Index
+
+if TYPE_CHECKING:
+    from agent33.skills.definition import SkillDefinition
+    from agent33.skills.registry import SkillRegistry
+    from agent33.skills.semantic import SkillEmbeddingIndex
+
+logger = logging.getLogger(__name__)
+
+# Default RRF constant (same value used in memory/hybrid.py).
+_RRF_K = 60
+
+
+@dataclass
+class ResolvedSkill:
+    """A single result from semantic skill resolution."""
+
+    name: str
+    description: str
+    score: float
+    tags: list[str] = field(default_factory=list)
+    instructions: str = ""
+    semantic_rank: int = 0
+    bm25_rank: int = 0
+
+
+class SemanticSkillResolver:
+    """Hybrid BM25 + embedding search for skill and tool discovery.
+
+    Combines two retrieval signals using Reciprocal Rank Fusion (RRF):
+    - **Semantic**: cosine similarity from the SkillEmbeddingIndex
+    - **BM25**: keyword matching from an in-memory BM25 index built on
+      skill name, description, and tags
+
+    The resolver is designed for *discovery* (operators and agents finding
+    skills by natural-language objective), not prompt-injection safety.
+    """
+
+    def __init__(
+        self,
+        skill_registry: SkillRegistry,
+        embedding_index: SkillEmbeddingIndex | None = None,
+        bm25_weight: float = 0.4,
+        semantic_weight: float = 0.6,
+        rrf_k: int = _RRF_K,
+    ) -> None:
+        self._registry = skill_registry
+        self._embedding_index = embedding_index
+        self._bm25_weight = max(0.0, min(1.0, bm25_weight))
+        self._semantic_weight = max(0.0, min(1.0, semantic_weight))
+        self._rrf_k = max(1, rrf_k)
+        self._bm25 = BM25Index()
+        self._bm25_name_map: dict[int, str] = {}
+        self._built = False
+
+    @property
+    def is_built(self) -> bool:
+        """Whether the BM25 index has been built."""
+        return self._built
+
+    def build_bm25_index(self) -> int:
+        """Build (or rebuild) the BM25 keyword index from current registry contents.
+
+        Returns the number of skills indexed.
+        """
+        self._bm25 = BM25Index()
+        self._bm25_name_map.clear()
+
+        skills = self._registry.list_all()
+        for skill in skills:
+            text = self._skill_to_bm25_text(skill)
+            idx = self._bm25.add_document(text, metadata={"name": skill.name})
+            self._bm25_name_map[idx] = skill.name
+
+        self._built = True
+        logger.info("Built BM25 index with %d skills", len(skills))
+        return len(skills)
+
+    async def resolve(
+        self,
+        query: str,
+        *,
+        top_k: int = 10,
+        include_instructions: bool = False,
+        exclude_deprecated: bool = True,
+    ) -> list[ResolvedSkill]:
+        """Resolve a natural-language query to matching skills.
+
+        Uses hybrid BM25 + semantic search with RRF fusion when the
+        embedding index is available.  Falls back to BM25-only when
+        embeddings are unavailable.
+
+        Parameters
+        ----------
+        query:
+            Natural-language description of the desired capability.
+        top_k:
+            Maximum number of results to return.
+        include_instructions:
+            If True, include full skill instructions in results (L1).
+        exclude_deprecated:
+            If True, filter out deprecated skills.
+        """
+        if not self._built:
+            self.build_bm25_index()
+
+        # -- BM25 retrieval ---------------------------------------------------
+        fetch_k = top_k * 3
+        bm25_results = self._bm25.search(query, top_k=fetch_k)
+        bm25_ranked: list[tuple[str, int]] = []
+        for rank, result in enumerate(bm25_results, 1):
+            name = self._bm25_name_map.get(result.doc_index, "")
+            if name:
+                bm25_ranked.append((name, rank))
+
+        # -- Semantic retrieval -----------------------------------------------
+        semantic_ranked: list[tuple[str, int]] = []
+        if self._embedding_index is not None:
+            try:
+                sem_results = await self._embedding_index.search(query, top_k=fetch_k)
+                for rank, (name, _score) in enumerate(sem_results, 1):
+                    semantic_ranked.append((name, rank))
+            except Exception:
+                logger.warning("Semantic search failed; falling back to BM25-only")
+
+        # -- RRF fusion -------------------------------------------------------
+        fused = self._fuse(bm25_ranked, semantic_ranked)
+
+        # -- Build results ----------------------------------------------------
+        results: list[ResolvedSkill] = []
+        for name, score, bm25_rank, sem_rank in fused[:top_k]:
+            skill = self._registry.get(name)
+            if skill is None:
+                continue
+            if exclude_deprecated and skill.status.value == "deprecated":
+                continue
+
+            resolved = ResolvedSkill(
+                name=skill.name,
+                description=skill.description,
+                score=score,
+                tags=list(skill.tags),
+                bm25_rank=bm25_rank,
+                semantic_rank=sem_rank,
+            )
+            if include_instructions and skill.instructions:
+                resolved.instructions = skill.instructions
+            results.append(resolved)
+
+        return results
+
+    # -- Internals ------------------------------------------------------------
+
+    @staticmethod
+    def _skill_to_bm25_text(skill: SkillDefinition) -> str:
+        """Build a weighted BM25 document from skill metadata.
+
+        Repeats high-weight fields to approximate field weighting.
+        """
+        parts: list[str] = []
+        # name weight 3.0 => repeat 3x
+        parts.extend([skill.name] * 3)
+        # description weight 2.0 => repeat 2x
+        parts.extend([skill.description] * 2)
+        # tags weight 1.0
+        parts.extend(skill.tags)
+        # instructions first 500 chars weight 0.5 => include once (min unit)
+        if skill.instructions:
+            parts.append(skill.instructions[:500])
+        return " ".join(parts)
+
+    def _fuse(
+        self,
+        bm25_ranked: list[tuple[str, int]],
+        semantic_ranked: list[tuple[str, int]],
+    ) -> list[tuple[str, float, int, int]]:
+        """Merge two ranked lists using weighted RRF.
+
+        Returns (name, fused_score, bm25_rank, semantic_rank) tuples sorted
+        by descending fused score.
+        """
+        scores: dict[str, tuple[float, int, int]] = {}
+
+        for name, rank in bm25_ranked:
+            rrf = self._bm25_weight / (self._rrf_k + rank)
+            prev = scores.get(name, (0.0, 0, 0))
+            scores[name] = (prev[0] + rrf, rank, prev[2])
+
+        for name, rank in semantic_ranked:
+            rrf = self._semantic_weight / (self._rrf_k + rank)
+            prev = scores.get(name, (0.0, 0, 0))
+            scores[name] = (prev[0] + rrf, prev[1], rank)
+
+        fused = [
+            (name, score, bm25_r, sem_r)
+            for name, (score, bm25_r, sem_r) in scores.items()
+        ]
+        fused.sort(key=lambda x: x[1], reverse=True)
+        return fused
