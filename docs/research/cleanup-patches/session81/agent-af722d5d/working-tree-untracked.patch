+"""Session-scoped tool activation sets for dynamic discovery mode."""
+
+from __future__ import annotations
+
+import logging
+from datetime import datetime, timezone
+from typing import Any
+
+from pydantic import BaseModel, Field
+
+from agent33.tools.catalog import CORE_TOOL_NAMES
+
+logger = logging.getLogger(__name__)
+
+
+class ToolActivationSet(BaseModel):
+    """Session-scoped set of activated tools."""
+
+    session_id: str
+    tenant_id: str
+    core_tools: list[str] = Field(default_factory=list)
+    activated_tools: set[str] = Field(default_factory=set)
+    deactivated_tools: set[str] = Field(default_factory=set)
+    created_at: datetime = Field(default_factory=lambda: datetime.now(timezone.utc))
+    updated_at: datetime = Field(default_factory=lambda: datetime.now(timezone.utc))
+
+    def to_persist(self) -> dict[str, Any]:
+        """Serialize for persistence."""
+        return {
+            "session_id": self.session_id,
+            "tenant_id": self.tenant_id,
+            "core_tools": self.core_tools,
+            "activated_tools": sorted(self.activated_tools),
+            "deactivated_tools": sorted(self.deactivated_tools),
+            "created_at": self.created_at.isoformat(),
+            "updated_at": self.updated_at.isoformat(),
+        }
+
+    @classmethod
+    def from_persist(cls, data: dict[str, Any]) -> ToolActivationSet:
+        """Deserialize from persisted data."""
+        return cls(
+            session_id=data["session_id"],
+            tenant_id=data.get("tenant_id", ""),
+            core_tools=data.get("core_tools", []),
+            activated_tools=set(data.get("activated_tools", [])),
+            deactivated_tools=set(data.get("deactivated_tools", [])),
+            created_at=datetime.fromisoformat(data["created_at"]),
+            updated_at=datetime.fromisoformat(data["updated_at"]),
+        )
+
+
+class ToolActivationManager:
+    """Manages per-session tool activation state."""
+
+    def __init__(self, core_tools: list[str] | None = None) -> None:
+        self._sets: dict[str, ToolActivationSet] = {}
+        self._core_tools = list(core_tools or sorted(CORE_TOOL_NAMES))
+
+    @property
+    def core_tools(self) -> list[str]:
+        """Return the list of core tools that are always visible."""
+        return list(self._core_tools)
+
+    def get_or_create(self, session_id: str, tenant_id: str = "") -> ToolActivationSet:
+        """Get or create an activation set for a session."""
+        if session_id not in self._sets:
+            self._sets[session_id] = ToolActivationSet(
+                session_id=session_id,
+                tenant_id=tenant_id,
+                core_tools=list(self._core_tools),
+            )
+            logger.info(
+                "Created activation set for session %s with %d core tools",
+                session_id,
+                len(self._core_tools),
+            )
+        return self._sets[session_id]
+
+    def get(self, session_id: str) -> ToolActivationSet | None:
+        """Get an existing activation set or None."""
+        return self._sets.get(session_id)
+
+    def activate(self, session_id: str, tool_names: list[str]) -> ToolActivationSet:
+        """Add tools to the session's activation set."""
+        aset = self._sets.get(session_id)
+        if aset is None:
+            raise KeyError(f"No activation set for session '{session_id}'")
+        aset.activated_tools.update(tool_names)
+        # If previously deactivated, remove from deactivated set.
+        aset.deactivated_tools -= set(tool_names)
+        aset.updated_at = datetime.now(timezone.utc)
+        logger.info("Activated %d tools in session %s", len(tool_names), session_id)
+        return aset
+
+    def deactivate(self, session_id: str, tool_names: list[str]) -> ToolActivationSet:
+        """Remove tools from the session's activation set."""
+        aset = self._sets.get(session_id)
+        if aset is None:
+            raise KeyError(f"No activation set for session '{session_id}'")
+        for name in tool_names:
+            # Cannot deactivate core tools.
+            if name in aset.core_tools:
+                logger.warning(
+                    "Cannot deactivate core tool '%s' in session %s", name, session_id
+                )
+                continue
+            aset.activated_tools.discard(name)
+            aset.deactivated_tools.add(name)
+        aset.updated_at = datetime.now(timezone.utc)
+        logger.info("Deactivated %d tools in session %s", len(tool_names), session_id)
+        return aset
+
+    def is_visible(self, session_id: str, tool_name: str) -> bool:
+        """Check if a tool should be visible in the current session.
+
+        In dynamic mode, a tool is visible if:
+        1. It is a core tool AND not explicitly deactivated, OR
+        2. It has been explicitly activated AND not deactivated.
+        """
+        aset = self._sets.get(session_id)
+        if aset is None:
+            # No activation set means legacy mode; everything is visible.
+            return True
+        if tool_name in aset.deactivated_tools:
+            return False
+        if tool_name in aset.core_tools:
+            return True
+        return tool_name in aset.activated_tools
+
+    def list_visible(self, session_id: str) -> list[str]:
+        """Return all tool names visible in the session."""
+        aset = self._sets.get(session_id)
+        if aset is None:
+            return []
+        visible: set[str] = set()
+        visible.update(aset.core_tools)
+        visible.update(aset.activated_tools)
+        visible -= aset.deactivated_tools
+        return sorted(visible)
+
+    def remove_session(self, session_id: str) -> bool:
+        """Remove an activation set for a session. Returns True if it existed."""
+        return self._sets.pop(session_id, None) is not None
+
+    @property
+    def session_count(self) -> int:
+        """Number of active sessions with activation sets."""
+        return len(self._sets)
