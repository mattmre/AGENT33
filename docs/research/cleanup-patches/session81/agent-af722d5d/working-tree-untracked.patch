@@ -0,0 +1,145 @@
+"""Embedding-based semantic index for skill discovery."""
+
+from __future__ import annotations
+
+import logging
+import math
+from typing import TYPE_CHECKING
+
+if TYPE_CHECKING:
+    from agent33.memory.embeddings import EmbeddingProvider
+    from agent33.skills.definition import SkillDefinition
+
+logger = logging.getLogger(__name__)
+
+
+class SkillEmbeddingIndex:
+    """Maintains an embedding index over skill metadata for semantic search.
+
+    Uses cosine similarity over pre-computed embeddings to find skills
+    matching a natural-language query.  Degrades gracefully when the
+    embedding provider is unavailable (returns empty results).
+    """
+
+    def __init__(
+        self,
+        embedding_provider: EmbeddingProvider,
+    ) -> None:
+        self._provider = embedding_provider
+        self._embeddings: dict[str, list[float]] = {}
+        self._metadata: dict[str, dict[str, str]] = {}
+        self._dirty = False
+
+    @property
+    def size(self) -> int:
+        """Number of indexed skills."""
+        return len(self._embeddings)
+
+    @property
+    def indexed_names(self) -> list[str]:
+        """Return the names of all indexed skills."""
+        return sorted(self._embeddings.keys())
+
+    async def index_skill(self, skill: SkillDefinition) -> bool:
+        """Compute and store embedding for a single skill.
+
+        Returns True if indexing succeeded, False on embedding failure.
+        """
+        text = self._build_index_text(skill)
+        try:
+            vector = await self._provider.embed(text)
+        except Exception:
+            logger.warning(
+                "Failed to embed skill '%s'; skipping semantic index", skill.name
+            )
+            return False
+
+        self._embeddings[skill.name] = vector
+        self._metadata[skill.name] = {
+            "name": skill.name,
+            "description": skill.description,
+            "tags": ", ".join(skill.tags),
+        }
+        self._dirty = True
+        return True
+
+    async def index_all(self, skills: list[SkillDefinition]) -> int:
+        """Index all skills. Returns count of successfully indexed skills."""
+        count = 0
+        for skill in skills:
+            if await self.index_skill(skill):
+                count += 1
+        logger.info("Indexed %d / %d skills in semantic index", count, len(skills))
+        return count
+
+    def remove(self, skill_name: str) -> bool:
+        """Remove a skill from the index. Returns True if it existed."""
+        removed = self._embeddings.pop(skill_name, None) is not None
+        self._metadata.pop(skill_name, None)
+        if removed:
+            self._dirty = True
+        return removed
+
+    async def search(
+        self, query: str, top_k: int = 10
+    ) -> list[tuple[str, float]]:
+        """Return (skill_name, similarity_score) pairs ranked by cosine similarity.
+
+        Returns an empty list if the embedding provider is unavailable or
+        the index is empty.
+        """
+        if not self._embeddings:
+            return []
+
+        try:
+            query_vector = await self._provider.embed(query)
+        except Exception:
+            logger.warning("Embedding provider unavailable for semantic search query")
+            return []
+
+        return self._cosine_rank(query_vector, top_k)
+
+    def clear(self) -> None:
+        """Remove all indexed entries."""
+        self._embeddings.clear()
+        self._metadata.clear()
+        self._dirty = True
+
+    # -- Internal helpers ----------------------------------------------------
+
+    @staticmethod
+    def _build_index_text(skill: SkillDefinition) -> str:
+        """Combine skill metadata into a single indexable string."""
+        parts = [skill.name, skill.description]
+        parts.extend(skill.tags)
+        if skill.instructions:
+            # Include first 500 chars of instructions for richer semantic signal.
+            parts.append(skill.instructions[:500])
+        return " ".join(parts)
+
+    @staticmethod
+    def _cosine_similarity(a: list[float], b: list[float]) -> float:
+        """Compute cosine similarity between two vectors."""
+        if len(a) != len(b) or not a:
+            return 0.0
+        dot = sum(x * y for x, y in zip(a, b))
+        norm_a = math.sqrt(sum(x * x for x in a))
+        norm_b = math.sqrt(sum(x * x for x in b))
+        if norm_a == 0.0 or norm_b == 0.0:
+            return 0.0
+        return dot / (norm_a * norm_b)
+
+    def _cosine_rank(
+        self, query_vec: list[float], top_k: int
+    ) -> list[tuple[str, float]]:
+        """Rank all indexed skills against the query vector."""
+        scored: list[tuple[str, float]] = []
+        for name, emb in self._embeddings.items():
+            sim = self._cosine_similarity(query_vec, emb)
+            scored.append((name, sim))
+        scored.sort(key=lambda x: x[1], reverse=True)
+        return scored[:top_k]
+
+    def get_metadata(self, skill_name: str) -> dict[str, str] | None:
+        """Return the metadata stored for a skill, or None."""
+        return self._metadata.get(skill_name)
