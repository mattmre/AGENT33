+"""Integration tests for Phase 46: natural-language query -> resolved skill -> activated.
+
+These tests verify the full pipeline from semantic resolution through
+session activation, exercising all three subsystems together.
+"""
+
+from __future__ import annotations
+
+import json
+from typing import Any
+from unittest.mock import AsyncMock
+
+import pytest
+
+from agent33.skills.definition import SkillDefinition, SkillStatus
+from agent33.skills.registry import SkillRegistry
+from agent33.skills.semantic import SkillEmbeddingIndex
+from agent33.skills.semantic_resolver import SemanticSkillResolver
+from agent33.tools.activation import ToolActivationManager
+from agent33.tools.base import ToolContext
+from agent33.tools.builtin.discover_tools import DiscoverToolsTool
+from agent33.tools.builtin.resolve_workflow import ResolveWorkflowTool
+from agent33.tools.catalog_service import ToolCatalogService
+from agent33.tools.registry import ToolRegistry
+
+
+# -- Helpers ------------------------------------------------------------------
+
+
+class FakeTool:
+    def __init__(self, name: str, description: str = "fake") -> None:
+        self._name = name
+        self._description = description
+
+    @property
+    def name(self) -> str:
+        return self._name
+
+    @property
+    def description(self) -> str:
+        return self._description
+
+    async def execute(self, params: dict[str, Any], context: Any) -> Any:
+        pass
+
+
+def _make_embedding_provider(dim: int = 8) -> AsyncMock:
+    """Deterministic mock embedding provider."""
+    provider = AsyncMock()
+
+    async def _embed(text: str) -> list[float]:
+        words = text.lower().split()
+        vec = [0.0] * dim
+        for word in words:
+            idx = hash(word) % dim
+            vec[idx] += 1.0
+        magnitude = sum(v * v for v in vec) ** 0.5
+        if magnitude > 0:
+            vec = [v / magnitude for v in vec]
+        return vec
+
+    provider.embed = AsyncMock(side_effect=_embed)
+    return provider
+
+
+# -- Integration tests --------------------------------------------------------
+
+
+class TestPhase46Integration:
+    """Full pipeline: resolve skill -> discover tool -> activate in session."""
+
+    async def test_resolve_then_activate_pipeline(self) -> None:
+        """A natural-language query resolves a skill, and the corresponding
+        tool is activated in the session."""
+        # Set up skill registry with skills.
+        skill_registry = SkillRegistry()
+        skill_registry.register(
+            SkillDefinition(
+                name="kubernetes-deploy",
+                description="Deploy applications to a Kubernetes cluster",
+                tags=["devops", "containers"],
+                instructions="Use kubectl apply -f to deploy manifests.",
+            )
+        )
+        skill_registry.register(
+            SkillDefinition(
+                name="email-notify",
+                description="Send email notifications to users",
+                tags=["messaging"],
+            )
+        )
+
+        # Set up embedding index.
+        provider = _make_embedding_provider()
+        embedding_index = SkillEmbeddingIndex(provider)
+        await embedding_index.index_all(skill_registry.list_all())
+
+        # Set up resolver.
+        resolver = SemanticSkillResolver(
+            skill_registry, embedding_index=embedding_index
+        )
+
+        # Resolve "deploy containers to cloud".
+        results = await resolver.resolve(
+            "deploy containers to cloud",
+            top_k=5,
+            include_instructions=True,
+        )
+        assert len(results) >= 1
+        # Kubernetes deploy skill should rank high.
+        assert results[0].name == "kubernetes-deploy"
+        assert "kubectl" in results[0].instructions
+
+        # Set up tool activation.
+        tool_registry = ToolRegistry()
+        tool_registry.register(FakeTool("shell", "Shell"))
+        tool_registry.register(FakeTool("kubernetes-deploy", "K8s deploy"))
+        catalog = ToolCatalogService(tool_registry)
+
+        mgr = ToolActivationManager(core_tools=["shell"])
+        mgr.get_or_create("session-1")
+
+        # Activate the resolved skill's corresponding tool.
+        mgr.activate("session-1", [results[0].name])
+        assert mgr.is_visible("session-1", "kubernetes-deploy")
+        assert not mgr.is_visible("session-1", "email-notify")
+
+    async def test_discover_tools_activates_found_tools(self) -> None:
+        """The discover_tools builtin activates tools it finds."""
+        tool_registry = ToolRegistry()
+        tool_registry.register(FakeTool("shell", "Run commands"))
+        tool_registry.register(FakeTool("web_fetch", "Fetch web pages"))
+        tool_registry.register(FakeTool("browser", "Browser automation"))
+
+        catalog = ToolCatalogService(tool_registry)
+        mgr = ToolActivationManager(core_tools=["shell"])
+        mgr.get_or_create("session-1")
+
+        discover = DiscoverToolsTool()
+        discover.set_catalog_service(catalog)
+        discover.set_activation_manager(mgr)
+
+        # Discover web-related tools.
+        result = await discover.execute(
+            {"query": "web"},
+            ToolContext(requested_by="session-1"),
+        )
+        assert result.success
+        parsed = json.loads(result.output)
+
+        # Both web_fetch and browser should be found.
+        found_names = {t["name"] for t in parsed}
+        assert "web_fetch" in found_names
+
+        # They should now be activated.
+        assert mgr.is_visible("session-1", "web_fetch")
+
+    async def test_resolve_workflow_excludes_deprecated_in_pipeline(self) -> None:
+        """Deprecated skills are excluded from resolve_workflow results."""
+        skill_registry = SkillRegistry()
+        skill_registry.register(
+            SkillDefinition(
+                name="old-deploy",
+                description="Old deployment skill",
+                status=SkillStatus.DEPRECATED,
+            )
+        )
+        skill_registry.register(
+            SkillDefinition(
+                name="new-deploy",
+                description="New deployment skill",
+                status=SkillStatus.ACTIVE,
+            )
+        )
+
+        resolver = SemanticSkillResolver(skill_registry)
+        tool = ResolveWorkflowTool()
+        tool.set_resolver(resolver)
+
+        result = await tool.execute({"objective": "deploy"}, ToolContext())
+        assert result.success
+        parsed = json.loads(result.output)
+        names = [r["name"] for r in parsed]
+        assert "old-deploy" not in names
+        assert "new-deploy" in names
+
+    async def test_catalog_search_matches_registry(self) -> None:
+        """Catalog service reflects the actual tool registry state."""
+        tool_registry = ToolRegistry()
+        tool_registry.register(FakeTool("shell", "Run commands"))
+        tool_registry.register(FakeTool("file_ops", "File operations"))
+        tool_registry.register(FakeTool("web_fetch", "Fetch web pages"))
+
+        catalog = ToolCatalogService(tool_registry)
+
+        # Build catalog.
+        response = catalog.build_catalog()
+        all_names = {
+            t.name for g in response.groups for t in g.tools
+        }
+        registry_names = {t.name for t in tool_registry.list_all()}
+        assert all_names == registry_names
+
+    async def test_dynamic_mode_hides_non_core(self) -> None:
+        """In dynamic mode, non-core tools are not visible until activated."""
+        mgr = ToolActivationManager(core_tools=["shell", "file_ops"])
+        mgr.get_or_create("s1")
+
+        # Core tools visible.
+        assert mgr.is_visible("s1", "shell")
+        assert mgr.is_visible("s1", "file_ops")
+
+        # Non-core hidden.
+        assert not mgr.is_visible("s1", "web_fetch")
+        assert not mgr.is_visible("s1", "browser")
+
+        # After discovery + activation, non-core becomes visible.
+        mgr.activate("s1", ["web_fetch"])
+        assert mgr.is_visible("s1", "web_fetch")
+        assert not mgr.is_visible("s1", "browser")
+
+    async def test_embedding_fallback_to_bm25(self) -> None:
+        """When embeddings fail, resolver still returns BM25 results."""
+        skill_registry = SkillRegistry()
+        skill_registry.register(
+            SkillDefinition(
+                name="kubernetes-deploy",
+                description="Deploy to Kubernetes cluster",
+                tags=["devops"],
+            )
+        )
+
+        # Embedding provider that always fails.
+        broken_provider = AsyncMock()
+        broken_provider.embed = AsyncMock(side_effect=ConnectionError("offline"))
+        broken_index = SkillEmbeddingIndex(broken_provider)
+
+        resolver = SemanticSkillResolver(
+            skill_registry, embedding_index=broken_index
+        )
+        results = await resolver.resolve("deploy kubernetes")
+        assert len(results) >= 1
+        assert results[0].name == "kubernetes-deploy"
