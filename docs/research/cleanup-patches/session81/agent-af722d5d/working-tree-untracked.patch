+"""API route tests for Phase 46 discovery endpoints."""
+
+from __future__ import annotations
+
+from typing import Any
+
+import pytest
+from fastapi.testclient import TestClient
+
+from agent33.main import app
+from agent33.security.auth import create_access_token
+from agent33.skills.definition import SkillDefinition
+from agent33.skills.registry import SkillRegistry
+from agent33.skills.semantic_resolver import SemanticSkillResolver
+from agent33.tools.activation import ToolActivationManager
+from agent33.tools.catalog_service import ToolCatalogService
+from agent33.tools.discovery import DynamicToolDiscovery
+from agent33.tools.registry import ToolRegistry
+
+
+# -- Helpers ------------------------------------------------------------------
+
+
+class FakeTool:
+    def __init__(self, name: str, description: str = "fake") -> None:
+        self._name = name
+        self._description = description
+
+    @property
+    def name(self) -> str:
+        return self._name
+
+    @property
+    def description(self) -> str:
+        return self._description
+
+    async def execute(self, params: dict[str, Any], context: Any) -> Any:
+        pass
+
+
+def _client(scopes: list[str]) -> TestClient:
+    """Create a TestClient with a valid JWT carrying the given scopes."""
+    token = create_access_token("test-user", scopes=scopes)
+    return TestClient(app, headers={"Authorization": f"Bearer {token}"})
+
+
+@pytest.fixture()
+def admin_client() -> TestClient:
+    return _client(["admin", "tools:execute"])
+
+
+@pytest.fixture()
+def tools_client() -> TestClient:
+    return _client(["tools:execute"])
+
+
+def _setup_resolver() -> SemanticSkillResolver:
+    """Create a resolver with a few skills."""
+    registry = SkillRegistry()
+    registry.register(
+        SkillDefinition(
+            name="deploy-k8s",
+            description="Deploy to Kubernetes",
+            tags=["devops"],
+        )
+    )
+    registry.register(
+        SkillDefinition(
+            name="send-email",
+            description="Send email notifications",
+            tags=["messaging"],
+        )
+    )
+    return SemanticSkillResolver(registry, embedding_index=None)
+
+
+def _setup_tool_registry() -> ToolRegistry:
+    """Create a ToolRegistry with a few tools."""
+    registry = ToolRegistry()
+    registry.register(FakeTool("shell", "Run shell commands"))
+    registry.register(FakeTool("web_fetch", "Fetch web pages"))
+    registry.register(FakeTool("file_ops", "File operations"))
+    return registry
+
+
+# -- Semantic resolution route tests ------------------------------------------
+
+
+class TestResolveRoute:
+    def test_resolve_returns_matching_skills(self, tools_client: TestClient) -> None:
+        resolver = _setup_resolver()
+        app.state.skill_resolver = resolver
+
+        resp = tools_client.post(
+            "/v1/discovery/resolve",
+            json={"query": "deploy to kubernetes"},
+        )
+        assert resp.status_code == 200
+        data = resp.json()
+        assert data["query"] == "deploy to kubernetes"
+        assert data["count"] >= 1
+        assert data["results"][0]["name"] == "deploy-k8s"
+        assert data["results"][0]["score"] > 0
+        assert "devops" in data["results"][0]["tags"]
+
+    def test_resolve_empty_query_rejected(self, tools_client: TestClient) -> None:
+        resolver = _setup_resolver()
+        app.state.skill_resolver = resolver
+
+        resp = tools_client.post("/v1/discovery/resolve", json={"query": ""})
+        assert resp.status_code == 422
+
+    def test_resolve_no_resolver_503(self, tools_client: TestClient) -> None:
+        # Remove the resolver from app state.
+        if hasattr(app.state, "skill_resolver"):
+            delattr(app.state, "skill_resolver")
+
+        resp = tools_client.post(
+            "/v1/discovery/resolve",
+            json={"query": "test"},
+        )
+        assert resp.status_code == 503
+
+    def test_resolve_max_results(self, tools_client: TestClient) -> None:
+        registry = SkillRegistry()
+        for i in range(10):
+            registry.register(
+                SkillDefinition(name=f"s{i}", description=f"Skill {i}")
+            )
+        app.state.skill_resolver = SemanticSkillResolver(registry)
+
+        resp = tools_client.post(
+            "/v1/discovery/resolve",
+            json={"query": "skill", "max_results": 3},
+        )
+        assert resp.status_code == 200
+        data = resp.json()
+        assert len(data["results"]) <= 3
+
+    def test_resolve_unauthenticated_401(self) -> None:
+        client = TestClient(app)
+        resp = client.post(
+            "/v1/discovery/resolve",
+            json={"query": "test"},
+        )
+        assert resp.status_code == 401
+
+
+# -- Discovery scan/status route tests ----------------------------------------
+
+
+class TestDiscoveryRoutes:
+    def test_scan_returns_result(self, admin_client: TestClient) -> None:
+        tool_registry = _setup_tool_registry()
+        app.state.tool_discovery = DynamicToolDiscovery(tool_registry)
+
+        resp = admin_client.get("/v1/discovery/scan")
+        assert resp.status_code == 200
+        data = resp.json()
+        assert "total" in data
+        assert isinstance(data["added"], list)
+
+    def test_status_returns_health(self, tools_client: TestClient) -> None:
+        tool_registry = _setup_tool_registry()
+        app.state.tool_discovery = DynamicToolDiscovery(tool_registry)
+
+        resp = tools_client.get("/v1/discovery/status")
+        assert resp.status_code == 200
+        data = resp.json()
+        assert data["scan_count"] == 0
+        assert data["healthy"] is True
+
+    def test_status_no_discovery_503(self, tools_client: TestClient) -> None:
+        if hasattr(app.state, "tool_discovery"):
+            delattr(app.state, "tool_discovery")
+
+        resp = tools_client.get("/v1/discovery/status")
+        assert resp.status_code == 503
+
+
+# -- Session activation route tests -------------------------------------------
+
+
+class TestActivationRoutes:
+    def _setup_activation(self) -> ToolActivationManager:
+        tool_registry = _setup_tool_registry()
+        catalog = ToolCatalogService(tool_registry)
+        mgr = ToolActivationManager(core_tools=["shell"])
+        app.state.tool_activation_manager = mgr
+        app.state.tool_catalog_service = catalog
+        return mgr
+
+    def test_activate_tools(self, tools_client: TestClient) -> None:
+        mgr = self._setup_activation()
+        mgr.get_or_create("s1")
+
+        resp = tools_client.post(
+            "/v1/sessions/s1/tools/activate",
+            json={"tool_names": ["web_fetch"]},
+        )
+        assert resp.status_code == 200
+        data = resp.json()
+        assert data["session_id"] == "s1"
+        assert "web_fetch" in data["activated_tools"]
+        assert "web_fetch" in data["visible_tools"]
+
+    def test_deactivate_tool(self, tools_client: TestClient) -> None:
+        mgr = self._setup_activation()
+        mgr.get_or_create("s1")
+        mgr.activate("s1", ["web_fetch"])
+
+        resp = tools_client.delete("/v1/sessions/s1/tools/web_fetch")
+        assert resp.status_code == 200
+        data = resp.json()
+        assert "web_fetch" in data["deactivated_tools"]
+        assert "web_fetch" not in data["visible_tools"]
+
+    def test_deactivate_nonexistent_session_404(self, tools_client: TestClient) -> None:
+        self._setup_activation()
+
+        resp = tools_client.delete("/v1/sessions/nonexistent/tools/shell")
+        assert resp.status_code == 404
+
+    def test_list_active_tools(self, tools_client: TestClient) -> None:
+        mgr = self._setup_activation()
+        mgr.get_or_create("s1")
+        mgr.activate("s1", ["web_fetch"])
+
+        resp = tools_client.get("/v1/sessions/s1/tools")
+        assert resp.status_code == 200
+        data = resp.json()
+        names = [t["name"] for t in data]
+        assert "shell" in names
+        assert "web_fetch" in names
+
+    def test_list_active_tools_core_only(self, tools_client: TestClient) -> None:
+        mgr = self._setup_activation()
+        mgr.get_or_create("s1")
+
+        resp = tools_client.get("/v1/sessions/s1/tools")
+        assert resp.status_code == 200
+        data = resp.json()
+        names = [t["name"] for t in data]
+        assert "shell" in names
+        assert "web_fetch" not in names
+
+    def test_activate_empty_list_rejected(self, tools_client: TestClient) -> None:
+        self._setup_activation()
+
+        resp = tools_client.post(
+            "/v1/sessions/s1/tools/activate",
+            json={"tool_names": []},
+        )
+        assert resp.status_code == 422
+
+    def test_session_isolation_via_api(self, tools_client: TestClient) -> None:
+        """Activating in session s1 does not affect session s2."""
+        mgr = self._setup_activation()
+        mgr.get_or_create("s1")
+        mgr.get_or_create("s2")
+
+        tools_client.post(
+            "/v1/sessions/s1/tools/activate",
+            json={"tool_names": ["web_fetch"]},
+        )
+
+        resp = tools_client.get("/v1/sessions/s2/tools")
+        assert resp.status_code == 200
+        names = [t["name"] for t in resp.json()]
+        assert "web_fetch" not in names
+
+    def test_no_activation_manager_503(self, tools_client: TestClient) -> None:
+        if hasattr(app.state, "tool_activation_manager"):
+            delattr(app.state, "tool_activation_manager")
+
+        resp = tools_client.post(
+            "/v1/sessions/s1/tools/activate",
+            json={"tool_names": ["shell"]},
+        )
+        assert resp.status_code == 503
