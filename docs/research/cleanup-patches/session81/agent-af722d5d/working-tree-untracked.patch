+"""Meta-tool that searches the runtime tool catalog."""
+
+from __future__ import annotations
+
+import json
+from typing import Any
+
+from agent33.tools.base import ToolContext, ToolResult
+
+
+class DiscoverToolsTool:
+    """Search for available tools by keyword or category.
+
+    In dynamic discovery mode, matched tools are automatically added
+    to the session's activation set.
+    """
+
+    @property
+    def name(self) -> str:
+        return "discover_tools"
+
+    @property
+    def description(self) -> str:
+        return "Search for available tools by keyword or category."
+
+    @property
+    def parameters_schema(self) -> dict[str, Any]:
+        return {
+            "type": "object",
+            "properties": {
+                "query": {
+                    "type": "string",
+                    "description": "Search query for tool discovery",
+                },
+                "category": {
+                    "type": "string",
+                    "description": "Category filter (e.g. files, web, runtime)",
+                },
+            },
+            "required": ["query"],
+        }
+
+    def __init__(self) -> None:
+        self._catalog_service: Any = None
+        self._activation_manager: Any = None
+
+    def set_catalog_service(self, service: Any) -> None:
+        """Wire the catalog service after construction."""
+        self._catalog_service = service
+
+    def set_activation_manager(self, manager: Any) -> None:
+        """Wire the activation manager after construction."""
+        self._activation_manager = manager
+
+    async def execute(self, params: dict[str, Any], context: ToolContext) -> ToolResult:
+        """Search the tool catalog and optionally activate found tools."""
+        query = params.get("query", "").strip()
+        category = params.get("category", "").strip()
+
+        if not query and not category:
+            return ToolResult.fail("Either 'query' or 'category' must be provided.")
+
+        if self._catalog_service is None:
+            return ToolResult.fail("Tool catalog service not available.")
+
+        if query:
+            entries = self._catalog_service.search_catalog(query)
+        else:
+            catalog = self._catalog_service.build_catalog(category_filter=category)
+            entries = []
+            for group in catalog.groups:
+                entries.extend(group.tools)
+
+        if category and query:
+            entries = [e for e in entries if e.category == category]
+
+        if not entries:
+            return ToolResult.ok("No tools found matching your query.")
+
+        # Format results.
+        results = []
+        tool_names = []
+        for entry in entries[:20]:  # Cap at 20 results.
+            results.append({
+                "name": entry.name,
+                "description": entry.description,
+                "category": entry.category,
+                "source": entry.source,
+                "available": entry.available,
+            })
+            tool_names.append(entry.name)
+
+        # Auto-activate discovered tools in dynamic mode.
+        if self._activation_manager is not None and tool_names:
+            session_id = getattr(context, "requested_by", "")
+            if session_id:
+                try:
+                    aset = self._activation_manager.get(session_id)
+                    if aset is not None:
+                        self._activation_manager.activate(session_id, tool_names)
+                except Exception:
+                    pass  # Activation is best-effort.
+
+        return ToolResult.ok(json.dumps(results, indent=2))
