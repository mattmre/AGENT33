+"""Tests for dynamic tool discovery (Phase 46)."""
+
+from __future__ import annotations
+
+from typing import Any
+from unittest.mock import AsyncMock, MagicMock, patch
+
+import pytest
+
+from agent33.tools.discovery import DynamicToolDiscovery, DiscoveryScanResult
+from agent33.tools.registry import ToolRegistry
+
+
+# -- Helpers ------------------------------------------------------------------
+
+
+class FakeTool:
+    def __init__(self, name: str, description: str = "fake") -> None:
+        self._name = name
+        self._description = description
+
+    @property
+    def name(self) -> str:
+        return self._name
+
+    @property
+    def description(self) -> str:
+        return self._description
+
+    async def execute(self, params: dict[str, Any], context: Any) -> Any:
+        pass
+
+
+# -- Tests --------------------------------------------------------------------
+
+
+class TestDynamicToolDiscovery:
+    async def test_initial_status(self) -> None:
+        registry = ToolRegistry()
+        discovery = DynamicToolDiscovery(registry)
+
+        st = discovery.status
+        assert st.last_scan is None
+        assert st.scan_count == 0
+        assert st.total_discovered == 0
+        assert st.errors == []
+
+    async def test_scan_discovers_entrypoint_tools(self) -> None:
+        registry = ToolRegistry()
+        # Pre-register one tool.
+        registry.register(FakeTool("shell", "Run commands"))
+
+        discovery = DynamicToolDiscovery(registry)
+        result = await discovery.scan()
+
+        assert isinstance(result, DiscoveryScanResult)
+        # At minimum, the pre-registered tool is counted.
+        assert result.total >= 1
+        assert discovery.status.scan_count == 1
+        assert discovery.status.last_scan is not None
+
+    async def test_scan_detects_new_tools(self) -> None:
+        registry = ToolRegistry()
+        registry.register(FakeTool("shell", "Run commands"))
+
+        discovery = DynamicToolDiscovery(registry)
+        # First scan sets baseline.
+        await discovery.scan()
+
+        # Add a new tool between scans.
+        registry.register(FakeTool("new_tool", "New tool"))
+        result = await discovery.scan()
+
+        assert "new_tool" in result.added
+
+    async def test_scan_detects_removed_tools(self) -> None:
+        registry = ToolRegistry()
+        tool_a = FakeTool("tool_a", "Tool A")
+        registry.register(tool_a)
+        registry.register(FakeTool("tool_b", "Tool B"))
+
+        discovery = DynamicToolDiscovery(registry)
+        await discovery.scan()
+
+        # Remove a tool between scans.
+        registry._tools.pop("tool_a")
+        result = await discovery.scan()
+
+        assert "tool_a" in result.removed
+
+    async def test_scan_records_errors(self) -> None:
+        registry = ToolRegistry()
+        # Use an MCP URL that will fail.
+        discovery = DynamicToolDiscovery(
+            registry, mcp_server_urls=["http://nonexistent:9999"]
+        )
+        result = await discovery.scan()
+
+        # MCP discovery failure should be recorded but not crash the scan.
+        assert discovery.status.scan_count == 1
+
+    async def test_mcp_url_management(self) -> None:
+        registry = ToolRegistry()
+        discovery = DynamicToolDiscovery(registry)
+
+        assert discovery.mcp_urls == []
+
+        discovery.add_mcp_url("http://mcp1:8080")
+        discovery.add_mcp_url("http://mcp2:8080")
+        assert len(discovery.mcp_urls) == 2
+
+        # Duplicate add is idempotent.
+        discovery.add_mcp_url("http://mcp1:8080")
+        assert len(discovery.mcp_urls) == 2
+
+        assert discovery.remove_mcp_url("http://mcp1:8080") is True
+        assert len(discovery.mcp_urls) == 1
+        assert discovery.remove_mcp_url("http://nonexistent") is False
+
+    async def test_scan_result_serialization(self) -> None:
+        result = DiscoveryScanResult(
+            total=5,
+            added=["new_tool"],
+            removed=["old_tool"],
+            entrypoint_count=3,
+            mcp_count=2,
+            errors=[],
+        )
+        data = result.to_dict()
+        assert data["total"] == 5
+        assert data["added"] == ["new_tool"]
+        assert data["removed"] == ["old_tool"]
+        assert data["entrypoint_count"] == 3
+        assert data["mcp_count"] == 2
+
+    async def test_status_serialization(self) -> None:
+        registry = ToolRegistry()
+        discovery = DynamicToolDiscovery(registry)
+        await discovery.scan()
+
+        data = discovery.status.to_dict()
+        assert data["scan_count"] == 1
+        assert data["last_scan"] is not None
+        assert data["healthy"] is True
+
+    async def test_status_unhealthy_on_errors(self) -> None:
+        registry = ToolRegistry()
+        discovery = DynamicToolDiscovery(registry)
+        discovery.status.errors.append("something broke")
+
+        data = discovery.status.to_dict()
+        assert data["healthy"] is False
+
+    async def test_multiple_scans_increment_count(self) -> None:
+        registry = ToolRegistry()
+        discovery = DynamicToolDiscovery(registry)
+
+        await discovery.scan()
+        await discovery.scan()
+        await discovery.scan()
+
+        assert discovery.status.scan_count == 3
