index 0000000..d4e682b
--- /dev/null
+++ b/engine/src/agent33/api/routes/discovery.py
@@ -0,0 +1,328 @@
+"""API routes for dynamic tool discovery and session-scoped tool activation."""
+
+# NOTE: no ``from __future__ import annotations`` -- Pydantic needs these
+# types at runtime for request-body validation.
+
+from typing import Any
+
+import structlog
+from fastapi import APIRouter, HTTPException, Request, status
+from pydantic import BaseModel, Field
+
+from agent33.security.permissions import require_scope
+
+logger = structlog.get_logger()
+
+router = APIRouter(prefix="/v1", tags=["discovery"])
+
+
+# -- Request / response models -----------------------------------------------
+
+
+class ResolveRequest(BaseModel):
+    """Request body for semantic skill resolution."""
+
+    query: str = Field(..., min_length=1, description="Natural-language query")
+    max_results: int = Field(default=5, ge=1, le=50)
+    include_instructions: bool = False
+
+
+class ResolvedSkillResponse(BaseModel):
+    """A single resolved skill."""
+
+    name: str
+    description: str
+    score: float
+    tags: list[str] = Field(default_factory=list)
+    instructions: str = ""
+
+
+class ResolveResponse(BaseModel):
+    """Response for semantic skill resolution."""
+
+    query: str
+    results: list[ResolvedSkillResponse]
+    count: int
+
+
+class ActivateRequest(BaseModel):
+    """Request body for tool activation."""
+
+    tool_names: list[str] = Field(..., min_length=1)
+
+
+class ActivationSetResponse(BaseModel):
+    """Response showing the current activation state."""
+
+    session_id: str
+    core_tools: list[str]
+    activated_tools: list[str]
+    deactivated_tools: list[str]
+    visible_tools: list[str]
+
+
+class DiscoveryStatusResponse(BaseModel):
+    """Response for discovery system status."""
+
+    last_scan: str | None = None
+    scan_count: int = 0
+    total_discovered: int = 0
+    mcp_discovered: int = 0
+    plugin_discovered: int = 0
+    entrypoint_discovered: int = 0
+    errors: list[str] = Field(default_factory=list)
+    healthy: bool = True
+
+
+class ScanResponse(BaseModel):
+    """Response for a discovery scan."""
+
+    total: int
+    added: list[str] = Field(default_factory=list)
+    removed: list[str] = Field(default_factory=list)
+    entrypoint_count: int = 0
+    mcp_count: int = 0
+    errors: list[str] = Field(default_factory=list)
+
+
+class ActiveToolResponse(BaseModel):
+    """A single active tool in a session."""
+
+    name: str
+    description: str = ""
+    category: str = ""
+    source: str = ""
+
+
+# -- Helpers ------------------------------------------------------------------
+
+
+def _get_resolver(request: Request) -> Any:
+    """Extract the SemanticSkillResolver from app state."""
+    resolver = getattr(request.app.state, "skill_resolver", None)
+    if resolver is None:
+        raise HTTPException(
+            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
+            detail="Semantic skill resolver not initialized",
+        )
+    return resolver
+
+
+def _get_activation_manager(request: Request) -> Any:
+    """Extract the ToolActivationManager from app state."""
+    manager = getattr(request.app.state, "tool_activation_manager", None)
+    if manager is None:
+        raise HTTPException(
+            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
+            detail="Tool activation manager not initialized",
+        )
+    return manager
+
+
+def _get_discovery(request: Request) -> Any:
+    """Extract the DynamicToolDiscovery from app state."""
+    discovery = getattr(request.app.state, "tool_discovery", None)
+    if discovery is None:
+        raise HTTPException(
+            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
+            detail="Dynamic tool discovery not initialized",
+        )
+    return discovery
+
+
+def _get_catalog_service(request: Request) -> Any:
+    """Extract the ToolCatalogService from app state."""
+    service = getattr(request.app.state, "tool_catalog_service", None)
+    if service is None:
+        raise HTTPException(
+            status_code=status.HTTP_503_SERVICE_UNAVAILABLE,
+            detail="Tool catalog service not initialized",
+        )
+    return service
+
+
+# -- Semantic resolution endpoints --------------------------------------------
+
+
+@router.post(
+    "/discovery/resolve",
+    response_model=ResolveResponse,
+    dependencies=[require_scope("tools:execute")],
+)
+async def resolve_skills(request: Request, body: ResolveRequest) -> ResolveResponse:
+    """Semantic skill resolution: match a natural-language query to skills."""
+    resolver = _get_resolver(request)
+
+    results = await resolver.resolve(
+        body.query,
+        top_k=body.max_results,
+        include_instructions=body.include_instructions,
+        exclude_deprecated=True,
+    )
+
+    return ResolveResponse(
+        query=body.query,
+        results=[
+            ResolvedSkillResponse(
+                name=r.name,
+                description=r.description,
+                score=round(r.score, 4),
+                tags=r.tags,
+                instructions=r.instructions,
+            )
+            for r in results
+        ],
+        count=len(results),
+    )
+
+
+# -- Dynamic discovery endpoints ----------------------------------------------
+
+
+@router.get(
+    "/discovery/scan",
+    response_model=ScanResponse,
+    dependencies=[require_scope("admin")],
+)
+async def trigger_scan(request: Request) -> ScanResponse:
+    """Trigger a dynamic tool re-scan across all sources."""
+    discovery = _get_discovery(request)
+    result = await discovery.scan()
+    return ScanResponse(
+        total=result.total,
+        added=result.added,
+        removed=result.removed,
+        entrypoint_count=result.entrypoint_count,
+        mcp_count=result.mcp_count,
+        errors=result.errors,
+    )
+
+
+@router.get(
+    "/discovery/status",
+    response_model=DiscoveryStatusResponse,
+    dependencies=[require_scope("tools:execute")],
+)
+async def discovery_status(request: Request) -> DiscoveryStatusResponse:
+    """Return the current discovery index status."""
+    discovery = _get_discovery(request)
+    st = discovery.status
+    return DiscoveryStatusResponse(
+        last_scan=st.last_scan.isoformat() if st.last_scan else None,
+        scan_count=st.scan_count,
+        total_discovered=st.total_discovered,
+        mcp_discovered=st.mcp_discovered,
+        plugin_discovered=st.plugin_discovered,
+        entrypoint_discovered=st.entrypoint_discovered,
+        errors=st.errors,
+        healthy=len(st.errors) == 0,
+    )
+
+
+# -- Session-scoped tool activation endpoints ---------------------------------
+
+
+@router.post(
+    "/sessions/{session_id}/tools/activate",
+    response_model=ActivationSetResponse,
+    dependencies=[require_scope("tools:execute")],
+)
+async def activate_tools(
+    request: Request, session_id: str, body: ActivateRequest
+) -> ActivationSetResponse:
+    """Activate tools in a session."""
+    manager = _get_activation_manager(request)
+    # Ensure the set exists.
+    manager.get_or_create(session_id)
+    manager.activate(session_id, body.tool_names)
+    return _build_activation_response(manager, session_id)
+
+
+@router.delete(
+    "/sessions/{session_id}/tools/{tool_name}",
+    response_model=ActivationSetResponse,
+    dependencies=[require_scope("tools:execute")],
+)
+async def deactivate_tool(
+    request: Request, session_id: str, tool_name: str
+) -> ActivationSetResponse:
+    """Deactivate a tool from a session."""
+    manager = _get_activation_manager(request)
+    aset = manager.get(session_id)
+    if aset is None:
+        raise HTTPException(
+            status_code=status.HTTP_404_NOT_FOUND,
+            detail=f"No activation set for session '{session_id}'",
+        )
+    manager.deactivate(session_id, [tool_name])
+    return _build_activation_response(manager, session_id)
+
+
+@router.get(
+    "/sessions/{session_id}/tools",
+    response_model=list[ActiveToolResponse],
+    dependencies=[require_scope("tools:execute")],
+)
+async def list_active_tools(
+    request: Request, session_id: str
+) -> list[ActiveToolResponse]:
+    """List active tools in a session."""
+    manager = _get_activation_manager(request)
+    catalog = _get_catalog_service(request)
+
+    visible = manager.list_visible(session_id)
+    if not visible:
+        # If no activation set, return all tools (legacy mode).
+        aset = manager.get(session_id)
+        if aset is None:
+            all_tools = catalog.build_catalog()
+            results: list[ActiveToolResponse] = []
+            for group in all_tools.groups:
+                for tool in group.tools:
+                    results.append(
+                        ActiveToolResponse(
+                            name=tool.name,
+                            description=tool.description,
+                            category=tool.category,
+                            source=tool.source,
+                        )
+                    )
+            return results
+
+    results = []
+    for name in visible:
+        detail = catalog.get_tool_detail(name)
+        if detail:
+            results.append(
+                ActiveToolResponse(
+                    name=detail.name,
+                    description=detail.description,
+                    category=detail.category,
+                    source=detail.source,
+                )
+            )
+        else:
+            results.append(ActiveToolResponse(name=name))
+    return results
+
+
+def _build_activation_response(
+    manager: Any, session_id: str
+) -> ActivationSetResponse:
+    """Build an ActivationSetResponse from the manager state."""
+    aset = manager.get(session_id)
+    if aset is None:
+        return ActivationSetResponse(
+            session_id=session_id,
+            core_tools=[],
+            activated_tools=[],
+            deactivated_tools=[],
+            visible_tools=[],
+        )
+    return ActivationSetResponse(
+        session_id=session_id,
+        core_tools=aset.core_tools,
+        activated_tools=sorted(aset.activated_tools),
+        deactivated_tools=sorted(aset.deactivated_tools),
+        visible_tools=manager.list_visible(session_id),
+    )
