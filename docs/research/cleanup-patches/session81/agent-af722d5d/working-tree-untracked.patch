+"""Tests for semantic skill embedding index and resolver (Phase 46)."""
+
+from __future__ import annotations
+
+from typing import Any
+from unittest.mock import AsyncMock
+
+import pytest
+
+from agent33.skills.definition import SkillDefinition, SkillStatus
+from agent33.skills.registry import SkillRegistry
+from agent33.skills.semantic import SkillEmbeddingIndex
+from agent33.skills.semantic_resolver import SemanticSkillResolver
+
+
+# -- Helpers ------------------------------------------------------------------
+
+
+def _make_embedding_provider(dim: int = 4) -> AsyncMock:
+    """Create a mock EmbeddingProvider that returns deterministic vectors.
+
+    Uses a simple hash-based approach: each word in the text shifts
+    the vector slightly, ensuring different texts produce different
+    embeddings while keeping vectors normalized enough for cosine
+    similarity to be meaningful.
+    """
+    provider = AsyncMock()
+
+    async def _embed(text: str) -> list[float]:
+        # Deterministic vector based on text content.
+        words = text.lower().split()
+        vec = [0.0] * dim
+        for i, word in enumerate(words):
+            idx = hash(word) % dim
+            vec[idx] += 1.0
+        # Normalize.
+        magnitude = sum(v * v for v in vec) ** 0.5
+        if magnitude > 0:
+            vec = [v / magnitude for v in vec]
+        return vec
+
+    provider.embed = AsyncMock(side_effect=_embed)
+    return provider
+
+
+def _make_skill(
+    name: str,
+    description: str,
+    tags: list[str] | None = None,
+    instructions: str = "",
+    status: SkillStatus = SkillStatus.ACTIVE,
+) -> SkillDefinition:
+    return SkillDefinition(
+        name=name,
+        description=description,
+        tags=tags or [],
+        instructions=instructions,
+        status=status,
+    )
+
+
+def _make_registry(*skills: SkillDefinition) -> SkillRegistry:
+    registry = SkillRegistry()
+    for skill in skills:
+        registry.register(skill)
+    return registry
+
+
+# -- SkillEmbeddingIndex tests ------------------------------------------------
+
+
+class TestSkillEmbeddingIndex:
+    async def test_index_single_skill(self) -> None:
+        provider = _make_embedding_provider()
+        index = SkillEmbeddingIndex(provider)
+        skill = _make_skill("deploy-k8s", "Deploy to Kubernetes cluster", ["devops"])
+
+        result = await index.index_skill(skill)
+        assert result is True
+        assert index.size == 1
+        assert "deploy-k8s" in index.indexed_names
+
+    async def test_index_all_skills(self) -> None:
+        provider = _make_embedding_provider()
+        index = SkillEmbeddingIndex(provider)
+        skills = [
+            _make_skill("skill-a", "Skill A"),
+            _make_skill("skill-b", "Skill B"),
+            _make_skill("skill-c", "Skill C"),
+        ]
+        count = await index.index_all(skills)
+        assert count == 3
+        assert index.size == 3
+
+    async def test_index_skill_embedding_failure_returns_false(self) -> None:
+        provider = AsyncMock()
+        provider.embed = AsyncMock(side_effect=ConnectionError("Ollama unavailable"))
+        index = SkillEmbeddingIndex(provider)
+        skill = _make_skill("broken", "This will fail to embed")
+
+        result = await index.index_skill(skill)
+        assert result is False
+        assert index.size == 0
+
+    async def test_search_returns_ranked_results(self) -> None:
+        provider = _make_embedding_provider(dim=8)
+        index = SkillEmbeddingIndex(provider)
+
+        # Index skills with different descriptions.
+        await index.index_skill(
+            _make_skill("deploy-k8s", "Deploy containers to Kubernetes cluster")
+        )
+        await index.index_skill(
+            _make_skill("send-email", "Send email notifications to users")
+        )
+        await index.index_skill(
+            _make_skill("deploy-docker", "Deploy Docker containers to production")
+        )
+
+        results = await index.search("deploy containers", top_k=3)
+
+        # Should return results ranked by similarity.
+        assert len(results) == 3
+        # All three skills should appear with scores.
+        names = [name for name, _ in results]
+        assert len(names) == 3
+        # The top result's score should be >= the last result's score.
+        scores = [score for _, score in results]
+        assert scores[0] >= scores[-1]
+
+    async def test_search_empty_index_returns_empty(self) -> None:
+        provider = _make_embedding_provider()
+        index = SkillEmbeddingIndex(provider)
+        results = await index.search("anything")
+        assert results == []
+
+    async def test_search_embedding_failure_returns_empty(self) -> None:
+        provider = _make_embedding_provider()
+        index = SkillEmbeddingIndex(provider)
+        await index.index_skill(_make_skill("test", "Test skill"))
+
+        # Make the query embedding fail.
+        provider.embed = AsyncMock(side_effect=ConnectionError("down"))
+        results = await index.search("test")
+        assert results == []
+
+    async def test_search_top_k_limits_results(self) -> None:
+        provider = _make_embedding_provider(dim=16)
+        index = SkillEmbeddingIndex(provider)
+        for i in range(10):
+            await index.index_skill(_make_skill(f"skill-{i}", f"Skill number {i}"))
+
+        results = await index.search("skill", top_k=3)
+        assert len(results) == 3
+
+    async def test_remove_skill(self) -> None:
+        provider = _make_embedding_provider()
+        index = SkillEmbeddingIndex(provider)
+        await index.index_skill(_make_skill("to-remove", "Will be removed"))
+        assert index.size == 1
+
+        assert index.remove("to-remove") is True
+        assert index.size == 0
+        assert index.remove("to-remove") is False
+
+    async def test_clear_index(self) -> None:
+        provider = _make_embedding_provider()
+        index = SkillEmbeddingIndex(provider)
+        await index.index_all([
+            _make_skill("a", "A"),
+            _make_skill("b", "B"),
+        ])
+        assert index.size == 2
+
+        index.clear()
+        assert index.size == 0
+
+    async def test_get_metadata(self) -> None:
+        provider = _make_embedding_provider()
+        index = SkillEmbeddingIndex(provider)
+        await index.index_skill(
+            _make_skill("deploy-k8s", "Deploy to K8s", tags=["devops", "containers"])
+        )
+
+        meta = index.get_metadata("deploy-k8s")
+        assert meta is not None
+        assert meta["name"] == "deploy-k8s"
+        assert meta["description"] == "Deploy to K8s"
+        assert "devops" in meta["tags"]
+
+    async def test_get_metadata_missing(self) -> None:
+        provider = _make_embedding_provider()
+        index = SkillEmbeddingIndex(provider)
+        assert index.get_metadata("nonexistent") is None
+
+    def test_cosine_similarity_identical_vectors(self) -> None:
+        v = [1.0, 0.0, 0.0, 1.0]
+        sim = SkillEmbeddingIndex._cosine_similarity(v, v)
+        assert abs(sim - 1.0) < 1e-6
+
+    def test_cosine_similarity_orthogonal_vectors(self) -> None:
+        a = [1.0, 0.0]
+        b = [0.0, 1.0]
+        sim = SkillEmbeddingIndex._cosine_similarity(a, b)
+        assert abs(sim) < 1e-6
+
+    def test_cosine_similarity_zero_vector(self) -> None:
+        a = [0.0, 0.0]
+        b = [1.0, 0.0]
+        sim = SkillEmbeddingIndex._cosine_similarity(a, b)
+        assert sim == 0.0
+
+    def test_cosine_similarity_mismatched_lengths(self) -> None:
+        a = [1.0, 0.0]
+        b = [1.0, 0.0, 0.0]
+        sim = SkillEmbeddingIndex._cosine_similarity(a, b)
+        assert sim == 0.0
+
+    def test_build_index_text_includes_metadata(self) -> None:
+        skill = _make_skill(
+            "deploy-k8s",
+            "Deploy to Kubernetes",
+            tags=["devops", "containers"],
+            instructions="Step 1: configure kubectl. Step 2: apply manifests.",
+        )
+        text = SkillEmbeddingIndex._build_index_text(skill)
+        assert "deploy-k8s" in text
+        assert "Deploy to Kubernetes" in text
+        assert "devops" in text
+        assert "containers" in text
+        assert "configure kubectl" in text
+
+
+# -- SemanticSkillResolver tests ----------------------------------------------
+
+
+class TestSemanticSkillResolver:
+    async def test_resolve_bm25_only(self) -> None:
+        """BM25-only resolution when no embedding index is provided."""
+        registry = _make_registry(
+            _make_skill("deploy-k8s", "Deploy to Kubernetes cluster", ["devops"]),
+            _make_skill("send-email", "Send email notifications"),
+            _make_skill("deploy-docker", "Deploy Docker containers"),
+        )
+        resolver = SemanticSkillResolver(registry, embedding_index=None)
+
+        results = await resolver.resolve("deploy")
+        assert len(results) > 0
+        # At least one deploy skill should appear.
+        names = [r.name for r in results]
+        assert any("deploy" in n for n in names)
+
+    async def test_resolve_hybrid(self) -> None:
+        """Hybrid resolution with both BM25 and semantic."""
+        provider = _make_embedding_provider(dim=8)
+        registry = _make_registry(
+            _make_skill("deploy-k8s", "Deploy to Kubernetes cluster", ["devops"]),
+            _make_skill("send-email", "Send email notifications"),
+            _make_skill("deploy-docker", "Deploy Docker containers"),
+        )
+        embedding_index = SkillEmbeddingIndex(provider)
+        await embedding_index.index_all(registry.list_all())
+
+        resolver = SemanticSkillResolver(registry, embedding_index=embedding_index)
+
+        results = await resolver.resolve("deploy containers")
+        assert len(results) > 0
+        # Deploy skills should rank above email.
+        deploy_found = False
+        email_found = False
+        for r in results:
+            if "deploy" in r.name:
+                assert not email_found, "Deploy skills should appear before email"
+                deploy_found = True
+            if r.name == "send-email":
+                email_found = True
+        assert deploy_found
+
+    async def test_resolve_excludes_deprecated(self) -> None:
+        registry = _make_registry(
+            _make_skill("old-skill", "Deprecated skill", status=SkillStatus.DEPRECATED),
+            _make_skill("new-skill", "Active skill"),
+        )
+        resolver = SemanticSkillResolver(registry)
+
+        results = await resolver.resolve("skill", exclude_deprecated=True)
+        names = [r.name for r in results]
+        assert "old-skill" not in names
+        assert "new-skill" in names
+
+    async def test_resolve_includes_deprecated_when_requested(self) -> None:
+        registry = _make_registry(
+            _make_skill("old-skill", "Deprecated skill", status=SkillStatus.DEPRECATED),
+        )
+        resolver = SemanticSkillResolver(registry)
+
+        results = await resolver.resolve("skill", exclude_deprecated=False)
+        names = [r.name for r in results]
+        assert "old-skill" in names
+
+    async def test_resolve_includes_instructions(self) -> None:
+        registry = _make_registry(
+            _make_skill(
+                "detailed-skill",
+                "A detailed skill",
+                instructions="Step 1: Do this. Step 2: Do that.",
+            ),
+        )
+        resolver = SemanticSkillResolver(registry)
+
+        # Without instructions.
+        results = await resolver.resolve("detailed", include_instructions=False)
+        assert results[0].instructions == ""
+
+        # With instructions.
+        resolver2 = SemanticSkillResolver(registry)
+        results = await resolver2.resolve("detailed", include_instructions=True)
+        assert "Step 1" in results[0].instructions
+
+    async def test_resolve_top_k_limits(self) -> None:
+        skills = [_make_skill(f"skill-{i}", f"Skill number {i}") for i in range(20)]
+        registry = _make_registry(*skills)
+        resolver = SemanticSkillResolver(registry)
+
+        results = await resolver.resolve("skill", top_k=5)
+        assert len(results) <= 5
+
+    async def test_resolve_empty_registry(self) -> None:
+        registry = _make_registry()
+        resolver = SemanticSkillResolver(registry)
+        results = await resolver.resolve("anything")
+        assert results == []
+
+    async def test_resolve_scores_are_positive(self) -> None:
+        registry = _make_registry(
+            _make_skill("deploy", "Deploy applications"),
+        )
+        resolver = SemanticSkillResolver(registry)
+        results = await resolver.resolve("deploy")
+        assert len(results) > 0
+        for r in results:
+            assert r.score > 0.0
+
+    async def test_resolve_results_have_tags(self) -> None:
+        registry = _make_registry(
+            _make_skill("deploy-k8s", "Deploy to K8s", ["devops", "containers"]),
+        )
+        resolver = SemanticSkillResolver(registry)
+        results = await resolver.resolve("deploy")
+        assert results[0].tags == ["devops", "containers"]
+
+    def test_build_bm25_index(self) -> None:
+        registry = _make_registry(
+            _make_skill("a", "Skill A"),
+            _make_skill("b", "Skill B"),
+        )
+        resolver = SemanticSkillResolver(registry)
+        assert not resolver.is_built
+
+        count = resolver.build_bm25_index()
+        assert count == 2
+        assert resolver.is_built
+
+    async def test_auto_builds_bm25_on_first_resolve(self) -> None:
+        registry = _make_registry(_make_skill("auto", "Auto build test"))
+        resolver = SemanticSkillResolver(registry)
+        assert not resolver.is_built
+
+        await resolver.resolve("auto")
