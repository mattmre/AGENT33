+"""Built-in tool for resolving natural-language objectives to skills."""
+
+from __future__ import annotations
+
+import json
+from typing import Any
+
+from agent33.tools.base import ToolContext, ToolResult
+
+
+class ResolveWorkflowTool:
+    """Resolve a natural-language objective to matching skills and workflows.
+
+    Uses the SemanticSkillResolver (hybrid BM25 + embedding search) to
+    find the best matching skills for a given objective.  Returns skill
+    metadata (L0) and optionally full instructions (L1) for top matches.
+    """
+
+    @property
+    def name(self) -> str:
+        return "resolve_workflow"
+
+    @property
+    def description(self) -> str:
+        return (
+            "Given a natural-language objective, find the best matching skills "
+            "and workflow templates. Returns skill instructions and metadata."
+        )
+
+    @property
+    def parameters_schema(self) -> dict[str, Any]:
+        return {
+            "type": "object",
+            "properties": {
+                "objective": {
+                    "type": "string",
+                    "description": (
+                        "Natural-language description of what you want to accomplish"
+                    ),
+                },
+                "max_results": {
+                    "type": "integer",
+                    "default": 3,
+                    "description": "Maximum number of matching skills to return",
+                },
+                "include_instructions": {
+                    "type": "boolean",
+                    "default": False,
+                    "description": "Include full skill instructions (L1) in results",
+                },
+            },
+            "required": ["objective"],
+        }
+
+    def __init__(self) -> None:
+        self._resolver: Any = None
+
+    def set_resolver(self, resolver: Any) -> None:
+        """Wire the SemanticSkillResolver after construction."""
+        self._resolver = resolver
+
+    async def execute(self, params: dict[str, Any], context: ToolContext) -> ToolResult:
+        """Resolve an objective to matching skills."""
+        objective = params.get("objective", "").strip()
+        if not objective:
+            return ToolResult.fail("The 'objective' parameter is required.")
+
+        if self._resolver is None:
+            return ToolResult.fail("Semantic skill resolver not available.")
+
+        max_results = params.get("max_results", 3)
+        include_instructions = params.get("include_instructions", False)
+
+        try:
+            results = await self._resolver.resolve(
+                objective,
+                top_k=max_results,
+                include_instructions=include_instructions,
+                exclude_deprecated=True,
+            )
+        except Exception as exc:
+            return ToolResult.fail(f"Skill resolution failed: {exc}")
+
+        if not results:
+            return ToolResult.ok("No matching skills found for the given objective.")
+
+        output = []
+        for resolved in results:
+            entry: dict[str, Any] = {
+                "name": resolved.name,
+                "description": resolved.description,
+                "score": round(resolved.score, 4),
+                "tags": resolved.tags,
+            }
+            if include_instructions and resolved.instructions:
+                entry["instructions"] = resolved.instructions
+            output.append(entry)
+
+        return ToolResult.ok(json.dumps(output, indent=2))
