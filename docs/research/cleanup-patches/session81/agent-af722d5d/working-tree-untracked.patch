+"""Tests for session-scoped tool activation (Phase 46)."""
+
+from __future__ import annotations
+
+import pytest
+
+from agent33.tools.activation import ToolActivationManager, ToolActivationSet
+from agent33.tools.catalog import CORE_TOOL_NAMES
+
+
+class TestToolActivationSet:
+    def test_creation_defaults(self) -> None:
+        aset = ToolActivationSet(session_id="s1", tenant_id="t1")
+        assert aset.session_id == "s1"
+        assert aset.tenant_id == "t1"
+        assert aset.core_tools == []
+        assert aset.activated_tools == set()
+        assert aset.deactivated_tools == set()
+
+    def test_serialize_round_trip(self) -> None:
+        aset = ToolActivationSet(
+            session_id="s1",
+            tenant_id="t1",
+            core_tools=["shell", "file_ops"],
+            activated_tools={"web_fetch"},
+            deactivated_tools={"browser"},
+        )
+        data = aset.to_persist()
+        restored = ToolActivationSet.from_persist(data)
+
+        assert restored.session_id == "s1"
+        assert restored.tenant_id == "t1"
+        assert restored.core_tools == ["shell", "file_ops"]
+        assert restored.activated_tools == {"web_fetch"}
+        assert restored.deactivated_tools == {"browser"}
+
+
+class TestToolActivationManager:
+    def test_get_or_create_new_session(self) -> None:
+        mgr = ToolActivationManager(core_tools=["shell", "file_ops"])
+        aset = mgr.get_or_create("session-1", "tenant-1")
+
+        assert aset.session_id == "session-1"
+        assert aset.tenant_id == "tenant-1"
+        assert aset.core_tools == ["shell", "file_ops"]
+        assert mgr.session_count == 1
+
+    def test_get_or_create_returns_existing(self) -> None:
+        mgr = ToolActivationManager(core_tools=["shell"])
+        aset1 = mgr.get_or_create("session-1")
+        aset2 = mgr.get_or_create("session-1")
+        assert aset1.session_id == aset2.session_id
+        assert mgr.session_count == 1
+
+    def test_get_nonexistent_returns_none(self) -> None:
+        mgr = ToolActivationManager()
+        assert mgr.get("nonexistent") is None
+
+    def test_activate_adds_tools(self) -> None:
+        mgr = ToolActivationManager(core_tools=["shell"])
+        mgr.get_or_create("s1")
+        mgr.activate("s1", ["web_fetch", "browser"])
+
+        aset = mgr.get("s1")
+        assert aset is not None
+        assert "web_fetch" in aset.activated_tools
+        assert "browser" in aset.activated_tools
+
+    def test_activate_removes_from_deactivated(self) -> None:
+        mgr = ToolActivationManager(core_tools=["shell"])
+        mgr.get_or_create("s1")
+        mgr.activate("s1", ["web_fetch"])
+        mgr.deactivate("s1", ["web_fetch"])
+
+        aset = mgr.get("s1")
+        assert aset is not None
+        assert "web_fetch" in aset.deactivated_tools
+        assert "web_fetch" not in aset.activated_tools
+
+        # Re-activate should move it back.
+        mgr.activate("s1", ["web_fetch"])
+        aset = mgr.get("s1")
+        assert aset is not None
+        assert "web_fetch" in aset.activated_tools
+        assert "web_fetch" not in aset.deactivated_tools
+
+    def test_activate_nonexistent_session_raises(self) -> None:
+        mgr = ToolActivationManager()
+        with pytest.raises(KeyError, match="No activation set"):
+            mgr.activate("nonexistent", ["shell"])
+
+    def test_deactivate_nonexistent_session_raises(self) -> None:
+        mgr = ToolActivationManager()
+        with pytest.raises(KeyError, match="No activation set"):
+            mgr.deactivate("nonexistent", ["shell"])
+
+    def test_deactivate_core_tool_is_blocked(self) -> None:
+        mgr = ToolActivationManager(core_tools=["shell"])
+        mgr.get_or_create("s1")
+        mgr.deactivate("s1", ["shell"])
+
+        # Core tool should NOT be in deactivated set.
+        aset = mgr.get("s1")
+        assert aset is not None
+        assert "shell" not in aset.deactivated_tools
+
+    def test_deactivate_non_core_tool(self) -> None:
+        mgr = ToolActivationManager(core_tools=["shell"])
+        mgr.get_or_create("s1")
+        mgr.activate("s1", ["web_fetch"])
+        mgr.deactivate("s1", ["web_fetch"])
+
+        aset = mgr.get("s1")
+        assert aset is not None
+        assert "web_fetch" in aset.deactivated_tools
+        assert "web_fetch" not in aset.activated_tools
+
+    def test_is_visible_core_tool(self) -> None:
+        mgr = ToolActivationManager(core_tools=["shell", "file_ops"])
+        mgr.get_or_create("s1")
+
+        assert mgr.is_visible("s1", "shell") is True
+        assert mgr.is_visible("s1", "file_ops") is True
+
+    def test_is_visible_activated_tool(self) -> None:
+        mgr = ToolActivationManager(core_tools=["shell"])
+        mgr.get_or_create("s1")
+        mgr.activate("s1", ["web_fetch"])
+
+        assert mgr.is_visible("s1", "web_fetch") is True
+
+    def test_is_visible_non_activated_tool(self) -> None:
+        mgr = ToolActivationManager(core_tools=["shell"])
+        mgr.get_or_create("s1")
+
+        assert mgr.is_visible("s1", "web_fetch") is False
+
+    def test_is_visible_deactivated_tool(self) -> None:
+        mgr = ToolActivationManager(core_tools=["shell"])
+        mgr.get_or_create("s1")
+        mgr.activate("s1", ["web_fetch"])
+        mgr.deactivate("s1", ["web_fetch"])
+
+        assert mgr.is_visible("s1", "web_fetch") is False
+
+    def test_is_visible_no_session_returns_true(self) -> None:
+        """No activation set means legacy mode -- everything visible."""
+        mgr = ToolActivationManager()
+        assert mgr.is_visible("nonexistent", "any_tool") is True
+
+    def test_list_visible(self) -> None:
+        mgr = ToolActivationManager(core_tools=["shell", "file_ops"])
+        mgr.get_or_create("s1")
+        mgr.activate("s1", ["web_fetch", "browser"])
+        mgr.deactivate("s1", ["browser"])
+
+        visible = mgr.list_visible("s1")
+        assert "shell" in visible
+        assert "file_ops" in visible
+        assert "web_fetch" in visible
+        assert "browser" not in visible
+
+    def test_list_visible_empty_session(self) -> None:
+        mgr = ToolActivationManager()
+        assert mgr.list_visible("nonexistent") == []
+
+    def test_session_isolation(self) -> None:
+        """Activating in session A does NOT affect session B."""
+        mgr = ToolActivationManager(core_tools=["shell"])
+        mgr.get_or_create("s1")
+        mgr.get_or_create("s2")
+
+        mgr.activate("s1", ["web_fetch"])
+
+        assert mgr.is_visible("s1", "web_fetch") is True
+        assert mgr.is_visible("s2", "web_fetch") is False
+
+    def test_remove_session(self) -> None:
+        mgr = ToolActivationManager()
+        mgr.get_or_create("s1")
+        assert mgr.session_count == 1
+
+        assert mgr.remove_session("s1") is True
+        assert mgr.session_count == 0
+        assert mgr.get("s1") is None
+
+    def test_remove_nonexistent_session(self) -> None:
+        mgr = ToolActivationManager()
+        assert mgr.remove_session("nonexistent") is False
+
+    def test_core_tools_property(self) -> None:
+        mgr = ToolActivationManager(core_tools=["a", "b"])
+        assert mgr.core_tools == ["a", "b"]
+
+    def test_default_core_tools(self) -> None:
+        mgr = ToolActivationManager()
+        # Should use CORE_TOOL_NAMES from catalog.
+        for name in mgr.core_tools:
+            assert name in CORE_TOOL_NAMES
