+"""Tool catalog data models for the dynamic discovery surface."""
+
+from __future__ import annotations
+
+from datetime import datetime
+from typing import Any
+
+from pydantic import BaseModel, Field
+
+from agent33.tools.registry_entry import ToolProvenance, ToolStatus
+
+
+# -- Category taxonomy -------------------------------------------------------
+
+CATEGORY_MAP: dict[str, str] = {
+    "file_ops": "files",
+    "apply_patch": "files",
+    "shell": "runtime",
+    "execute_code": "runtime",
+    "web_fetch": "web",
+    "web_search": "web",
+    "search": "web",
+    "browser": "web",
+    "telegram": "messaging",
+    "discord": "messaging",
+    "slack": "messaging",
+    "whatsapp": "messaging",
+    "matrix": "messaging",
+    "voice": "media",
+    "image": "media",
+    "discover_tools": "discovery",
+    "resolve_workflow": "discovery",
+}
+
+# Tools tagged as "core" are always visible in dynamic mode.
+CORE_TOOL_NAMES: frozenset[str] = frozenset(
+    {
+        "shell",
+        "file_ops",
+        "web_fetch",
+        "search",
+        "discover_tools",
+        "resolve_workflow",
+    }
+)
+
+
+class ToolCatalogEntry(BaseModel):
+    """A single tool in the runtime catalog."""
+
+    name: str
+    description: str
+    version: str = ""
+    category: str = ""
+    source: str = ""  # "core", "plugin:<id>", "pack:<id>", "mcp:<server>"
+    status: ToolStatus = ToolStatus.ACTIVE
+    available: bool = True
+    unavailable_reason: str = ""
+    parameters_schema: dict[str, Any] = Field(default_factory=dict)
+    result_schema: dict[str, Any] = Field(default_factory=dict)
+    tags: list[str] = Field(default_factory=list)
+    provenance: ToolProvenance | None = None
+    requires_approval: bool = False
+    last_used: datetime | None = None
+
+
+class ToolCatalogGroup(BaseModel):
+    """Tools grouped by category."""
+
+    category: str
+    tools: list[ToolCatalogEntry]
+
+
+class ToolCatalogResponse(BaseModel):
+    """Full catalog response."""
+
+    groups: list[ToolCatalogGroup]
+    total_count: int
+    active_count: int
+    discovery_mode: str  # "legacy" or "dynamic"
diff --git a/engine/src/agent33/tools/catalog_service.py b/engine/src/agent33/tools/catalog_service.py
new file mode 100644
index 0000000..db2f658
--- /dev/null
+++ b/engine/src/agent33/tools/catalog_service.py
@@ -0,0 +1,229 @@
+"""Catalog service that builds runtime-truth tool catalogs."""
+
+from __future__ import annotations
+
+import logging
+from typing import TYPE_CHECKING, Any
+
+from agent33.tools.catalog import (
+    CATEGORY_MAP,
+    ToolCatalogEntry,
+    ToolCatalogGroup,
+    ToolCatalogResponse,
+)
+from agent33.tools.registry_entry import ToolStatus
+
+if TYPE_CHECKING:
+    from agent33.skills.registry import SkillRegistry
+    from agent33.tools.base import SchemaAwareTool, Tool
+    from agent33.tools.registry import ToolRegistry
+
+logger = logging.getLogger(__name__)
+
+
+def _resolve_category(tool_name: str, tags: list[str]) -> str:
+    """Derive the category for a tool from the static map or its tags."""
+    if tool_name in CATEGORY_MAP:
+        return CATEGORY_MAP[tool_name]
+    # Check tags for a category hint.
+    for tag in tags:
+        low = tag.lower()
+        if low in CATEGORY_MAP.values():
+            return low
+    return "general"
+
+
+def _resolve_source(tool_name: str, entry_tags: list[str]) -> str:
+    """Determine the provenance source label for a tool."""
+    for tag in entry_tags:
+        if tag.startswith("plugin:") or tag.startswith("pack:") or tag.startswith("mcp:"):
+            return tag
+    return "core"
+
+
+class ToolCatalogService:
+    """Builds runtime-truth tool catalogs from ToolRegistry + SkillRegistry."""
+
+    def __init__(
+        self,
+        tool_registry: ToolRegistry,
+        skill_registry: SkillRegistry | None = None,
+    ) -> None:
+        self._tool_registry = tool_registry
+        self._skill_registry = skill_registry
+
+    def build_catalog(
+        self,
+        *,
+        tenant_id: str = "",
+        agent_id: str = "",
+        session_id: str = "",
+        include_schemas: bool = False,
+        category_filter: str = "",
+        status_filter: str = "",
+        source_filter: str = "",
+        discovery_mode: str = "legacy",
+    ) -> ToolCatalogResponse:
+        """Build the full catalog with grouping, filtering, and availability."""
+        entries: list[ToolCatalogEntry] = []
+
+        for tool in self._tool_registry.list_all():
+            reg_entry = self._tool_registry.get_entry(tool.name)
+            tags = reg_entry.tags if reg_entry else []
+            category = _resolve_category(tool.name, tags)
+            source = _resolve_source(tool.name, tags)
+            tool_status = reg_entry.status if reg_entry else ToolStatus.ACTIVE
+            version = reg_entry.version if reg_entry else ""
+            provenance = reg_entry.provenance if reg_entry else None
+
+            # Determine availability.
+            available = True
+            unavailable_reason = ""
+            if tool_status == ToolStatus.BLOCKED:
+                available = False
+                unavailable_reason = "Tool is blocked"
+            elif tool_status == ToolStatus.DEPRECATED:
+                dep_msg = reg_entry.deprecation_message if reg_entry else ""
+                unavailable_reason = dep_msg or "Tool is deprecated"
+
+            # Determine if approval is required (check for approval scope).
+            requires_approval = bool(
+                reg_entry
+                and reg_entry.scope
+                and reg_entry.scope.data_access == "write"
+            )
+
+            params_schema: dict[str, Any] = {}
+            result_schema: dict[str, Any] = {}
+            if include_schemas:
+                params_schema = self._get_params_schema(tool, reg_entry)
+                result_schema = (reg_entry.result_schema if reg_entry else {})
+
+            entry = ToolCatalogEntry(
+                name=tool.name,
+                description=tool.description,
+                version=version,
+                category=category,
+                source=source,
+                status=tool_status,
+                available=available,
+                unavailable_reason=unavailable_reason,
+                parameters_schema=params_schema,
+                result_schema=result_schema,
+                tags=tags,
+                provenance=provenance,
+                requires_approval=requires_approval,
+            )
+            entries.append(entry)
+
+        # Apply filters.
+        if category_filter:
+            entries = [e for e in entries if e.category == category_filter]
+        if status_filter:
+            entries = [e for e in entries if e.status.value == status_filter]
+        if source_filter:
+            entries = [e for e in entries if e.source.startswith(source_filter)]
+
+        # Group by category.
+        groups_map: dict[str, list[ToolCatalogEntry]] = {}
+        for entry in entries:
+            groups_map.setdefault(entry.category, []).append(entry)
+
+        groups = [
+            ToolCatalogGroup(category=cat, tools=tools)
+            for cat, tools in sorted(groups_map.items())
+        ]
+
+        active_count = sum(1 for e in entries if e.status == ToolStatus.ACTIVE)
+
+        return ToolCatalogResponse(
+            groups=groups,
+            total_count=len(entries),
+            active_count=active_count,
+            discovery_mode=discovery_mode,
+        )
+
+    def get_tool_detail(
+        self, tool_name: str
+    ) -> ToolCatalogEntry | None:
+        """Return full catalog entry for a single tool including schema."""
+        tool = self._tool_registry.get(tool_name)
+        if tool is None:
+            return None
+
+        reg_entry = self._tool_registry.get_entry(tool_name)
+        tags = reg_entry.tags if reg_entry else []
+        category = _resolve_category(tool_name, tags)
+        source = _resolve_source(tool_name, tags)
+        tool_status = reg_entry.status if reg_entry else ToolStatus.ACTIVE
+        version = reg_entry.version if reg_entry else ""
+        provenance = reg_entry.provenance if reg_entry else None
+
+        available = tool_status != ToolStatus.BLOCKED
+        unavailable_reason = ""
+        if tool_status == ToolStatus.BLOCKED:
+            unavailable_reason = "Tool is blocked"
+        elif tool_status == ToolStatus.DEPRECATED:
+            unavailable_reason = (
+                reg_entry.deprecation_message if reg_entry else "Tool is deprecated"
+            )
+
+        return ToolCatalogEntry(
+            name=tool.name,
+            description=tool.description,
+            version=version,
+            category=category,
+            source=source,
+            status=tool_status,
+            available=available,
+            unavailable_reason=unavailable_reason,
+            parameters_schema=self._get_params_schema(tool, reg_entry),
+            result_schema=(reg_entry.result_schema if reg_entry else {}),
+            tags=tags,
+            provenance=provenance,
+        )
+
+    def search_catalog(self, query: str) -> list[ToolCatalogEntry]:
+        """Text search across catalog entries."""
+        query_lower = query.lower()
+        results: list[ToolCatalogEntry] = []
+        for tool in self._tool_registry.list_all():
+            if (
+                query_lower in tool.name.lower()
+                or query_lower in tool.description.lower()
+            ):
+                reg_entry = self._tool_registry.get_entry(tool.name)
+                tags = reg_entry.tags if reg_entry else []
+                category = _resolve_category(tool.name, tags)
+                source = _resolve_source(tool.name, tags)
+                tool_status = reg_entry.status if reg_entry else ToolStatus.ACTIVE
+                version = reg_entry.version if reg_entry else ""
+
+                results.append(
+                    ToolCatalogEntry(
+                        name=tool.name,
+                        description=tool.description,
+                        version=version,
+                        category=category,
+                        source=source,
+                        status=tool_status,
+                        available=tool_status != ToolStatus.BLOCKED,
+                        tags=tags,
+                    )
+                )
+        return results
+
+    @staticmethod
+    def _get_params_schema(
+        tool: Tool,
+        reg_entry: Any,
+    ) -> dict[str, Any]:
+        """Extract parameters schema from a tool or its registry entry."""
+        # Prefer SchemaAwareTool's declared schema.
+        from agent33.tools.base import SchemaAwareTool
+
+        if isinstance(tool, SchemaAwareTool):
+            return dict(tool.parameters_schema)
+        if reg_entry and reg_entry.parameters_schema:
+            return dict(reg_entry.parameters_schema)
+        return {}
diff --git a/engine/src/agent33/tools/discovery.py b/engine/src/agent33/tools/discovery.py
new file mode 100644
index 0000000..df1f5c6
--- /dev/null
+++ b/engine/src/agent33/tools/discovery.py
@@ -0,0 +1,170 @@
+"""Dynamic tool discovery: runtime scanning beyond static registry."""
+
+from __future__ import annotations
+
+import logging
+from dataclasses import dataclass, field
+from datetime import datetime, timezone
+from typing import TYPE_CHECKING, Any
+
+if TYPE_CHECKING:
+    from agent33.tools.registry import ToolRegistry
+
+logger = logging.getLogger(__name__)
+
+
+@dataclass
+class DiscoveryStatus:
+    """Status of the dynamic discovery system."""
+
+    last_scan: datetime | None = None
+    scan_count: int = 0
+    total_discovered: int = 0
+    mcp_discovered: int = 0
+    plugin_discovered: int = 0
+    entrypoint_discovered: int = 0
+    errors: list[str] = field(default_factory=list)
+
+    def to_dict(self) -> dict[str, Any]:
+        """Serialize for API responses."""
+        return {
+            "last_scan": self.last_scan.isoformat() if self.last_scan else None,
+            "scan_count": self.scan_count,
+            "total_discovered": self.total_discovered,
+            "mcp_discovered": self.mcp_discovered,
+            "plugin_discovered": self.plugin_discovered,
+            "entrypoint_discovered": self.entrypoint_discovered,
+            "errors": self.errors,
+            "healthy": len(self.errors) == 0,
+        }
+
+
+class DynamicToolDiscovery:
+    """Runtime tool discovery beyond the static registry.
+
+    Scans multiple sources for available tools:
+    - MCP servers (via the tool registry's existing MCP integration)
+    - Python entrypoints (setuptools entry_points)
+    - Plugin-provided tools
+
+    Tracks what was discovered and when, and can detect changes between
+    successive scans.
+    """
+
+    def __init__(
+        self,
+        tool_registry: ToolRegistry,
+        mcp_server_urls: list[str] | None = None,
+    ) -> None:
+        self._tool_registry = tool_registry
+        self._mcp_urls = mcp_server_urls or []
+        self._status = DiscoveryStatus()
+        self._known_tools: set[str] = set()
+
+    @property
+    def status(self) -> DiscoveryStatus:
+        """Return the current discovery status."""
+        return self._status
+
+    async def scan(self) -> DiscoveryScanResult:
+        """Run a full discovery scan across all sources.
+
+        Returns a summary of what was found, including any newly
+        discovered or removed tools compared to the last scan.
+        """
+        self._status.errors.clear()
+        previous_tools = set(self._known_tools)
+
+        # Snapshot current tools before discovery.
+        pre_scan = {t.name for t in self._tool_registry.list_all()}
+
+        # -- Entrypoint discovery --------------------------------------------
+        entrypoint_count = 0
+        try:
+            entrypoint_count = self._tool_registry.discover_from_entrypoints()
+            self._status.entrypoint_discovered = entrypoint_count
+        except Exception as exc:
+            logger.error("Entrypoint discovery failed: %s", exc)
+            self._status.errors.append(f"entrypoint: {exc}")
+
+        # -- MCP server discovery --------------------------------------------
+        mcp_count = 0
+        for url in self._mcp_urls:
+            try:
+                count = await self._tool_registry.discover_mcp_sse_server(url)
+                mcp_count += count
+            except Exception as exc:
+                logger.error("MCP discovery failed for %s: %s", url, exc)
+                self._status.errors.append(f"mcp:{url}: {exc}")
+        self._status.mcp_discovered = mcp_count
+
+        # -- Plugin discovery ------------------------------------------------
+        # Plugins register tools via the ToolRegistry directly during their
+        # enable() lifecycle.  We count tools that appeared between scans
+        # and are not from entrypoints or MCP.
+        post_scan = {t.name for t in self._tool_registry.list_all()}
+        new_from_plugins = post_scan - pre_scan - {
+            t.name
+            for t in self._tool_registry.list_all()
+            if hasattr(t, "_mcp_session")
+        }
+        self._status.plugin_discovered = len(new_from_plugins)
+
+        # -- Aggregate -------------------------------------------------------
+        self._known_tools = post_scan
+        self._status.total_discovered = len(post_scan)
+        self._status.scan_count += 1
+        self._status.last_scan = datetime.now(timezone.utc)
+
+        added = post_scan - previous_tools if previous_tools else set()
+        removed = previous_tools - post_scan if previous_tools else set()
+
+        return DiscoveryScanResult(
+            total=len(post_scan),
+            added=sorted(added),
+            removed=sorted(removed),
+            entrypoint_count=entrypoint_count,
+            mcp_count=mcp_count,
+            errors=list(self._status.errors),
+        )
+
+    def add_mcp_url(self, url: str) -> None:
+        """Add an MCP server URL for future scans."""
+        if url not in self._mcp_urls:
+            self._mcp_urls.append(url)
+
+    def remove_mcp_url(self, url: str) -> bool:
+        """Remove an MCP server URL. Returns True if it was present."""
+        try:
+            self._mcp_urls.remove(url)
+            return True
+        except ValueError:
+            return False
+
+    @property
+    def mcp_urls(self) -> list[str]:
+        """Return configured MCP server URLs."""
+        return list(self._mcp_urls)
+
+
+@dataclass
+class DiscoveryScanResult:
+    """Result of a single discovery scan."""
+
+    total: int
+    added: list[str] = field(default_factory=list)
+    removed: list[str] = field(default_factory=list)
+    entrypoint_count: int = 0
+    mcp_count: int = 0
+    errors: list[str] = field(default_factory=list)
+
+    def to_dict(self) -> dict[str, Any]:
+        """Serialize for API responses."""
+        return {
+            "total": self.total,
+            "added": self.added,
+            "removed": self.removed,
+            "entrypoint_count": self.entrypoint_count,
+            "mcp_count": self.mcp_count,
+            "errors": self.errors,
+        }
