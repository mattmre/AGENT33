+"""Restore planning (preview only) for backup archives.
+
+Track Phase 6 implements restore *planning* only. Actual restore execution
+is a future phase. The planner generates a preview of what would be restored,
+including conflict detection, without making any state changes.
+"""
+
+from __future__ import annotations
+
+import logging
+from pathlib import Path  # noqa: TCH003
+
+from agent33.backup.archive import extract_manifest
+from agent33.backup.models import (
+    RestoreAssetPlan,
+    RestoreConflict,
+    RestorePlan,
+)
+
+logger = logging.getLogger(__name__)
+
+
+class RestorePlanner:
+    """Generates restore plans from backup archives."""
+
+    def __init__(self, target_root: Path) -> None:
+        self._target_root = target_root
+
+    def plan(self, archive_path: Path) -> RestorePlan:
+        """Generate a restore plan from a backup archive.
+
+        This is a read-only operation. No state changes are made.
+        """
+        manifest = extract_manifest(archive_path)
+        if manifest is None:
+            return RestorePlan(
+                backup_id="",
+                warnings=["Cannot read backup manifest from archive"],
+            )
+
+        assets_to_restore: list[RestoreAssetPlan] = []
+        conflicts: list[RestoreConflict] = []
+        warnings: list[str] = []
+
+        for asset in manifest.assets:
+            if not asset.included:
+                continue
+
+            # Determine target path
+            target = self._target_root / asset.relative_path
+            current_exists = target.exists()
+
+            if current_exists:
+                # Check for conflicts
+                action = "overwrite"
+
+                # If the file has been modified since the backup
+                if asset.checksum:
+                    from agent33.backup.archive import compute_sha256
+
+                    try:
+                        current_checksum = compute_sha256(target)
+                        if current_checksum != asset.checksum:
+                            conflicts.append(
+                                RestoreConflict(
+                                    relative_path=asset.relative_path,
+                                    conflict_type="file_modified",
+                                    message=(
+                                        f"File has been modified since backup "
+                                        f"(backup: {asset.checksum[:12]}..., "
+                                        f"current: {current_checksum[:12]}...)"
+                                    ),
+                                    resolution="overwrite",
+                                )
+                            )
+                    except OSError:
+                        warnings.append(
+                            f"Cannot read current file for comparison: {asset.relative_path}"
+                        )
+            else:
+                action = "create"
+
+            assets_to_restore.append(
+                RestoreAssetPlan(
+                    relative_path=asset.relative_path,
+                    asset_type=asset.asset_type,
+                    action=action,
+                    current_exists=current_exists,
+                    size_bytes=asset.size_bytes,
+                )
+            )
+
+        # Check schema version compatibility
+        if manifest.schema_version != "1.0":
+            warnings.append(
+                f"Backup schema version {manifest.schema_version} may not be "
+                f"fully compatible with current version"
+            )
+
+        return RestorePlan(
+            backup_id=manifest.backup_id,
+            backup_version=manifest.runtime_version,
+            assets_to_restore=assets_to_restore,
+            conflicts=conflicts,
+            warnings=warnings,
+        )
