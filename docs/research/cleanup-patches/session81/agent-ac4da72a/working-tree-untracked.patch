+"""Tests for Track Phase 6: backup service, archive, manifest, and restore planner."""
+
+from __future__ import annotations
+
+import tarfile
+from datetime import UTC, datetime
+from pathlib import Path
+
+from agent33.backup.archive import (
+    compute_sha256,
+    create_archive,
+    extract_manifest,
+    generate_archive_name,
+    should_exclude,
+    verify_archive_integrity,
+)
+from agent33.backup.models import (
+    AssetType,
+    BackupAsset,
+    BackupManifest,
+    BackupMode,
+    BackupSummary,
+    VerifyCheck,
+    VerifyResult,
+)
+from agent33.backup.restore_planner import RestorePlanner
+from agent33.backup.service import BackupService
+
+# ---------------------------------------------------------------------------
+# Manifest model tests
+# ---------------------------------------------------------------------------
+
+
+class TestBackupModels:
+    def test_manifest_serialization(self) -> None:
+        manifest = BackupManifest(
+            backup_id="test-123",
+            platform="linux",
+            backup_mode=BackupMode.FULL,
+            label="nightly",
+        )
+        data = manifest.model_dump(mode="json")
+        assert data["backup_id"] == "test-123"
+        assert data["schema_version"] == "1.0"
+        assert data["backup_mode"] == "full"
+        assert data["label"] == "nightly"
+
+    def test_manifest_roundtrip(self) -> None:
+        original = BackupManifest(
+            backup_id="rt-001",
+            platform="win32",
+            backup_mode=BackupMode.CONFIG_ONLY,
+            assets=[
+                BackupAsset(
+                    relative_path="config/settings.json",
+                    asset_type=AssetType.CONFIG,
+                    size_bytes=1024,
+                    checksum="abc123",
+                )
+            ],
+            checksums={"config/settings.json": "abc123"},
+        )
+        json_str = original.model_dump_json()
+        restored = BackupManifest.model_validate_json(json_str)
+        assert restored.backup_id == "rt-001"
+        assert len(restored.assets) == 1
+        assert restored.assets[0].checksum == "abc123"
+        assert restored.checksums["config/settings.json"] == "abc123"
+
+    def test_backup_modes(self) -> None:
+        assert BackupMode.FULL.value == "full"
+        assert BackupMode.CONFIG_ONLY.value == "config-only"
+        assert BackupMode.NO_WORKSPACE.value == "no-workspace"
+
+    def test_asset_types(self) -> None:
+        assert AssetType.CONFIG.value == "config"
+        assert AssetType.AGENT_DEFINITIONS.value == "agent_definitions"
+        assert AssetType.SKILLS.value == "skills"
+
+    def test_verify_result_all_passed(self) -> None:
+        result = VerifyResult(
+            valid=True,
+            checks=[
+                VerifyCheck(name="c1", passed=True, message="ok"),
+                VerifyCheck(name="c2", passed=True, message="ok"),
+            ],
+        )
+        assert result.valid is True
+        assert all(c.passed for c in result.checks)
+
+    def test_verify_result_with_failure(self) -> None:
+        result = VerifyResult(
+            valid=False,
+            checks=[
+                VerifyCheck(name="c1", passed=True, message="ok"),
+                VerifyCheck(name="c2", passed=False, message="bad checksum"),
+            ],
+        )
+        assert result.valid is False
+
+    def test_backup_summary(self) -> None:
+        summary = BackupSummary(
+            backup_id="sum-1",
+            created_at=datetime.now(UTC),
+            mode=BackupMode.FULL,
+            size_bytes=4096,
+            asset_count=5,
+        )
+        assert summary.backup_id == "sum-1"
+        assert summary.size_bytes == 4096
+
+
+# ---------------------------------------------------------------------------
+# Archive utility tests
+# ---------------------------------------------------------------------------
+
+
+class TestArchiveUtilities:
+    def test_compute_sha256(self, tmp_path: Path) -> None:
+        f = tmp_path / "hash_test.txt"
+        f.write_text("hello world")
+        checksum = compute_sha256(f)
+        assert len(checksum) == 64  # SHA-256 hex digest length
+        # Known SHA-256 of "hello world"
+        assert checksum == "b94d27b9934d3e08a52e52d7da7dabfac484efe37a5380ee9088f7ace2efcde9"
+
+    def test_generate_archive_name(self) -> None:
+        ts = datetime(2026, 3, 10, 14, 30, 22, tzinfo=UTC)
+        name = generate_archive_name("full", "a1b2c3d4", ts)
+        assert name == "agent33-backup-20260310-143022-full-a1b2c3d4.tar.gz"
+
+    def test_generate_archive_name_config_only(self) -> None:
+        ts = datetime(2026, 1, 1, 0, 0, 0, tzinfo=UTC)
+        name = generate_archive_name("config-only", "xyz12345", ts)
+        assert "config-only" in name
+        assert "xyz12345" in name
+
+    def test_should_exclude_pycache(self) -> None:
+        assert should_exclude("__pycache__") is True
+
+    def test_should_exclude_pyc(self) -> None:
+        assert should_exclude("module.pyc") is True
+
+    def test_should_exclude_dotenv(self) -> None:
+        assert should_exclude(".env") is True
+
+    def test_should_exclude_node_modules(self) -> None:
+        assert should_exclude("node_modules") is True
+
+    def test_should_not_exclude_normal_file(self) -> None:
+        assert should_exclude("main.py") is False
+
+    def test_create_archive(self, tmp_path: Path) -> None:
+        # Set up source
+        src_dir = tmp_path / "source"
+        src_dir.mkdir()
+        (src_dir / "file1.txt").write_text("content1")
+        (src_dir / "file2.txt").write_text("content2")
+
+        manifest = BackupManifest(
+            backup_id="arc-test",
+            platform="test",
+        )
+        output = tmp_path / "test.tar.gz"
+
+        result = create_archive({"data": src_dir}, manifest, output)
+        assert result.exists()
+        assert result.stat().st_size > 0
+
+        # Verify contents
+        with tarfile.open(str(result), "r:gz") as tar:
+            names = tar.getnames()
+            assert "manifest.json" in names
+            assert "data/file1.txt" in names
+            assert "data/file2.txt" in names
+
+    def test_create_archive_excludes_pycache(self, tmp_path: Path) -> None:
+        src_dir = tmp_path / "source"
+        src_dir.mkdir()
+        (src_dir / "good.py").write_text("code")
+        cache_dir = src_dir / "__pycache__"
+        cache_dir.mkdir()
+        (cache_dir / "bad.pyc").write_text("bytecode")
+
+        manifest = BackupManifest(backup_id="excl-test")
+        output = tmp_path / "excl.tar.gz"
+
+        create_archive({"src": src_dir}, manifest, output)
+
+        with tarfile.open(str(output), "r:gz") as tar:
+            names = tar.getnames()
+            assert "src/good.py" in names
+            assert all("__pycache__" not in n for n in names)
+
+    def test_extract_manifest(self, tmp_path: Path) -> None:
+        src_dir = tmp_path / "source"
+        src_dir.mkdir()
+        (src_dir / "data.txt").write_text("test")
+
+        manifest = BackupManifest(
+            backup_id="extract-test",
+            label="my-backup",
+        )
+        output = tmp_path / "mf.tar.gz"
+        create_archive({"data": src_dir}, manifest, output)
+
+        extracted = extract_manifest(output)
+        assert extracted is not None
+        assert extracted.backup_id == "extract-test"
+        assert extracted.label == "my-backup"
+
+    def test_extract_manifest_invalid_archive(self, tmp_path: Path) -> None:
+        bad_file = tmp_path / "bad.tar.gz"
+        bad_file.write_text("not a tarfile")
+
+        result = extract_manifest(bad_file)
+        assert result is None
+
+    def test_verify_archive_integrity(self, tmp_path: Path) -> None:
+        src_dir = tmp_path / "source"
+        src_dir.mkdir()
+        (src_dir / "f.txt").write_text("verify me")
+
+        manifest = BackupManifest(backup_id="verify-test")
+        output = tmp_path / "verify.tar.gz"
+        create_archive({"data": src_dir}, manifest, output)
+
+        checks = verify_archive_integrity(output)
+        assert len(checks) >= 4
+        assert all(passed for _, passed, _ in checks)
+
+    def test_verify_archive_corrupt(self, tmp_path: Path) -> None:
+        bad = tmp_path / "corrupt.tar.gz"
+        bad.write_bytes(b"\x00" * 100)
+
+        checks = verify_archive_integrity(bad)
+        assert any(not passed for _, passed, _ in checks)
+
+
+# ---------------------------------------------------------------------------
+# BackupService tests
+# ---------------------------------------------------------------------------
+
+
+class TestBackupService:
+    def _make_service(self, tmp_path: Path) -> BackupService:
+        config_dir = tmp_path / "config"
+        config_dir.mkdir()
+        (config_dir / "app.json").write_text('{"key": "value"}')
+
+        data_dir = tmp_path / "data"
+        data_dir.mkdir()
+        skills_dir = data_dir / "skills"
+        skills_dir.mkdir()
+        (skills_dir / "skill1.md").write_text("# Skill 1")
+
+        backup_dir = tmp_path / "backups"
+
+        return BackupService(
+            backup_dir=backup_dir,
+            config_dir=config_dir,
+            data_dir=data_dir,
+        )
+
+    async def test_create_full_backup(self, tmp_path: Path) -> None:
+        service = self._make_service(tmp_path)
+        result = await service.create(mode="full", label="test-full")
+
+        assert result.success is True
+        assert result.backup_id != ""
+        assert result.archive_path != ""
+        assert result.asset_count > 0
+        assert result.manifest is not None
+        assert result.manifest.label == "test-full"
+        assert result.manifest.backup_mode == BackupMode.FULL
+        assert Path(result.archive_path).exists()
+
+    async def test_create_config_only_backup(self, tmp_path: Path) -> None:
+        service = self._make_service(tmp_path)
+        result = await service.create(mode="config-only")
+
+        assert result.success is True
+        assert result.manifest is not None
+        assert result.manifest.backup_mode == BackupMode.CONFIG_ONLY
+        # Config-only should have fewer assets
+        full = await service.create(mode="full")
+        assert result.asset_count <= full.asset_count
+
+    async def test_create_invalid_mode(self, tmp_path: Path) -> None:
+        service = self._make_service(tmp_path)
+        result = await service.create(mode="invalid")
+
+        assert result.success is False
+        assert "Invalid" in result.errors[0]
+
+    async def test_list_backups(self, tmp_path: Path) -> None:
+        service = self._make_service(tmp_path)
+        await service.create(mode="full", label="first")
+        await service.create(mode="full", label="second")
+
+        backups = service.list_backups()
