@@ -0,0 +1,147 @@
+"""FastAPI router for backup and restore operations."""
+
+from __future__ import annotations
+
+from typing import Any
+
+from fastapi import APIRouter, HTTPException, Request
+from pydantic import BaseModel
+
+from agent33.backup.service import BackupService  # noqa: TCH001
+from agent33.security.permissions import require_scope
+
+router = APIRouter(prefix="/v1/backups", tags=["backups"])
+
+_service: BackupService | None = None
+
+
+def set_backup_service(service: BackupService) -> None:
+    global _service  # noqa: PLW0603
+    _service = service
+
+
+def _get_service() -> BackupService:
+    if _service is None:
+        raise HTTPException(status_code=503, detail="Backup service not initialized")
+    return _service
+
+
+def _get_token_payload(request: Request) -> Any:
+    payload = getattr(request.state, "user", None)
+    if payload is None:
+        raise HTTPException(status_code=401, detail="Not authenticated")
+    return payload
+
+
+class CreateBackupRequest(BaseModel):
+    mode: str = "full"  # "full", "config-only", "no-workspace"
+    label: str = ""
+
+
+@router.post("", dependencies=[require_scope("tools:execute")])
+async def create_backup(request: Request, body: CreateBackupRequest) -> dict[str, Any]:
+    """Create a new backup archive."""
+    token = _get_token_payload(request)
+    service = _get_service()
+
+    result = await service.create(
+        mode=body.mode,
+        label=body.label,
+        creator=token.sub or "",
+    )
+
+    if not result.success:
+        raise HTTPException(status_code=400, detail="; ".join(result.errors))
+
+    return result.model_dump(mode="json")
+
+
+@router.get("", dependencies=[require_scope("tools:execute")])
+async def list_backups(request: Request) -> list[dict[str, Any]]:
+    """List available backups."""
+    _get_token_payload(request)
+    service = _get_service()
+    backups = service.list_backups()
+    return [b.model_dump(mode="json") for b in backups]
+
+
+@router.get("/{backup_id}", dependencies=[require_scope("tools:execute")])
+async def get_backup(request: Request, backup_id: str) -> dict[str, Any]:
+    """Get backup detail with manifest."""
+    _get_token_payload(request)
+    service = _get_service()
+    manifest = service.get_backup(backup_id)
+    if manifest is None:
+        raise HTTPException(status_code=404, detail=f"Backup not found: {backup_id}")
+    return manifest.model_dump(mode="json")
+
+
+@router.post(
+    "/{backup_id}/verify",
+    dependencies=[require_scope("tools:execute")],
+)
+async def verify_backup(request: Request, backup_id: str) -> dict[str, Any]:
+    """Verify the integrity of a backup archive."""
+    _get_token_payload(request)
+    service = _get_service()
+
+    result = await service.verify(backup_id)
+    return result.model_dump(mode="json")
+
+
+class RestoreRequest(BaseModel):
+    dry_run: bool = True  # Default to preview-only
+
+
+@router.post(
+    "/{backup_id}/restore",
+    dependencies=[require_scope("tools:execute")],
+)
+async def restore_backup(request: Request, backup_id: str, body: RestoreRequest) -> dict[str, Any]:
+    """Generate a restore plan from a backup.
+
+    Currently only supports dry_run=True (restore planning).
+    Actual restore execution is a future phase.
+    """
+    _get_token_payload(request)
+    service = _get_service()
+
+    if not body.dry_run:
+        raise HTTPException(
+            status_code=501,
+            detail="Restore execution is not yet implemented. Use dry_run=True for planning.",
+        )
+
+    # Get the archive path
+    manifest = service.get_backup(backup_id)
+    if manifest is None:
+        raise HTTPException(status_code=404, detail=f"Backup not found: {backup_id}")
+
+    from pathlib import Path
+
+    from agent33.backup.restore_planner import RestorePlanner
+
+    # Find the archive for this backup
+    archive_path = service._find_archive(backup_id)
+    if archive_path is None:
+        raise HTTPException(status_code=404, detail=f"Archive not found: {backup_id}")
+
+    planner = RestorePlanner(target_root=Path(manifest.archive_root))
+    plan = planner.plan(archive_path)
+
+    return plan.model_dump(mode="json")
+
+
+@router.delete(
+    "/{backup_id}",
+    dependencies=[require_scope("tools:execute")],
+)
+async def delete_backup(request: Request, backup_id: str) -> dict[str, Any]:
+    """Delete a backup archive."""
+    _get_token_payload(request)
+    service = _get_service()
+
+    deleted = service.delete_backup(backup_id)
+    if not deleted:
+        raise HTTPException(status_code=404, detail=f"Backup not found: {backup_id}")
+    return {"deleted": True, "backup_id": backup_id}
diff --git a/engine/src/agent33/api/routes/mutations.py b/engine/src/agent33/api/routes/mutations.py
