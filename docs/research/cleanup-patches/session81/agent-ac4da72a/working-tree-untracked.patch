+"""Tests for Track Phase 5: process manager lifecycle and resource limits."""
+
+from __future__ import annotations
+
+import asyncio
+import sys
+from pathlib import Path  # noqa: TCH003
+
+import pytest
+
+from agent33.execution.process_manager import (
+    ProcessManager,
+    ProcessStatus,
+    ResourceLimits,
+)
+
+
+class TestProcessManager:
+    async def test_start_and_complete(self, tmp_path: Path) -> None:
+        pm = ProcessManager(log_dir=tmp_path / "logs")
+
+        # Use a cross-platform quick command
+        cmd = "echo hello"
+        if sys.platform == "win32":
+            cmd = "cmd /c echo hello"
+
+        process = await pm.start(cmd)
+        assert process.status == ProcessStatus.RUNNING
+        assert process.process_id != ""
+        assert process.command == cmd
+
+        # Wait for completion
+        for _ in range(50):
+            await asyncio.sleep(0.1)
+            status = pm.get_status(process.process_id)
+            if status is not None and status.status != ProcessStatus.RUNNING:
+                break
+
+        final = pm.get_status(process.process_id)
+        assert final is not None
+        assert final.status == ProcessStatus.COMPLETED
+        assert final.exit_code == 0
+
+    async def test_start_with_metadata(self, tmp_path: Path) -> None:
+        pm = ProcessManager(log_dir=tmp_path / "logs")
+
+        cmd = "echo test"
+        if sys.platform == "win32":
+            cmd = "cmd /c echo test"
+
+        process = await pm.start(
+            cmd,
+            agent_id="agent-1",
+            session_id="session-1",
+            tenant_id="tenant-1",
+        )
+        assert process.agent_id == "agent-1"
+        assert process.session_id == "session-1"
+        assert process.tenant_id == "tenant-1"
+
+    async def test_kill_running_process(self, tmp_path: Path) -> None:
+        pm = ProcessManager(log_dir=tmp_path / "logs")
+
+        # Start a long-running command
+        if sys.platform == "win32":
+            cmd = "cmd /c ping -n 60 127.0.0.1"
+        else:
+            cmd = "sleep 60"
+
+        process = await pm.start(cmd)
+        assert process.status == ProcessStatus.RUNNING
+
+        # Small delay to ensure process is started
+        await asyncio.sleep(0.3)
+
+        killed = await pm.kill(process.process_id)
+        assert killed is True
+
+        status = pm.get_status(process.process_id)
+        assert status is not None
+        assert status.status == ProcessStatus.KILLED
+        assert status.finished_at is not None
+
+    async def test_kill_nonexistent_returns_false(self, tmp_path: Path) -> None:
+        pm = ProcessManager(log_dir=tmp_path / "logs")
+        killed = await pm.kill("nonexistent-id")
+        assert killed is False
+
+    async def test_max_processes_limit(self, tmp_path: Path) -> None:
+        pm = ProcessManager(log_dir=tmp_path / "logs", max_processes=2)
+
+        if sys.platform == "win32":
+            cmd = "cmd /c ping -n 30 127.0.0.1"
+        else:
+            cmd = "sleep 30"
+
+        await pm.start(cmd)
+        await pm.start(cmd)
+
