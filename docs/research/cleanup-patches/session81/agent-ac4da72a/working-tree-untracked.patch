+        cmd = "echo tenant"
+        if sys.platform == "win32":
+            cmd = "cmd /c echo tenant"
+
+        await pm.start(cmd, tenant_id="t1")
+        await pm.start(cmd, tenant_id="t2")
+
+        procs = pm.list_processes(tenant_id="t1")
+        assert len(procs) == 1
+
+    async def test_read_log_output(self, tmp_path: Path) -> None:
+        pm = ProcessManager(log_dir=tmp_path / "logs")
+
+        cmd = "echo log_output_test"
+        if sys.platform == "win32":
+            cmd = "cmd /c echo log_output_test"
+
+        process = await pm.start(cmd)
+
+        # Wait for completion
+        for _ in range(50):
+            await asyncio.sleep(0.1)
+            status = pm.get_status(process.process_id)
+            if status is not None and status.status != ProcessStatus.RUNNING:
+                break
+
+        log_text = await pm.read_log(process.process_id)
+        assert "log_output_test" in log_text
+
+    async def test_read_log_nonexistent(self, tmp_path: Path) -> None:
+        pm = ProcessManager(log_dir=tmp_path / "logs")
+        log_text = await pm.read_log("no-such-id")
+        assert log_text == ""
+
+    async def test_cleanup_completed(self, tmp_path: Path) -> None:
+        pm = ProcessManager(log_dir=tmp_path / "logs")
+
+        cmd = "echo done"
+        if sys.platform == "win32":
+            cmd = "cmd /c echo done"
+
+        process = await pm.start(cmd)
+
+        # Wait for completion
+        for _ in range(50):
+            await asyncio.sleep(0.1)
+            status = pm.get_status(process.process_id)
+            if status is not None and status.status != ProcessStatus.RUNNING:
+                break
+
+        # Cleanup with 0s max age (everything is old)
+        cleaned = pm.cleanup_completed(max_age_seconds=0)
+        assert cleaned == 1
+        assert pm.get_status(process.process_id) is None
+
+    async def test_cleanup_skips_running(self, tmp_path: Path) -> None:
+        pm = ProcessManager(log_dir=tmp_path / "logs")
+
+        if sys.platform == "win32":
+            cmd = "cmd /c ping -n 30 127.0.0.1"
+        else:
+            cmd = "sleep 30"
+
+        process = await pm.start(cmd)
+        await asyncio.sleep(0.2)
+
+        cleaned = pm.cleanup_completed(max_age_seconds=0)
+        assert cleaned == 0
+        assert pm.get_status(process.process_id) is not None
+
+        # cleanup
+        await pm.kill(process.process_id)
+
+    async def test_active_count(self, tmp_path: Path) -> None:
+        pm = ProcessManager(log_dir=tmp_path / "logs")
+        assert pm.active_count == 0
+
+        if sys.platform == "win32":
+            cmd = "cmd /c ping -n 30 127.0.0.1"
+        else:
+            cmd = "sleep 30"
+
+        await pm.start(cmd)
+        assert pm.active_count == 1
+
+        await pm.start(cmd)
+        assert pm.active_count == 2
+
+        # Kill all
+        for p in pm.list_processes():
+            await pm.kill(p.process_id)
+
+    async def test_resource_timeout_kills_process(self, tmp_path: Path) -> None:
+        """Process that exceeds CPU time limit is killed."""
+        pm = ProcessManager(log_dir=tmp_path / "logs")
+        limits = ResourceLimits(max_cpu_seconds=1.0)
+
+        if sys.platform == "win32":
+            cmd = "cmd /c ping -n 30 127.0.0.1"
+        else:
+            cmd = "sleep 30"
+
+        process = await pm.start(cmd, limits=limits)
+
+        # Wait for the timeout to trigger
+        for _ in range(30):
+            await asyncio.sleep(0.5)
+            status = pm.get_status(process.process_id)
+            if status is not None and status.status != ProcessStatus.RUNNING:
+                break
+
+        final = pm.get_status(process.process_id)
+        assert final is not None
+        assert final.status == ProcessStatus.KILLED
+
+    async def test_failed_command(self, tmp_path: Path) -> None:
+        pm = ProcessManager(log_dir=tmp_path / "logs")
+
+        if sys.platform == "win32":
+            cmd = "cmd /c exit 1"
+        else:
+            cmd = "false"
+
+        process = await pm.start(cmd)
+
+        for _ in range(50):
+            await asyncio.sleep(0.1)
+            status = pm.get_status(process.process_id)
+            if status is not None and status.status != ProcessStatus.RUNNING:
+                break
+
+        final = pm.get_status(process.process_id)
+        assert final is not None
+        assert final.status == ProcessStatus.FAILED
+        assert final.exit_code != 0
+
+    async def test_list_by_status_filter(self, tmp_path: Path) -> None:
+        pm = ProcessManager(log_dir=tmp_path / "logs")
+
+        cmd = "echo status_test"
+        if sys.platform == "win32":
+            cmd = "cmd /c echo status_test"
+
+        process = await pm.start(cmd)
+
+        # Wait for completion
+        for _ in range(50):
+            await asyncio.sleep(0.1)
+            status = pm.get_status(process.process_id)
+            if status is not None and status.status != ProcessStatus.RUNNING:
+                break
+
+        completed = pm.list_processes(status_filter=ProcessStatus.COMPLETED)
+        running = pm.list_processes(status_filter=ProcessStatus.RUNNING)
+        assert len(completed) == 1
+        assert len(running) == 0
