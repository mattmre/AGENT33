+"""API route integration tests for Track Phase 5: mutations and processes."""
+
+from __future__ import annotations
+
+from pathlib import Path  # noqa: TCH003
+from typing import Any
+from unittest.mock import MagicMock
+
+from fastapi import FastAPI
+from fastapi.testclient import TestClient
+from starlette.requests import Request  # noqa: TCH002
+
+from agent33.api.routes import mutations
+from agent33.execution.process_manager import ProcessManager
+from agent33.tools.builtin.apply_patch import ApplyPatchTool
+from agent33.tools.builtin.patch_audit import PatchAuditLog
+
+
+def _make_app(tmp_path: Path) -> tuple[FastAPI, ApplyPatchTool, ProcessManager]:
+    """Create a test app with mutation routes wired up."""
+    app = FastAPI()
+
+    audit_log = PatchAuditLog(tmp_path / "audit")
+    patch_tool = ApplyPatchTool(
+        workspace_root=tmp_path / "workspace",
+        audit_log=audit_log,
+        backup_dir=tmp_path / "backups",
+    )
+    (tmp_path / "workspace").mkdir(parents=True)
+
+    process_manager = ProcessManager(log_dir=tmp_path / "proc_logs")
+
+    mutations.set_patch_tool(patch_tool)
+    mutations.set_audit_log(audit_log)
+    mutations.set_process_manager(process_manager)
+
+    # Inject mock auth middleware
+    @app.middleware("http")
+    async def mock_auth(request: Request, call_next: Any) -> Any:
+        user = MagicMock()
+        user.scopes = ["tools:execute", "admin"]
+        user.sub = "test-user"
+        user.tenant_id = "test-tenant"
+        request.state.user = user
+        return await call_next(request)
+
+    app.include_router(mutations.router)
+    return app, patch_tool, process_manager
+
+
+class TestPatchRoutes:
+    def test_apply_patch_create(self, tmp_path: Path) -> None:
+        app, tool, _ = _make_app(tmp_path)
+        client = TestClient(app)
+
+        resp = client.post(
+            "/v1/mutations/patch",
+            json={
+                "patches": [
+                    {
+                        "path": "new_file.txt",
+                        "operation": "create",
+                        "content": "hello from API",
+                    }
+                ],
+            },
+        )
+
+        assert resp.status_code == 200
+        data = resp.json()
+        assert data["success"] is True
+        assert "new_file.txt" in data["files_created"]
+        assert (tmp_path / "workspace" / "new_file.txt").read_text() == "hello from API"
+
+    def test_apply_patch_dry_run(self, tmp_path: Path) -> None:
+        app, _, _ = _make_app(tmp_path)
+        client = TestClient(app)
+
+        resp = client.post(
+            "/v1/mutations/patch",
+            json={
+                "patches": [
+                    {
+                        "path": "dry.txt",
+                        "operation": "create",
+                        "content": "dry content",
+                    }
+                ],
+                "dry_run": True,
+            },
+        )
+
+        assert resp.status_code == 200
+        data = resp.json()
+        assert data["dry_run"] is True
+        assert not (tmp_path / "workspace" / "dry.txt").exists()
+
+    def test_apply_patch_rejects_sensitive_path(self, tmp_path: Path) -> None:
+        app, _, _ = _make_app(tmp_path)
+        client = TestClient(app)
+
+        resp = client.post(
+            "/v1/mutations/patch",
+            json={
+                "patches": [
+                    {
+                        "path": ".env",
+                        "operation": "create",
+                        "content": "SECRET=x",
+                    }
+                ],
+            },
+        )
+
+        assert resp.status_code == 400
+        assert "sensitive" in resp.json()["detail"].lower()
+
+    def test_preview_patch(self, tmp_path: Path) -> None:
+        app, _, _ = _make_app(tmp_path)
+        client = TestClient(app)
+
+        # Create a file to preview modification
+        ws = tmp_path / "workspace"
+        (ws / "preview.txt").write_text("original text")
+
+        resp = client.post(
+            "/v1/mutations/patch/preview",
+            json={
+                "patches": [
+                    {
+                        "path": "preview.txt",
+                        "operation": "modify",
+                        "search": "original",
+                        "replace": "modified",
+                    }
+                ],
+            },
+        )
+
+        assert resp.status_code == 200
+        data = resp.json()
+        assert data["dry_run"] is True
+        assert len(data["previews"]) == 1
+        assert "modified" in data["previews"][0]["diff"]
+
+    def test_rollback_patch(self, tmp_path: Path) -> None:
+        app, tool, _ = _make_app(tmp_path)
+        client = TestClient(app)
+
+        ws = tmp_path / "workspace"
+        (ws / "rollback.txt").write_text("before")
+
+        # Apply a patch
+        resp = client.post(
+            "/v1/mutations/patch",
+            json={
+                "patches": [
+                    {
+                        "path": "rollback.txt",
+                        "operation": "modify",
+                        "content": "after",
+                    }
+                ],
+            },
+        )
+
+        assert resp.status_code == 200
+        patch_id = resp.json()["patch_id"]
+        assert (ws / "rollback.txt").read_text() == "after"
+
+        # Rollback
+        resp = client.post(f"/v1/mutations/patch/{patch_id}/rollback")
+        assert resp.status_code == 200
+        assert resp.json()["success"] is True
+        assert (ws / "rollback.txt").read_text() == "before"
+
+
+class TestProcessRoutes:
+    def test_list_processes_empty(self, tmp_path: Path) -> None:
+        app, _, _ = _make_app(tmp_path)
+        client = TestClient(app)
+
+        resp = client.get("/v1/processes/")
+        assert resp.status_code == 200
+        assert resp.json() == []
+
+    def test_get_process_not_found(self, tmp_path: Path) -> None:
+        app, _, _ = _make_app(tmp_path)
+        client = TestClient(app)
+
+        resp = client.get("/v1/processes/nonexistent")
+        assert resp.status_code == 404
+
+    def test_kill_process_not_found(self, tmp_path: Path) -> None:
+        app, _, _ = _make_app(tmp_path)
+        client = TestClient(app)
+
+        resp = client.post("/v1/processes/nonexistent/kill")
+        assert resp.status_code == 400
+
+    def test_pause_not_implemented(self, tmp_path: Path) -> None:
+        app, _, _ = _make_app(tmp_path)
+        client = TestClient(app)
+
+        resp = client.post("/v1/processes/some-id/pause")
+        assert resp.status_code in (404, 501)
+
+    def test_invalid_status_filter(self, tmp_path: Path) -> None:
+        app, _, _ = _make_app(tmp_path)
+        client = TestClient(app)
+
+        resp = client.get("/v1/processes/?status=invalid")
+        assert resp.status_code == 400
+        assert "Invalid status" in resp.json()["detail"]
