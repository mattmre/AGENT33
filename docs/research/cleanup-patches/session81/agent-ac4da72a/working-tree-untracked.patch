@@ -0,0 +1,310 @@
+"""Backup service: create, verify, list, and manage platform-level backups."""
+
+from __future__ import annotations
+
+import logging
+import sys
+import uuid
+from datetime import UTC, datetime
+from pathlib import Path  # noqa: TCH003
+
+from agent33.backup.archive import (
+    compute_sha256,
+    create_archive,
+    extract_manifest,
+    generate_archive_name,
+    verify_archive_integrity,
+)
+from agent33.backup.models import (
+    AssetType,
+    BackupAsset,
+    BackupManifest,
+    BackupMode,
+    BackupProvenance,
+    BackupResult,
+    BackupSummary,
+    VerifyCheck,
+    VerifyResult,
+)
+
+logger = logging.getLogger(__name__)
+
+
+class BackupService:
+    """Creates, verifies, and manages platform-level backups."""
+
+    def __init__(
+        self,
+        backup_dir: Path,
+        config_dir: Path,
+        data_dir: Path,
+        workspace_dir: Path | None = None,
+    ) -> None:
+        self._backup_dir = backup_dir
+        self._backup_dir.mkdir(parents=True, exist_ok=True)
+        self._config_dir = config_dir
+        self._data_dir = data_dir
+        self._workspace_dir = workspace_dir
+
+    async def create(
+        self,
+        *,
+        mode: str = "full",
+        label: str = "",
+        creator: str = "",
+    ) -> BackupResult:
+        """Create a backup archive.
+
+        Steps:
+        1. Gather asset inventory based on mode.
+        2. Compute checksums for all assets.
+        3. Build manifest.
+        4. Create archive atomically (write to .tmp, rename).
+        5. Verify the created archive.
+        """
+        try:
+            backup_mode = BackupMode(mode)
+        except ValueError:
+            return BackupResult(
+                success=False,
+                backup_id="",
+                errors=[f"Invalid backup mode: {mode}"],
+            )
+
+        backup_id = str(uuid.uuid4())
+        short_id = backup_id[:8]
+        now = datetime.now(UTC)
+
+        # Gather source directories based on mode
+        source_dirs: dict[str, Path] = {}
+        assets: list[BackupAsset] = []
+        checksums: dict[str, str] = {}
+        warnings: list[str] = []
+
+        # Config is always included
+        if self._config_dir.exists():
+            source_dirs["config"] = self._config_dir
+            config_assets = self._scan_directory(self._config_dir, "config", AssetType.CONFIG)
+            assets.extend(config_assets)
+            for a in config_assets:
+                full_path = self._config_dir / a.relative_path.removeprefix("config/")
+                if full_path.is_file():
+                    checksums[a.relative_path] = compute_sha256(full_path)
+                    a.checksum = checksums[a.relative_path]
+        else:
+            warnings.append(f"Config directory not found: {self._config_dir}")
+
+        # Data directories (agent defs, skills, packs, plugins, workflows)
+        if backup_mode != BackupMode.CONFIG_ONLY and self._data_dir.exists():
+            data_subdirs = {
+                "agent_definitions": AssetType.AGENT_DEFINITIONS,
+                "skills": AssetType.SKILLS,
+                "packs": AssetType.PACKS,
+                "plugins": AssetType.PLUGINS,
+            }
+            for subdir_name, asset_type in data_subdirs.items():
+                subdir = self._data_dir / subdir_name
+                if subdir.exists():
+                    source_dirs[subdir_name] = subdir
+                    sub_assets = self._scan_directory(subdir, subdir_name, asset_type)
+                    assets.extend(sub_assets)
+                    for a in sub_assets:
+                        full_path = subdir / a.relative_path.removeprefix(f"{subdir_name}/")
+                        if full_path.is_file():
+                            checksums[a.relative_path] = compute_sha256(full_path)
+                            a.checksum = checksums[a.relative_path]
+
+        # Workspace (only in full mode)
+        if (
+            backup_mode == BackupMode.FULL
+            and self._workspace_dir is not None
+            and self._workspace_dir.exists()
+        ):
+            source_dirs["workspace"] = self._workspace_dir
+            ws_assets = self._scan_directory(self._workspace_dir, "workspace", AssetType.WORKSPACE)
+            assets.extend(ws_assets)
+            # Skip checksums for workspace (can be large)
+
+        # Build manifest
+        manifest = BackupManifest(
+            backup_id=backup_id,
+            created_at=now,
+            platform=sys.platform,
+            archive_root=str(self._data_dir),
+            backup_mode=backup_mode,
+            assets=assets,
+            checksums=checksums,
+            label=label,
+        )
+
+        # Generate archive name and path
+        archive_name = generate_archive_name(mode, short_id, now)
+        archive_path = self._backup_dir / archive_name
+
+        # Safety: backup output must not be inside source roots
+        archive_resolved = archive_path.resolve()
+        for src_dir in source_dirs.values():
+            src_resolved = src_dir.resolve()
+            try:
+                archive_resolved.relative_to(src_resolved)
+                return BackupResult(
+                    success=False,
+                    backup_id=backup_id,
+                    errors=[f"Backup output {archive_path} is inside source root {src_dir}"],
+                )
+            except ValueError:
+                pass  # Good: output is outside source
+
+        # Create archive
+        errors: list[str] = []
+        try:
+            create_archive(source_dirs, manifest, archive_path)
+        except Exception as exc:
+            errors.append(f"Archive creation failed: {exc}")
+            return BackupResult(
+                success=False,
+                backup_id=backup_id,
+                errors=errors,
+            )
+
+        # Compute archive size
+        size_bytes = archive_path.stat().st_size if archive_path.exists() else 0
+
+        provenance = BackupProvenance(
+            creator=creator,
+            source_roots=[str(d) for d in source_dirs.values()],
+            platform=sys.platform,
+            created_at=now,
+        )
+
+        return BackupResult(
+            success=True,
+            backup_id=backup_id,
+            archive_path=str(archive_path),
+            manifest=manifest,
+            size_bytes=size_bytes,
+            asset_count=len([a for a in assets if a.included]),
+            warnings=warnings,
+            provenance=provenance,
+        )
+
+    async def verify(self, backup_id: str) -> VerifyResult:
+        """Verify a backup archive by its ID."""
+        archive_path = self._find_archive(backup_id)
+        if archive_path is None:
+            return VerifyResult(
+                valid=False,
+                checks=[
+                    VerifyCheck(
+                        name="archive_exists",
+                        passed=False,
+                        message=f"No archive found for backup {backup_id}",
+                    )
+                ],
+            )
+
+        raw_checks = verify_archive_integrity(archive_path)
+        checks = [
+            VerifyCheck(name=name, passed=passed, message=msg) for name, passed, msg in raw_checks
+        ]
+        valid = all(c.passed for c in checks)
+
+        return VerifyResult(valid=valid, checks=checks)
+
+    def list_backups(self) -> list[BackupSummary]:
+        """List all available backups, sorted newest first."""
+        summaries: list[BackupSummary] = []
+        if not self._backup_dir.exists():
+            return summaries
+
+        for path in sorted(self._backup_dir.glob("agent33-backup-*.tar.gz"), reverse=True):
+            manifest = extract_manifest(path)
+            if manifest is None:
+                continue
+            summaries.append(
+                BackupSummary(
+                    backup_id=manifest.backup_id,
+                    created_at=manifest.created_at,
+                    label=manifest.label,
+                    mode=manifest.backup_mode,
+                    size_bytes=path.stat().st_size,
+                    asset_count=len([a for a in manifest.assets if a.included]),
+                    archive_path=str(path),
+                )
+            )
+
+        return summaries
+
+    def get_backup(self, backup_id: str) -> BackupManifest | None:
+        """Get manifest for a specific backup."""
+        archive_path = self._find_archive(backup_id)
+        if archive_path is None:
+            return None
+        return extract_manifest(archive_path)
+
+    def delete_backup(self, backup_id: str) -> bool:
+        """Delete a backup archive. Returns True if deleted."""
+        archive_path = self._find_archive(backup_id)
+        if archive_path is None:
+            return False
+        try:
+            archive_path.unlink()
+            return True
+        except OSError:
+            logger.warning("Failed to delete backup: %s", archive_path, exc_info=True)
+            return False
+
+    def _find_archive(self, backup_id: str) -> Path | None:
+        """Find an archive file by backup_id (searches manifest of each archive)."""
+        if not self._backup_dir.exists():
+            return None
+
+        # First try short-id match in filename
+        short_id = backup_id[:8]
+        for path in self._backup_dir.glob(f"agent33-backup-*-{short_id}.tar.gz"):
+            manifest = extract_manifest(path)
+            if manifest is not None and manifest.backup_id == backup_id:
+                return path
+
+        # Fallback: scan all archives
+        for path in self._backup_dir.glob("agent33-backup-*.tar.gz"):
+            manifest = extract_manifest(path)
+            if manifest is not None and manifest.backup_id == backup_id:
+                return path
+
+        return None
+
+    @staticmethod
+    def _scan_directory(
+        directory: Path,
+        prefix: str,
+        asset_type: AssetType,
+    ) -> list[BackupAsset]:
+        """Scan a directory and build an asset inventory."""
+        assets: list[BackupAsset] = []
+        if not directory.exists():
+            return assets
+
+        for path in directory.rglob("*"):
+            if not path.is_file():
+                continue
+            # Skip common excludes
+            parts = path.relative_to(directory).parts
+            if any(p.startswith(".") or p == "__pycache__" for p in parts):
+                continue
+
+            rel = f"{prefix}/{path.relative_to(directory).as_posix()}"
+            try:
+                size = path.stat().st_size
+            except OSError:
+                size = 0
+
+            assets.append(
+                BackupAsset(
+                    relative_path=rel,
+                    asset_type=asset_type,
+                    size_bytes=size,
+                )
+            )
+
+        return assets
diff --git a/engine/src/agent33/execution/process_manager.py b/engine/src/agent33/execution/process_manager.py
