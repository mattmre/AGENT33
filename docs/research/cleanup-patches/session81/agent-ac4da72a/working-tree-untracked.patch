+++ b/engine/src/agent33/execution/process_manager.py
@@ -0,0 +1,278 @@
+"""Process manager for tracking and controlling long-running agent processes."""
+
+from __future__ import annotations
+
+import asyncio
+import logging
+import os
+import uuid
+from datetime import UTC, datetime
+from enum import StrEnum
+from pathlib import Path  # noqa: TCH003
+from typing import Any
+
+from pydantic import BaseModel, Field
+
+logger = logging.getLogger(__name__)
+
+
+class ProcessStatus(StrEnum):
+    """Lifecycle state of a managed process."""
+
+    RUNNING = "running"
+    COMPLETED = "completed"
+    FAILED = "failed"
+    KILLED = "killed"
+    PAUSED = "paused"
+
+
+class ManagedProcess(BaseModel):
+    """A background command session managed by the process manager."""
+
+    process_id: str
+    command: str
+    status: ProcessStatus = ProcessStatus.RUNNING
+    started_at: datetime = Field(default_factory=lambda: datetime.now(UTC))
+    finished_at: datetime | None = None
+    exit_code: int | None = None
+    agent_id: str = ""
+    session_id: str = ""
+    tenant_id: str = ""
+    pid: int | None = None
+
+
+class ResourceLimits(BaseModel):
+    """Resource limits for a managed process."""
+
+    max_cpu_seconds: float = 300.0  # 5 min default
+    max_memory_mb: int = 512
+    max_output_bytes: int = 10 * 1024 * 1024  # 10 MB
+
+
+class ProcessManager:
+    """Manages background command sessions with log tailing and cleanup.
+
+    Stores process output in a log directory and tracks process metadata
+    in-memory. Uses asyncio.create_subprocess_shell for non-blocking execution.
+    """
+
+    def __init__(
+        self,
+        log_dir: Path,
+        max_processes: int = 10,
+        default_limits: ResourceLimits | None = None,
+    ) -> None:
+        self._log_dir = log_dir
+        self._log_dir.mkdir(parents=True, exist_ok=True)
+        self._max_processes = max_processes
+        self._default_limits = default_limits or ResourceLimits()
+        self._processes: dict[str, ManagedProcess] = {}
+        self._handles: dict[str, asyncio.subprocess.Process] = {}
+
+    @property
+    def active_count(self) -> int:
+        """Number of currently running processes."""
+        return sum(1 for p in self._processes.values() if p.status == ProcessStatus.RUNNING)
+
+    async def start(
+        self,
+        command: str,
+        *,
+        agent_id: str = "",
+        session_id: str = "",
+        tenant_id: str = "",
+        limits: ResourceLimits | None = None,
+    ) -> ManagedProcess:
+        """Start a new background process.
+
+        Raises ValueError if the max process limit is reached.
+        """
+        if self.active_count >= self._max_processes:
+            raise ValueError(f"Maximum concurrent processes ({self._max_processes}) reached")
+
+        if not command.strip():
+            raise ValueError("Empty command")
+
+        process_id = str(uuid.uuid4())
+        log_path = self._log_dir / f"{process_id}.log"
+
+        managed = ManagedProcess(
+            process_id=process_id,
+            command=command,
+            agent_id=agent_id,
+            session_id=session_id,
+            tenant_id=tenant_id,
+        )
+        self._processes[process_id] = managed
+
+        # Open log file for stdout/stderr capture
+        log_file = log_path.open("w", encoding="utf-8")
+
+        # Merge env to preserve PATH (Windows platform note from CLAUDE.md)
+        env = {**os.environ}
+
+        try:
+            proc = await asyncio.create_subprocess_shell(
+                command,
+                stdout=log_file,
+                stderr=asyncio.subprocess.STDOUT,
+                env=env,
+            )
+            managed.pid = proc.pid
+            self._handles[process_id] = proc
+
+            # Launch background monitor
+            effective_limits = limits or self._default_limits
+            asyncio.create_task(self._monitor(process_id, proc, log_file, effective_limits))
+
+        except Exception as exc:
+            log_file.close()
+            managed.status = ProcessStatus.FAILED
+            managed.finished_at = datetime.now(UTC)
+            logger.error("Process start failed: %s", exc, exc_info=True)
+
+        return managed
+
+    async def kill(self, process_id: str) -> bool:
+        """Terminate a running process.
+
+        Returns True if the process was killed, False if not found or already finished.
+        """
+        managed = self._processes.get(process_id)
+        if managed is None:
+            return False
+
+        if managed.status != ProcessStatus.RUNNING:
+            return False
+
+        proc = self._handles.get(process_id)
+        if proc is None:
+            return False
+
+        try:
+            proc.terminate()
+            # Give it a moment to terminate gracefully
+            try:
+                await asyncio.wait_for(proc.wait(), timeout=5.0)
+            except TimeoutError:
+                proc.kill()
+
+            managed.status = ProcessStatus.KILLED
+            managed.finished_at = datetime.now(UTC)
+            managed.exit_code = proc.returncode
+            return True
+        except ProcessLookupError:
+            managed.status = ProcessStatus.KILLED
+            managed.finished_at = datetime.now(UTC)
+            return True
+
+    def get_status(self, process_id: str) -> ManagedProcess | None:
+        """Get the current status of a process."""
+        return self._processes.get(process_id)
+
+    def list_processes(
+        self,
+        *,
+        session_id: str = "",
+        tenant_id: str = "",
+        status_filter: ProcessStatus | None = None,
+    ) -> list[ManagedProcess]:
+        """List processes with optional filtering."""
+        results: list[ManagedProcess] = []
+        for p in self._processes.values():
+            if session_id and p.session_id != session_id:
+                continue
+            if tenant_id and p.tenant_id != tenant_id:
+                continue
+            if status_filter is not None and p.status != status_filter:
+                continue
+            results.append(p)
+        # Sort by started_at descending
+        results.sort(key=lambda p: p.started_at, reverse=True)
+        return results
+
+    async def read_log(self, process_id: str, *, tail: int = 100) -> str:
+        """Read the output log for a process.
+
+        Returns the last ``tail`` lines of the log.
+        """
+        log_path = self._log_dir / f"{process_id}.log"
+        if not log_path.exists():
+            return ""
+
+        try:
+            text = log_path.read_text(encoding="utf-8", errors="replace")
+            lines = text.splitlines()
+            if tail > 0 and len(lines) > tail:
+                lines = lines[-tail:]
+            return "\n".join(lines)
+        except OSError:
+            return ""
+
+    def cleanup_completed(self, *, max_age_seconds: int = 3600) -> int:
+        """Remove completed/failed/killed processes older than max_age.
+
+        Returns the number of processes cleaned up.
+        """
+        now = datetime.now(UTC)
+        to_remove: list[str] = []
+
+        for pid, managed in self._processes.items():
+            if managed.status == ProcessStatus.RUNNING:
+                continue
+            if managed.finished_at is not None:
+                age = (now - managed.finished_at).total_seconds()
+                if age > max_age_seconds:
+                    to_remove.append(pid)
+
+        for pid in to_remove:
+            self._processes.pop(pid, None)
+            self._handles.pop(pid, None)
+            # Clean up log file
+            log_path = self._log_dir / f"{pid}.log"
+            try:
+                if log_path.exists():
+                    log_path.unlink()
+            except OSError:
+                pass
+
+        return len(to_remove)
+
+    async def _monitor(
+        self,
+        process_id: str,
+        proc: asyncio.subprocess.Process,
+        log_file: Any,
+        limits: ResourceLimits,
+    ) -> None:
+        """Background task that monitors a process until completion."""
+        managed = self._processes.get(process_id)
+        if managed is None:
+            return
+
+        try:
+            # Wait with a timeout based on CPU seconds limit
+            returncode = await asyncio.wait_for(proc.wait(), timeout=limits.max_cpu_seconds)
+            managed.exit_code = returncode
+            managed.status = ProcessStatus.COMPLETED if returncode == 0 else ProcessStatus.FAILED
+        except TimeoutError:
+            # Exceeded time limit
+            import contextlib
+
+            try:
+                proc.terminate()
+                await asyncio.wait_for(proc.wait(), timeout=5.0)
+            except (TimeoutError, ProcessLookupError):
+                with contextlib.suppress(ProcessLookupError):
+                    proc.kill()
+            managed.status = ProcessStatus.KILLED
+            managed.exit_code = -1
+        except Exception:
+            managed.status = ProcessStatus.FAILED
+            logger.warning("Process monitor error: %s", process_id, exc_info=True)
+        finally:
+            managed.finished_at = datetime.now(UTC)
+            import contextlib as _ctxlib
+
+            with _ctxlib.suppress(Exception):
+                log_file.close()
diff --git a/engine/src/agent33/tools/builtin/apply_patch.py b/engine/src/agent33/tools/builtin/apply_patch.py
new file mode 100644
index 0000000..f0b295a
--- /dev/null
+++ b/engine/src/agent33/tools/builtin/apply_patch.py
@@ -0,0 +1,446 @@
+"""Safe, governed file mutation via structured patches.
+
+Provides an ``apply_patch`` tool that agents can use to modify files with
+workspace containment, dry-run preview, rollback support, and audit logging.
+"""
+
+from __future__ import annotations
+
+import difflib
+import logging
+import shutil
+import uuid
+from pathlib import Path
+from typing import Any
+
+from pydantic import BaseModel, Field
+
+from agent33.tools.base import ToolContext, ToolResult
+from agent33.tools.builtin.patch_audit import PatchAuditEntry, PatchAuditLog
+from agent33.tools.builtin.patch_security import PatchSecurityValidator
+
+logger = logging.getLogger(__name__)
+
+
+class PatchPreview(BaseModel):
+    """Preview of what a single patch operation would do."""
+
+    path: str
+    operation: str
+    diff: str = ""
+    lines_added: int = 0
+    lines_removed: int = 0
+    would_create: bool = False
+    would_delete: bool = False
+    validation_errors: list[str] = Field(default_factory=list)
+
+
+class PatchResult(BaseModel):
+    """Result of a patch batch application."""
+
+    patch_id: str
+    success: bool
+    dry_run: bool = False
+    previews: list[PatchPreview] = Field(default_factory=list)
+    files_modified: list[str] = Field(default_factory=list)
+    files_created: list[str] = Field(default_factory=list)
+    files_deleted: list[str] = Field(default_factory=list)
+    errors: list[str] = Field(default_factory=list)
+    rollback_available: bool = False
+
+
+class ApplyPatchTool:
+    """Safe, governed file mutation via structured patches.
+
+    Supports create, modify (via search/replace blocks), and delete operations.
+    All operations are contained within a workspace root and subject to
+    governance checks.
+    """
+
+    _name = "apply_patch"
+    _description = "Apply structured file patches with workspace containment and audit logging"
+
+    def __init__(
+        self,
+        workspace_root: Path | None = None,
+        audit_log: PatchAuditLog | None = None,
+        backup_dir: Path | None = None,
+    ) -> None:
+        self._workspace_root = workspace_root or Path.cwd()
+        self._security = PatchSecurityValidator(self._workspace_root)
+        self._audit_log = audit_log
+        self._backup_dir = backup_dir
+        if self._backup_dir is not None:
+            self._backup_dir.mkdir(parents=True, exist_ok=True)
+
+    @property
+    def name(self) -> str:
+        return self._name
+
+    @property
+    def description(self) -> str:
+        return self._description
+
+    @property
+    def parameters_schema(self) -> dict[str, Any]:
+        return {
+            "type": "object",
+            "properties": {
+                "patches": {
+                    "type": "array",
+                    "items": {
+                        "type": "object",
+                        "properties": {
+                            "path": {
+                                "type": "string",
+                                "description": "File path relative to workspace",
+                            },
+                            "operation": {
+                                "type": "string",
+                                "enum": ["create", "modify", "delete"],
+                            },
+                            "content": {
+                                "type": "string",
+                                "description": (
+                                    "New content (create) or search/replace block (modify)"
+                                ),
+                            },
+                            "search": {
+                                "type": "string",
+                                "description": "Text to search for (modify)",
+                            },
+                            "replace": {
+                                "type": "string",
+                                "description": "Text to replace with (modify)",
+                            },
+                        },
+                        "required": ["path", "operation"],
+                    },
+                },
+                "dry_run": {"type": "boolean", "default": False},
+                "workspace_root": {
+                    "type": "string",
+                    "description": "Override workspace containment root",
+                },
+            },
+            "required": ["patches"],
+        }
+
+    async def execute(self, params: dict[str, Any], context: ToolContext) -> ToolResult:
+        """Execute the patch tool."""
+        patches: list[dict[str, Any]] = params.get("patches", [])
+        dry_run: bool = params.get("dry_run", False)
+
+        if not patches:
+            return ToolResult.fail("No patches provided")
+
+        # Allow workspace root override from params
+        workspace_override = params.get("workspace_root", "")
+        if workspace_override:
+            security = PatchSecurityValidator(Path(workspace_override))
+        else:
+            security = self._security
+
+        # Validate all paths first
+        validation_errors = security.validate_batch(patches)
+        if validation_errors:
+            error_msg = "; ".join(f"{path}: {err}" for path, err in validation_errors)
+            return ToolResult.fail(f"Path validation failed: {error_msg}")
+
+        patch_id = str(uuid.uuid4())
+        result = await self._apply_batch(
+            patches=patches,
+            dry_run=dry_run,
+            patch_id=patch_id,
+            security=security,
+        )
+
+        # Record audit
+        if self._audit_log is not None:
+            audit_entry = PatchAuditEntry(
+                patch_id=patch_id,
+                agent_id=context.requested_by,
+                tenant_id=context.tenant_id,
+                workspace_root=str(security.workspace_root),
+                patches=patches,
+                dry_run=dry_run,
+                result="dry_run" if dry_run else ("success" if result.success else "failed"),
+                errors=result.errors,
+                files_modified=result.files_modified,
+                files_created=result.files_created,
+                files_deleted=result.files_deleted,
+            )
+            self._audit_log.record(audit_entry)
+
+        if result.success:
+            return ToolResult.ok(result.model_dump_json())
+        return ToolResult.fail(result.model_dump_json())
+
+    async def _apply_batch(
+        self,
+        patches: list[dict[str, Any]],
+        dry_run: bool,
+        patch_id: str,
+        security: PatchSecurityValidator,
+    ) -> PatchResult:
+        """Apply a batch of patches."""
+        previews: list[PatchPreview] = []
+        files_modified: list[str] = []
+        files_created: list[str] = []
+        files_deleted: list[str] = []
+        errors: list[str] = []
+        backups: dict[str, Path] = {}
+
+        for patch in patches:
+            path_str = patch.get("path", "")
+            operation = patch.get("operation", "")
+            target = (security.workspace_root / path_str).resolve()
+
+            if operation == "create":
+                preview = self._preview_create(path_str, patch, target)
+                previews.append(preview)
+                if preview.validation_errors:
+                    errors.extend(preview.validation_errors)
+                    continue
+                if not dry_run:
+                    try:
+                        self._backup_file(target, patch_id, backups)
+                        target.parent.mkdir(parents=True, exist_ok=True)
+                        target.write_text(patch.get("content", ""), encoding="utf-8")
+                        files_created.append(path_str)
+                    except OSError as exc:
+                        errors.append(f"Create failed for {path_str}: {exc}")
+
+            elif operation == "modify":
+                preview = self._preview_modify(path_str, patch, target)
+                previews.append(preview)
+                if preview.validation_errors:
+                    errors.extend(preview.validation_errors)
+                    continue
+                if not dry_run:
+                    try:
+                        self._backup_file(target, patch_id, backups)
+                        self._apply_modify(patch, target)
+                        files_modified.append(path_str)
+                    except OSError as exc:
+                        errors.append(f"Modify failed for {path_str}: {exc}")
+
+            elif operation == "delete":
+                preview = self._preview_delete(path_str, target)
+                previews.append(preview)
+                if preview.validation_errors:
+                    errors.extend(preview.validation_errors)
+                    continue
+                if not dry_run:
+                    try:
+                        self._backup_file(target, patch_id, backups)
+                        target.unlink()
+                        files_deleted.append(path_str)
+                    except OSError as exc:
+                        errors.append(f"Delete failed for {path_str}: {exc}")
+            else:
+                errors.append(f"Unknown operation '{operation}' for {path_str}")
+
+        return PatchResult(
+            patch_id=patch_id,
+            success=len(errors) == 0,
+            dry_run=dry_run,
+            previews=previews,
+            files_modified=files_modified,
+            files_created=files_created,
+            files_deleted=files_deleted,
+            errors=errors,
+            rollback_available=bool(backups) and not dry_run,
+        )
+
+    def _preview_create(self, path_str: str, patch: dict[str, Any], target: Path) -> PatchPreview:
+        content = patch.get("content", "")
+        validation_errors: list[str] = []
+        if target.exists():
+            validation_errors.append(f"File already exists: {path_str} (use 'modify' instead)")
+        lines_added = content.count("\n") + (1 if content and not content.endswith("\n") else 0)
+        return PatchPreview(
+            path=path_str,
+            operation="create",
+            diff=f"+++ {path_str}\n" + "\n".join(f"+{line}" for line in content.splitlines()),
+            lines_added=lines_added,
+            would_create=True,
+            validation_errors=validation_errors,
+        )
+
+    def _preview_modify(self, path_str: str, patch: dict[str, Any], target: Path) -> PatchPreview:
+        validation_errors: list[str] = []
+        if not target.exists():
+            validation_errors.append(f"File does not exist: {path_str}")
+            return PatchPreview(
+                path=path_str,
+                operation="modify",
+                validation_errors=validation_errors,
+            )
+
+        try:
+            original = target.read_text(encoding="utf-8")
+        except OSError as exc:
+            validation_errors.append(f"Cannot read {path_str}: {exc}")
+            return PatchPreview(
+                path=path_str,
+                operation="modify",
+                validation_errors=validation_errors,
+            )
+
+        search = patch.get("search", "")
+        replace = patch.get("replace", "")
+
+        if search:
+            if search not in original:
+                validation_errors.append(f"Search text not found in {path_str}")
+                return PatchPreview(
+                    path=path_str,
+                    operation="modify",
+                    validation_errors=validation_errors,
+                )
+            modified = original.replace(search, replace, 1)
+        elif "content" in patch:
+            modified = patch["content"]
+        else:
+            validation_errors.append(
+                f"Modify requires 'search'+'replace' or 'content' for {path_str}"
+            )
+            return PatchPreview(
+                path=path_str,
+                operation="modify",
+                validation_errors=validation_errors,
+            )
+
+        diff_lines = list(
+            difflib.unified_diff(
+                original.splitlines(keepends=True),
+                modified.splitlines(keepends=True),
+                fromfile=f"a/{path_str}",
+                tofile=f"b/{path_str}",
+            )
+        )
+        diff_text = "".join(diff_lines)
+        lines_added = sum(
+            1 for ln in diff_lines if ln.startswith("+") and not ln.startswith("+++")
+        )
+        lines_removed = sum(
+            1 for ln in diff_lines if ln.startswith("-") and not ln.startswith("---")
+        )
+
+        return PatchPreview(
+            path=path_str,
+            operation="modify",
+            diff=diff_text,
+            lines_added=lines_added,
+            lines_removed=lines_removed,
+            validation_errors=validation_errors,
+        )
+
+    def _preview_delete(self, path_str: str, target: Path) -> PatchPreview:
+        validation_errors: list[str] = []
+        if not target.exists():
+            validation_errors.append(f"File does not exist: {path_str}")
+        return PatchPreview(
+            path=path_str,
+            operation="delete",
+            would_delete=target.exists(),
+            validation_errors=validation_errors,
+        )
+
+    def _apply_modify(self, patch: dict[str, Any], target: Path) -> None:
+        """Apply a modify operation to a file."""
+        original = target.read_text(encoding="utf-8")
+        search = patch.get("search", "")
+        replace = patch.get("replace", "")
+
+        if search:
+            modified = original.replace(search, replace, 1)
+        else:
+            modified = patch.get("content", original)
+
+        target.write_text(modified, encoding="utf-8")
+
+    def _backup_file(
+        self,
+        target: Path,
+        patch_id: str,
+        backups: dict[str, Path],
+    ) -> None:
+        """Create a backup of a file before modifying it."""
+        if self._backup_dir is None:
+            return
+        if not target.exists():
+            return
+
+        backup_subdir = self._backup_dir / patch_id
+        backup_subdir.mkdir(parents=True, exist_ok=True)
+
+        # Use a safe filename derived from the original
+        safe_name = target.name + f".{len(backups)}.bak"
+        backup_path = backup_subdir / safe_name
+        shutil.copy2(str(target), str(backup_path))
+        backups[str(target)] = backup_path
+
+    def rollback(self, patch_id: str) -> tuple[bool, str]:
+        """Rollback a previously applied patch by restoring backups.
+
+        Returns (success, message).
+        """
+        if self._backup_dir is None:
+            return False, "No backup directory configured"
+
+        backup_subdir = self._backup_dir / patch_id
+        if not backup_subdir.exists():
+            return False, f"No backups found for patch {patch_id}"
+
+        # Check the audit log for the original paths
+        if self._audit_log is None:
+            return False, "No audit log available for rollback"
+
+        entry = self._audit_log.get_entry(patch_id)
+        if entry is None:
+            return False, f"No audit entry found for patch {patch_id}"
+
+        restored = 0
+        errors: list[str] = []
+
+        # Restore modified files
+        backup_files = sorted(backup_subdir.iterdir())
+
+        for i, rel_path in enumerate(entry.files_modified):
+            if i < len(backup_files):
+                target = (Path(entry.workspace_root) / rel_path).resolve()
+                try:
+                    shutil.copy2(str(backup_files[i]), str(target))
+                    restored += 1
+                except OSError as exc:
+                    errors.append(f"Failed to restore {rel_path}: {exc}")
+
+        # Delete created files
+        for rel_path in entry.files_created:
+            target = (Path(entry.workspace_root) / rel_path).resolve()
+            try:
+                if target.exists():
+                    target.unlink()
+                    restored += 1
+            except OSError as exc:
+                errors.append(f"Failed to remove {rel_path}: {exc}")
+
+        # Restore deleted files
+        offset = len(entry.files_modified)
+        for i, rel_path in enumerate(entry.files_deleted):
+            idx = offset + len(entry.files_created) + i
+            if idx < len(backup_files):
+                target = (Path(entry.workspace_root) / rel_path).resolve()
+                try:
+                    target.parent.mkdir(parents=True, exist_ok=True)
+                    shutil.copy2(str(backup_files[idx]), str(target))
+                    restored += 1
+                except OSError as exc:
+                    errors.append(f"Failed to restore deleted {rel_path}: {exc}")
+
+        if errors:
+            err_summary = "; ".join(errors)
+            return False, f"Partial rollback: {restored} restored, errors: {err_summary}"
+        return True, f"Rollback complete: {restored} files restored"
