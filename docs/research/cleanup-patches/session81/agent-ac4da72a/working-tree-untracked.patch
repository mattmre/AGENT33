@@ -0,0 +1,138 @@
+"""Data models for backup manifests, assets, and results."""
+
+from __future__ import annotations
+
+from datetime import UTC, datetime
+from enum import StrEnum
+from typing import Any
+
+from pydantic import BaseModel, Field
+
+
+class BackupMode(StrEnum):
+    """Backup scope modes."""
+
+    FULL = "full"
+    CONFIG_ONLY = "config-only"
+    NO_WORKSPACE = "no-workspace"
+
+
+class AssetType(StrEnum):
+    """Classification of assets included in a backup."""
+
+    CONFIG = "config"
+    AGENT_DEFINITIONS = "agent_definitions"
+    WORKFLOW_DEFINITIONS = "workflow_definitions"
+    SKILLS = "skills"
+    PACKS = "packs"
+    PLUGINS = "plugins"
+    WORKSPACE = "workspace"
+
+
+class BackupAsset(BaseModel):
+    """A single asset included in the backup."""
+
+    relative_path: str
+    asset_type: AssetType
+    size_bytes: int = 0
+    checksum: str = ""  # SHA-256
+    included: bool = True
+    exclusion_reason: str = ""
+
+
+class BackupManifest(BaseModel):
+    """Versioned manifest describing a backup archive."""
+
+    schema_version: str = "1.0"
+    backup_id: str
+    created_at: datetime = Field(default_factory=lambda: datetime.now(UTC))
+    platform: str = ""
+    runtime_version: str = "0.1.0"
+    archive_root: str = ""
+    backup_mode: BackupMode = BackupMode.FULL
+    assets: list[BackupAsset] = Field(default_factory=list)
+    checksums: dict[str, str] = Field(default_factory=dict)
+    metadata: dict[str, Any] = Field(default_factory=dict)
+    label: str = ""
+
+
+class BackupProvenance(BaseModel):
+    """Records who created the backup and from what state."""
+
+    creator: str = ""
+    source_roots: list[str] = Field(default_factory=list)
+    runtime_version: str = "0.1.0"
+    platform: str = ""
+    created_at: datetime = Field(default_factory=lambda: datetime.now(UTC))
+
+
+class BackupResult(BaseModel):
+    """Result of a backup creation operation."""
+
+    success: bool
+    backup_id: str
+    archive_path: str = ""
+    manifest: BackupManifest | None = None
+    size_bytes: int = 0
+    asset_count: int = 0
+    errors: list[str] = Field(default_factory=list)
+    warnings: list[str] = Field(default_factory=list)
+    provenance: BackupProvenance | None = None
+
+
+class BackupSummary(BaseModel):
+    """Lightweight summary for backup listing."""
+
+    backup_id: str
+    created_at: datetime
+    label: str = ""
+    mode: BackupMode = BackupMode.FULL
+    size_bytes: int = 0
+    asset_count: int = 0
+    archive_path: str = ""
+
+
+class VerifyCheck(BaseModel):
+    """A single verification check result."""
+
+    name: str
+    passed: bool
+    message: str = ""
+
+
+class VerifyResult(BaseModel):
+    """Result of verifying a backup archive."""
+
+    valid: bool
+    checks: list[VerifyCheck] = Field(default_factory=list)
+    warnings: list[str] = Field(default_factory=list)
+
+
+class RestoreAssetPlan(BaseModel):
+    """Plan for restoring a single asset."""
+
+    relative_path: str
+    asset_type: str
+    action: str = "create"  # "create", "overwrite", "skip"
+    current_exists: bool = False
+    size_bytes: int = 0
+
+
+class RestoreConflict(BaseModel):
+    """A conflict detected during restore planning."""
+
+    relative_path: str
+    conflict_type: str  # "version_mismatch", "file_modified", "schema_change"
+    message: str
+    resolution: str = "overwrite"  # "overwrite", "skip", "merge"
+
+
+class RestorePlan(BaseModel):
+    """Preview of what a restore would do (no state changes)."""
+
+    backup_id: str
+    backup_version: str = ""
+    current_version: str = "0.1.0"
+    assets_to_restore: list[RestoreAssetPlan] = Field(default_factory=list)
+    conflicts: list[RestoreConflict] = Field(default_factory=list)
+    warnings: list[str] = Field(default_factory=list)
