+"""Archive creation and extraction utilities for backup system."""
+
+from __future__ import annotations
+
+import hashlib
+import json
+import logging
+import os
+import tarfile
+import tempfile
+from datetime import UTC, datetime
+from pathlib import Path
+
+from agent33.backup.models import BackupManifest
+
+logger = logging.getLogger(__name__)
+
+# Files/directories excluded from all backups
+_GLOBAL_EXCLUDES: frozenset[str] = frozenset(
+    {
+        "__pycache__",
+        ".pyc",
+        "node_modules",
+        ".git",
+        ".venv",
+        "venv",
+        ".env",
+        ".env.local",
+        ".env.production",
+    }
+)
+
+
+def compute_sha256(file_path: Path) -> str:
+    """Compute SHA-256 checksum of a file."""
+    h = hashlib.sha256()
+    with file_path.open("rb") as f:
+        for chunk in iter(lambda: f.read(8192), b""):
+            h.update(chunk)
+    return h.hexdigest()
+
+
+def generate_archive_name(
+    mode: str,
+    short_id: str,
+    timestamp: datetime | None = None,
+) -> str:
+    """Generate a lexically sortable archive name.
+
+    Format: agent33-backup-{YYYYMMDD-HHmmss}-{mode}-{short_id}.tar.gz
+    """
+    ts = timestamp or datetime.now(UTC)
+    ts_str = ts.strftime("%Y%m%d-%H%M%S")
+    return f"agent33-backup-{ts_str}-{mode}-{short_id}.tar.gz"
+
+
+def should_exclude(name: str) -> bool:
+    """Check if a file or directory name should be excluded from backup."""
+    basename = os.path.basename(name)
+    if basename in _GLOBAL_EXCLUDES:
+        return True
+    return bool(basename.endswith(".pyc"))
+
+
+def create_archive(
+    source_dirs: dict[str, Path],
+    manifest: BackupManifest,
+    output_path: Path,
+) -> Path:
+    """Create a tar.gz archive from source directories.
+
+    Args:
+        source_dirs: Mapping of archive prefix -> source directory path.
+        manifest: The backup manifest to include.
+        output_path: Where to write the final archive.
+
+    Returns:
+        The path to the created archive.
+
+    The archive is written atomically via a temp file + rename pattern.
+    """
+    output_path.parent.mkdir(parents=True, exist_ok=True)
+
+    # Write to temp file first, then rename atomically
+    tmp_fd, tmp_path_str = tempfile.mkstemp(
+        suffix=".tar.gz.tmp",
+        dir=str(output_path.parent),
+    )
+    os.close(tmp_fd)
+    tmp_path = Path(tmp_path_str)
+
+    try:
+        with tarfile.open(str(tmp_path), "w:gz") as tar:
+            # Add manifest
+            manifest_json = manifest.model_dump_json(indent=2)
+            manifest_bytes = manifest_json.encode("utf-8")
+            import io
+
+            info = tarfile.TarInfo(name="manifest.json")
+            info.size = len(manifest_bytes)
+            tar.addfile(info, io.BytesIO(manifest_bytes))
+
+            # Add source directories
+            for prefix, source_dir in source_dirs.items():
+                if not source_dir.exists():
+                    logger.debug("Skipping non-existent source dir: %s", source_dir)
+                    continue
+                _add_directory(tar, source_dir, prefix)
+
+        # Atomic rename
+        tmp_path.replace(output_path)
+        return output_path
+
+    except Exception:
+        # Clean up temp file on failure
+        import contextlib
+
+        with contextlib.suppress(OSError):
+            tmp_path.unlink(missing_ok=True)
+        raise
+
+
+def _add_directory(tar: tarfile.TarFile, source_dir: Path, prefix: str) -> None:
+    """Add a directory tree to a tar archive with a prefix."""
+    for root, dirs, files in os.walk(str(source_dir)):
+        # Filter out excluded directories
+        dirs[:] = [d for d in dirs if not should_exclude(d)]
+
+        for filename in files:
+            if should_exclude(filename):
+                continue
+            file_path = Path(root) / filename
+            # Compute archive name
+            rel = file_path.relative_to(source_dir)
+            arcname = f"{prefix}/{rel.as_posix()}"
+            try:
+                tar.add(str(file_path), arcname=arcname)
+            except (OSError, tarfile.TarError):
+                logger.warning(
+                    "Failed to add file to archive: %s",
+                    file_path,
+                    exc_info=True,
+                )
+
+
+def extract_manifest(archive_path: Path) -> BackupManifest | None:
+    """Extract and parse the manifest from a backup archive."""
+    try:
+        with tarfile.open(str(archive_path), "r:gz") as tar:
+            try:
+                member = tar.getmember("manifest.json")
+            except KeyError:
+                return None
+
+            f = tar.extractfile(member)
+            if f is None:
+                return None
+
+            data = json.loads(f.read().decode("utf-8"))
+            return BackupManifest.model_validate(data)
+    except (tarfile.TarError, json.JSONDecodeError, ValueError):
+        logger.warning("Failed to extract manifest from %s", archive_path, exc_info=True)
+        return None
+
+
+def verify_archive_integrity(archive_path: Path) -> list[tuple[str, bool, str]]:
+    """Verify the structural integrity of a backup archive.
+
+    Returns a list of (check_name, passed, message) tuples.
+    """
+    checks: list[tuple[str, bool, str]] = []
+
+    # 1. Archive is readable
+    try:
+        with tarfile.open(str(archive_path), "r:gz") as tar:
+            members = tar.getnames()
+        checks.append(("archive_readable", True, "Archive is readable"))
+    except (tarfile.TarError, OSError) as exc:
+        checks.append(("archive_readable", False, f"Cannot read archive: {exc}"))
+        return checks  # no point continuing
+
+    # 2. Manifest present
+    if "manifest.json" not in members:
+        checks.append(("manifest_present", False, "manifest.json not found"))
+        return checks
+    checks.append(("manifest_present", True, "manifest.json found"))
+
+    # 3. Manifest parseable
+    manifest = extract_manifest(archive_path)
+    if manifest is None:
+        checks.append(("manifest_parseable", False, "Cannot parse manifest.json"))
+        return checks
+    checks.append(("manifest_parseable", True, "Manifest parsed successfully"))
+
+    # 4. Schema version supported
+    if manifest.schema_version not in {"1.0"}:
+        checks.append(
+            (
+                "schema_version",
+                False,
+                f"Unsupported schema version: {manifest.schema_version}",
+            )
+        )
+    else:
+        checks.append(("schema_version", True, "Schema version 1.0"))
+
+    # 5. No path escape (all members within archive root)
+    escaped = [m for m in members if m.startswith("/") or ".." in m]
+    if escaped:
+        checks.append(
+            (
+                "path_containment",
+                False,
+                f"Path escape detected: {escaped[:5]}",
+            )
+        )
+    else:
+        checks.append(("path_containment", True, "All paths contained"))
+
+    # 6. No duplicate entries
+    if len(members) != len(set(members)):
+        checks.append(("no_duplicates", False, "Duplicate entries detected"))
+    else:
+        checks.append(("no_duplicates", True, "No duplicate entries"))
+
+    # 7. Checksum verification (spot check declared assets)
+    if manifest.checksums:
+        with tarfile.open(str(archive_path), "r:gz") as tar:
+            mismatch = False
+            for rel_path, expected in list(manifest.checksums.items())[:10]:
+                try:
+                    member = tar.getmember(rel_path)
+                    f = tar.extractfile(member)
+                    if f is not None:
+                        h = hashlib.sha256(f.read()).hexdigest()
+                        if h != expected:
+                            mismatch = True
+                            break
+                except (KeyError, OSError):
+                    mismatch = True
+                    break
+
+            if mismatch:
+                checks.append(("checksums", False, "Checksum mismatch detected"))
+            else:
+                checks.append(("checksums", True, "Checksums verified"))
+
+    return checks
