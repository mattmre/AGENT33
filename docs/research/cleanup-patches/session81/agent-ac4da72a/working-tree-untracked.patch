+class TestRestorePlanner:
+    def _create_test_archive(self, tmp_path: Path) -> Path:
+        """Helper to create a real backup archive for testing."""
+        src = tmp_path / "src"
+        src.mkdir()
+        (src / "config.json").write_text('{"key": "value"}')
+        (src / "data.txt").write_text("important data")
+
+        checksum = compute_sha256(src / "config.json")
+        manifest = BackupManifest(
+            backup_id="restore-test",
+            assets=[
+                BackupAsset(
+                    relative_path="data/config.json",
+                    asset_type=AssetType.CONFIG,
+                    size_bytes=16,
+                    checksum=checksum,
+                ),
+                BackupAsset(
+                    relative_path="data/data.txt",
+                    asset_type=AssetType.WORKSPACE,
+                    size_bytes=14,
+                ),
+            ],
+        )
+
+        output = tmp_path / "restore_test.tar.gz"
+        create_archive({"data": src}, manifest, output)
+        return output
+
+    def test_plan_new_files(self, tmp_path: Path) -> None:
+        archive = self._create_test_archive(tmp_path)
+        target = tmp_path / "target"
+        target.mkdir()
+
+        planner = RestorePlanner(target_root=target)
+        plan = planner.plan(archive)
+
+        assert plan.backup_id == "restore-test"
+        assert len(plan.assets_to_restore) == 2
+        assert all(a.action == "create" for a in plan.assets_to_restore)
+        assert len(plan.conflicts) == 0
+
+    def test_plan_detects_modified_files(self, tmp_path: Path) -> None:
+        archive = self._create_test_archive(tmp_path)
+        target = tmp_path / "target"
+        target.mkdir()
+
+        # Create a conflicting file with different content
+        (target / "data").mkdir(parents=True)
+        (target / "data" / "config.json").write_text('{"key": "different"}')
+
+        planner = RestorePlanner(target_root=target)
+        plan = planner.plan(archive)
+
+        assert len(plan.conflicts) >= 1
+        conflict = plan.conflicts[0]
+        assert conflict.conflict_type == "file_modified"
+        assert "modified" in conflict.message.lower()
+
+    def test_plan_overwrite_existing(self, tmp_path: Path) -> None:
+        archive = self._create_test_archive(tmp_path)
+        target = tmp_path / "target"
+        target.mkdir()
+
+        # Create existing file with same content (no checksum means no conflict)
+        (target / "data").mkdir(parents=True)
+        (target / "data" / "data.txt").write_text("old content")
+
+        planner = RestorePlanner(target_root=target)
+        plan = planner.plan(archive)
+
+        # data.txt has no checksum in manifest, so action is overwrite with no conflict
+        data_asset = next(
+            (a for a in plan.assets_to_restore if "data.txt" in a.relative_path),
+            None,
+        )
+        assert data_asset is not None
+        assert data_asset.action == "overwrite"
+        assert data_asset.current_exists is True
+
+    def test_plan_invalid_archive(self, tmp_path: Path) -> None:
+        bad = tmp_path / "bad.tar.gz"
+        bad.write_text("not valid")
+
+        target = tmp_path / "target"
+        target.mkdir()
+
+        planner = RestorePlanner(target_root=target)
+        plan = planner.plan(bad)
+
+        assert plan.backup_id == ""
+        assert len(plan.warnings) > 0
