index 0000000..1a2af25
--- /dev/null
+++ b/engine/src/agent33/tools/builtin/patch_security.py
@@ -0,0 +1,119 @@
+"""Filesystem boundary enforcement for patch operations."""
+
+from __future__ import annotations
+
+from pathlib import Path  # noqa: TCH003
+from typing import Any
+
+# Paths that are never patchable regardless of workspace containment
+_SENSITIVE_PATTERNS: frozenset[str] = frozenset(
+    {
+        ".env",
+        ".env.local",
+        ".env.production",
+        "secrets.json",
+        "credentials.json",
+        "id_rsa",
+        "id_ed25519",
+        ".git/config",
+        ".git/HEAD",
+    }
+)
+
+_SENSITIVE_SUFFIXES: frozenset[str] = frozenset(
+    {
+        ".pem",
+        ".key",
+        ".p12",
+        ".pfx",
+        ".jks",
+    }
+)
+
+
+class PatchSecurityValidator:
+    """Validates patch operations against filesystem security boundaries."""
+
+    def __init__(self, workspace_root: Path) -> None:
+        self._workspace_root = workspace_root.resolve()
+
+    @property
+    def workspace_root(self) -> Path:
+        return self._workspace_root
+
+    def validate_path(self, path: str) -> tuple[bool, str]:
+        """Validate a patch path is safe.
+
+        Checks:
+        1. Path resolves within workspace_root (no traversal escape).
+        2. No null bytes.
+        3. No symlink escape.
+        4. Not a sensitive file pattern.
+
+        Returns (is_valid, error_message). Error message is empty when valid.
+        """
+        if not path:
+            return False, "Empty path"
+
+        if "\x00" in path:
+            return False, "Null bytes are not allowed in file paths"
+
+        # Reject raw path traversal patterns before resolving
+        if ".." in path.replace("\\", "/").split("/"):
+            return False, "Path traversal (..) is not allowed"
+
+        # Resolve relative to workspace root
+        target = (self._workspace_root / path).resolve()
+
+        # Containment check
+        try:
+            target.relative_to(self._workspace_root)
+        except ValueError:
+            return False, (
+                f"Path '{path}' resolves outside workspace root '{self._workspace_root}'"
+            )
+
+        # Symlink escape check (only if the path already exists)
+        if target.exists() and target.is_symlink():
+            real_target = target.resolve()
+            try:
+                real_target.relative_to(self._workspace_root)
+            except ValueError:
+                return False, (
+                    f"Symlink at '{path}' points outside workspace root (target: {real_target})"
+                )
+
+        # Sensitive file check
+        relative_posix = target.relative_to(self._workspace_root).as_posix()
+        if self._is_sensitive(relative_posix, target):
+            return False, f"Path '{path}' matches a sensitive file pattern"
+
+        return True, ""
+
+    def validate_batch(self, patches: list[dict[str, Any]]) -> list[tuple[str, str]]:
+        """Validate all paths in a patch batch.
+
+        Returns list of (path, error) for failures. Empty list means all valid.
+        """
+        errors: list[tuple[str, str]] = []
+        for patch in patches:
+            path = patch.get("path", "")
+            valid, error = self.validate_path(path)
+            if not valid:
+                errors.append((path, error))
+        return errors
+
+    @staticmethod
+    def _is_sensitive(relative_posix: str, target: Path) -> bool:
+        """Check if a path matches sensitive file patterns."""
+        # Check exact filename matches
+        filename = target.name
+        if filename in _SENSITIVE_PATTERNS:
+            return True
+
+        # Check relative path matches (e.g. ".git/config")
+        if relative_posix in _SENSITIVE_PATTERNS:
+            return True
+
+        # Check suffix matches
+        return target.suffix.lower() in _SENSITIVE_SUFFIXES
