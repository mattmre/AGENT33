@@ -0,0 +1,237 @@
+"""FastAPI router for safe mutation (apply_patch) and process management."""
+
+from __future__ import annotations
+
+from typing import Any
+
+from fastapi import APIRouter, HTTPException, Request
+from pydantic import BaseModel
+
+from agent33.execution.process_manager import ProcessManager, ProcessStatus  # noqa: TCH001
+from agent33.security.permissions import require_scope
+from agent33.tools.base import ToolContext
+from agent33.tools.builtin.apply_patch import ApplyPatchTool  # noqa: TCH001
+from agent33.tools.builtin.patch_audit import PatchAuditLog  # noqa: TCH001
+
+router = APIRouter(tags=["mutations"])
+
+# Module-level singletons set from lifespan
+_patch_tool: ApplyPatchTool | None = None
+_audit_log: PatchAuditLog | None = None
+_process_manager: ProcessManager | None = None
+
+
+def set_patch_tool(tool: ApplyPatchTool) -> None:
+    global _patch_tool  # noqa: PLW0603
+    _patch_tool = tool
+
+
+def set_audit_log(log: PatchAuditLog) -> None:
+    global _audit_log  # noqa: PLW0603
+    _audit_log = log
+
+
+def set_process_manager(pm: ProcessManager) -> None:
+    global _process_manager  # noqa: PLW0603
+    _process_manager = pm
+
+
+def _get_patch_tool() -> ApplyPatchTool:
+    if _patch_tool is None:
+        raise HTTPException(status_code=503, detail="Patch tool not initialized")
+    return _patch_tool
+
+
+def _get_audit_log() -> PatchAuditLog:
+    if _audit_log is None:
+        raise HTTPException(status_code=503, detail="Patch audit log not initialized")
+    return _audit_log
+
+
+def _get_process_manager() -> ProcessManager:
+    if _process_manager is None:
+        raise HTTPException(status_code=503, detail="Process manager not initialized")
+    return _process_manager
+
+
+def _get_token_payload(request: Request) -> Any:
+    payload = getattr(request.state, "user", None)
+    if payload is None:
+        raise HTTPException(status_code=401, detail="Not authenticated")
+    return payload
+
+
+# ---------------------------------------------------------------------------
+# Patch endpoints
+# ---------------------------------------------------------------------------
+
+
+class PatchOperation(BaseModel):
+    path: str
+    operation: str  # "create", "modify", "delete"
+    content: str = ""
+    search: str = ""
+    replace: str = ""
+
+
+class ApplyPatchRequest(BaseModel):
+    patches: list[PatchOperation]
+    dry_run: bool = False
+    workspace_root: str = ""
+
+
+@router.post("/v1/mutations/patch", dependencies=[require_scope("tools:execute")])
+async def apply_patch(request: Request, body: ApplyPatchRequest) -> dict[str, Any]:
+    """Apply a batch of file patches with workspace containment."""
+    token = _get_token_payload(request)
+    tool = _get_patch_tool()
+
+    context = ToolContext(
+        user_scopes=token.scopes,
+        requested_by=token.sub or "",
+        tenant_id=token.tenant_id or "",
+    )
+
+    params: dict[str, Any] = {
+        "patches": [p.model_dump() for p in body.patches],
+        "dry_run": body.dry_run,
+    }
+    if body.workspace_root:
+        params["workspace_root"] = body.workspace_root
+
+    result = await tool.execute(params, context)
+    if result.success:
+        import json
+
+        return json.loads(result.output)
+    raise HTTPException(status_code=400, detail=result.error)
+
+
+@router.post(
+    "/v1/mutations/patch/preview",
+    dependencies=[require_scope("tools:execute")],
+)
+async def preview_patch(request: Request, body: ApplyPatchRequest) -> dict[str, Any]:
+    """Preview what a patch would do (always dry-run)."""
+    token = _get_token_payload(request)
+    tool = _get_patch_tool()
+
+    context = ToolContext(
+        user_scopes=token.scopes,
+        requested_by=token.sub or "",
+        tenant_id=token.tenant_id or "",
+    )
+
+    params: dict[str, Any] = {
+        "patches": [p.model_dump() for p in body.patches],
+        "dry_run": True,
+    }
+    if body.workspace_root:
+        params["workspace_root"] = body.workspace_root
+
+    result = await tool.execute(params, context)
+    import json
+
+    return json.loads(result.output)
+
+
+@router.post(
+    "/v1/mutations/patch/{patch_id}/rollback",
+    dependencies=[require_scope("tools:execute")],
+)
+async def rollback_patch(request: Request, patch_id: str) -> dict[str, Any]:
+    """Rollback a previously applied patch."""
+    _get_token_payload(request)
+    tool = _get_patch_tool()
+
+    success, message = tool.rollback(patch_id)
+    if not success:
+        raise HTTPException(status_code=400, detail=message)
+    return {"success": True, "message": message}
+
+
+# ---------------------------------------------------------------------------
+# Process management endpoints
+# ---------------------------------------------------------------------------
+
+
+class StartProcessRequest(BaseModel):
+    command: str
+    session_id: str = ""
+
+
+@router.get("/v1/processes/", dependencies=[require_scope("tools:execute")])
+async def list_processes(
+    request: Request,
+    status: str | None = None,
+) -> list[dict[str, Any]]:
+    """List managed background processes."""
+    token = _get_token_payload(request)
+    pm = _get_process_manager()
+    tenant_id = token.tenant_id or ""
+
+    status_filter: ProcessStatus | None = None
+    if status is not None:
+        try:
+            status_filter = ProcessStatus(status)
+        except ValueError as exc:
+            raise HTTPException(status_code=400, detail=f"Invalid status: {status}") from exc
+
+    processes = pm.list_processes(tenant_id=tenant_id, status_filter=status_filter)
+    return [p.model_dump(mode="json") for p in processes]
+
+
+@router.get("/v1/processes/{process_id}", dependencies=[require_scope("tools:execute")])
+async def get_process(request: Request, process_id: str) -> dict[str, Any]:
+    """Get process detail."""
+    token = _get_token_payload(request)
+    pm = _get_process_manager()
+
+    process = pm.get_status(process_id)
+    if process is None:
+        raise HTTPException(status_code=404, detail=f"Process not found: {process_id}")
+
+    tenant_id = token.tenant_id or ""
+    if tenant_id and process.tenant_id != tenant_id:
+        raise HTTPException(status_code=404, detail=f"Process not found: {process_id}")
+
+    return process.model_dump(mode="json")
+
+
+@router.post(
+    "/v1/processes/{process_id}/kill",
+    dependencies=[require_scope("tools:execute")],
+)
+async def kill_process(request: Request, process_id: str) -> dict[str, Any]:
+    """Terminate a running process."""
+    _get_token_payload(request)
+    pm = _get_process_manager()
+
+    killed = await pm.kill(process_id)
+    if not killed:
+        raise HTTPException(
+            status_code=400,
+            detail=f"Cannot kill process {process_id} (not found or not running)",
+        )
+    return {"killed": True, "process_id": process_id}
+
+
+@router.post(
+    "/v1/processes/{process_id}/pause",
+    dependencies=[require_scope("tools:execute")],
+)
+async def pause_process(request: Request, process_id: str) -> dict[str, Any]:
+    """Pause a running process (not supported on all platforms)."""
+    _get_token_payload(request)
+    pm = _get_process_manager()
+
+    process = pm.get_status(process_id)
+    if process is None:
+        raise HTTPException(status_code=404, detail=f"Process not found: {process_id}")
+
+    # Pause is platform-specific and not universally supported
+    # On Windows, SIGSTOP is not available
+    raise HTTPException(
+        status_code=501,
+        detail="Process pause is not yet implemented on this platform",
+    )
