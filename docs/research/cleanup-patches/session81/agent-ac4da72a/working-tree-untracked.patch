+def _make_app(tmp_path: Path) -> tuple[FastAPI, BackupService]:
+    """Create a test app with backup routes wired up."""
+    config_dir = tmp_path / "config"
+    config_dir.mkdir()
+    (config_dir / "app.json").write_text('{"setting": "value"}')
+
+    data_dir = tmp_path / "data"
+    data_dir.mkdir()
+    skills_dir = data_dir / "skills"
+    skills_dir.mkdir()
+    (skills_dir / "skill.md").write_text("# Test Skill")
+
+    backup_dir = tmp_path / "backups"
+    service = BackupService(
+        backup_dir=backup_dir,
+        config_dir=config_dir,
+        data_dir=data_dir,
+    )
+
+    backups.set_backup_service(service)
+
+    app = FastAPI()
+
+    @app.middleware("http")
+    async def mock_auth(request: Request, call_next: Any) -> Any:
+        user = MagicMock()
+        user.scopes = ["tools:execute", "admin"]
+        user.sub = "test-operator"
+        user.tenant_id = "test-tenant"
+        request.state.user = user
+        return await call_next(request)
+
+    app.include_router(backups.router)
+    return app, service
