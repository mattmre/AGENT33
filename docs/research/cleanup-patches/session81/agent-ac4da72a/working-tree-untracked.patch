@@ -0,0 +1,121 @@
+"""Mutation audit trail for patch operations."""
+
+from __future__ import annotations
+
+import json
+import logging
+from datetime import UTC, datetime
+from pathlib import Path  # noqa: TCH003
+from typing import Any
+
+from pydantic import BaseModel, Field
+
+logger = logging.getLogger(__name__)
+
+
+class PatchAuditEntry(BaseModel):
+    """Audit record for a patch application."""
+
+    patch_id: str
+    timestamp: datetime = Field(default_factory=lambda: datetime.now(UTC))
+    agent_id: str = ""
+    session_id: str = ""
+    tenant_id: str = ""
+    workspace_root: str = ""
+    patches: list[dict[str, Any]] = Field(default_factory=list)
+    dry_run: bool = False
+    approval_id: str = ""
+    result: str = ""  # "success", "partial", "failed", "dry_run"
+    errors: list[str] = Field(default_factory=list)
+    files_modified: list[str] = Field(default_factory=list)
+    files_created: list[str] = Field(default_factory=list)
+    files_deleted: list[str] = Field(default_factory=list)
+
+
+class PatchAuditLog:
+    """Persistent audit log for patch operations.
+
+    Stores entries as newline-delimited JSON in the log directory.
+    """
+
+    def __init__(self, log_dir: Path) -> None:
+        self._log_dir = log_dir
+        self._log_dir.mkdir(parents=True, exist_ok=True)
+        self._log_file = self._log_dir / "patch_audit.jsonl"
+
+    def record(self, entry: PatchAuditEntry) -> None:
+        """Append an audit entry to the log."""
+        try:
+            with self._log_file.open("a", encoding="utf-8") as f:
+                f.write(entry.model_dump_json() + "\n")
+        except OSError:
+            logger.warning(
+                "Failed to write patch audit entry: patch_id=%s",
+                entry.patch_id,
+                exc_info=True,
+            )
+
+    def query(
+        self,
+        *,
+        session_id: str = "",
+        tenant_id: str = "",
+        limit: int = 50,
+    ) -> list[PatchAuditEntry]:
+        """Query the audit log with optional filters.
+
+        Returns entries in reverse chronological order (newest first).
+        """
+        entries: list[PatchAuditEntry] = []
+        if not self._log_file.exists():
+            return entries
+
+        try:
+            lines = self._log_file.read_text(encoding="utf-8").strip().split("\n")
+        except OSError:
+            logger.warning("Failed to read patch audit log", exc_info=True)
+            return entries
+
+        for line in reversed(lines):
+            line = line.strip()
+            if not line:
+                continue
+            try:
+                data = json.loads(line)
+                entry = PatchAuditEntry.model_validate(data)
+            except (json.JSONDecodeError, ValueError):
+                continue
+
+            if session_id and entry.session_id != session_id:
+                continue
+            if tenant_id and entry.tenant_id != tenant_id:
+                continue
+
+            entries.append(entry)
+            if len(entries) >= limit:
+                break
+
+        return entries
+
+    def get_entry(self, patch_id: str) -> PatchAuditEntry | None:
+        """Retrieve a single audit entry by patch_id."""
+        if not self._log_file.exists():
+            return None
+
+        try:
+            lines = self._log_file.read_text(encoding="utf-8").strip().split("\n")
+        except OSError:
+            return None
+
+        for line in reversed(lines):
+            line = line.strip()
+            if not line:
+                continue
+            try:
+                data = json.loads(line)
+                if data.get("patch_id") == patch_id:
+                    return PatchAuditEntry.model_validate(data)
+            except (json.JSONDecodeError, ValueError):
+                continue
+
+        return None
