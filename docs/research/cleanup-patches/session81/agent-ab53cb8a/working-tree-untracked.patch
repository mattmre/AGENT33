index 0000000..b206b79
--- /dev/null
+++ b/frontend/src/components/AuthPanel.test.tsx
@@ -0,0 +1,184 @@
+import { render, screen, waitFor } from "@testing-library/react";
+import userEvent from "@testing-library/user-event";
+import { describe, expect, it, vi } from "vitest";
+
+const { apiRequestMock } = vi.hoisted(() => ({
+  apiRequestMock: vi.fn()
+}));
+
+vi.mock("../lib/api", () => ({
+  apiRequest: apiRequestMock,
+  getRuntimeConfig: () => ({ API_BASE_URL: "http://localhost:8000" })
+}));
+
+import { AuthPanel } from "./AuthPanel";
+
+describe("AuthPanel", () => {
+  it("renders all form fields", () => {
+    render(
+      <AuthPanel
+        token=""
+        apiKey=""
+        onTokenChange={vi.fn()}
+        onApiKeyChange={vi.fn()}
+      />
+    );
+
+    expect(screen.getByText("Access Control")).toBeInTheDocument();
+    expect(screen.getByText("Sign In")).toBeInTheDocument();
+    expect(screen.getByPlaceholderText("Paste JWT token")).toBeInTheDocument();
+    expect(screen.getByPlaceholderText("a33_xxx...")).toBeInTheDocument();
+  });
+
+  it("calls onTokenChange when pasting into the Bearer Token textarea", async () => {
+    const user = userEvent.setup();
+    const onTokenChange = vi.fn();
+
+    render(
+      <AuthPanel
+        token=""
+        apiKey=""
+        onTokenChange={onTokenChange}
+        onApiKeyChange={vi.fn()}
+      />
+    );
+
+    const textarea = screen.getByPlaceholderText("Paste JWT token");
+    await user.type(textarea, "abc");
+
+    // onTokenChange is called for each keystroke
+    expect(onTokenChange).toHaveBeenCalledTimes(3);
+    expect(onTokenChange).toHaveBeenLastCalledWith("abc");
+  });
+
+  it("calls onApiKeyChange when typing into the API Key input", async () => {
+    const user = userEvent.setup();
+    const onApiKeyChange = vi.fn();
+
+    render(
+      <AuthPanel
+        token=""
+        apiKey=""
+        onTokenChange={vi.fn()}
+        onApiKeyChange={onApiKeyChange}
+      />
+    );
+
+    const input = screen.getByPlaceholderText("a33_xxx...");
+    await user.type(input, "key");
+
+    expect(onApiKeyChange).toHaveBeenCalledTimes(3);
+    expect(onApiKeyChange).toHaveBeenLastCalledWith("key");
+  });
+
+  it("performs login and calls onTokenChange with the returned token", async () => {
+    const user = userEvent.setup();
+    const onTokenChange = vi.fn();
+
+    apiRequestMock.mockResolvedValue({
+      ok: true,
+      status: 200,
+      data: { access_token: "jwt-from-server" }
+    });
+
+    render(
+      <AuthPanel
+        token=""
+        apiKey=""
+        onTokenChange={onTokenChange}
+        onApiKeyChange={vi.fn()}
+      />
+    );
+
+    await user.click(screen.getByText("Sign In"));
+
+    await waitFor(() => {
+      expect(onTokenChange).toHaveBeenCalledWith("jwt-from-server");
+    });
+
+    expect(apiRequestMock).toHaveBeenCalledWith(
+      expect.objectContaining({
+        method: "POST",
+        path: "/v1/auth/token"
+      })
+    );
+  });
+
+  it("displays error when login fails", async () => {
+    const user = userEvent.setup();
+
+    apiRequestMock.mockResolvedValue({
+      ok: false,
+      status: 401,
+      data: null
+    });
+
+    render(
+      <AuthPanel
+        token=""
+        apiKey=""
+        onTokenChange={vi.fn()}
+        onApiKeyChange={vi.fn()}
+      />
+    );
+
+    await user.click(screen.getByText("Sign In"));
+
+    await waitFor(() => {
+      expect(screen.getByText("Login failed (401)")).toBeInTheDocument();
+    });
+  });
+
+  it("displays error when response has no access_token", async () => {
+    const user = userEvent.setup();
+
+    apiRequestMock.mockResolvedValue({
+      ok: true,
+      status: 200,
+      data: { no_token_field: true }
+    });
+
+    render(
+      <AuthPanel
+        token=""
+        apiKey=""
+        onTokenChange={vi.fn()}
+        onApiKeyChange={vi.fn()}
+      />
+    );
+
+    await user.click(screen.getByText("Sign In"));
+
+    await waitFor(() => {
+      expect(screen.getByText("No access_token in login response.")).toBeInTheDocument();
+    });
+  });
+
+  it("shows loading state during login", async () => {
+    const user = userEvent.setup();
+    let resolveLogin: (v: unknown) => void;
+    apiRequestMock.mockReturnValue(
+      new Promise((resolve) => {
+        resolveLogin = resolve;
+      })
+    );
+
+    render(
+      <AuthPanel
+        token=""
+        apiKey=""
+        onTokenChange={vi.fn()}
+        onApiKeyChange={vi.fn()}
+      />
+    );
+
+    await user.click(screen.getByText("Sign In"));
+    expect(screen.getByText("Signing in...")).toBeInTheDocument();
+
+    // Resolve and verify button returns to normal
+    resolveLogin!({ ok: false, status: 500, data: null });
+    await waitFor(() => {
+      expect(screen.getByText("Sign In")).toBeInTheDocument();
+    });
+  });
+});
diff --git a/frontend/src/components/GlobalSearch.test.tsx b/frontend/src/components/GlobalSearch.test.tsx
new file mode 100644
index 0000000..57c2ab8
--- /dev/null
+++ b/frontend/src/components/GlobalSearch.test.tsx
@@ -0,0 +1,114 @@
+import { render, screen, waitFor } from "@testing-library/react";
+import userEvent from "@testing-library/user-event";
+import { afterEach, describe, expect, it, vi } from "vitest";
+
+vi.mock("../lib/api", () => ({
+  getRuntimeConfig: () => ({ API_BASE_URL: "http://localhost:8000" })
+}));
+
+import { GlobalSearch } from "./GlobalSearch";
+
+describe("GlobalSearch", () => {
+  afterEach(() => {
+    delete window.__AGENT33_CONFIG__;
+  });
+
+  it("renders disabled search when no token is provided", () => {
+    render(<GlobalSearch token={null} />);
+    const input = screen.getByPlaceholderText("Sign in to use memory search");
+    expect(input).toBeDisabled();
+  });
+
+  it("renders enabled search when token is provided", () => {
+    render(<GlobalSearch token="jwt-token" />);
+    const input = screen.getByPlaceholderText("Search Semantic Memory (PGVector)...");
+    expect(input).not.toBeDisabled();
+  });
+
+  it("calls fetch with correct auth header and body on submit", async () => {
+    const user = userEvent.setup();
+    const fetchMock = vi.fn().mockResolvedValue({
+      json: () => Promise.resolve({ results: [] })
+    });
+    vi.stubGlobal("fetch", fetchMock);
+
+    render(<GlobalSearch token="my-jwt" />);
+    const input = screen.getByPlaceholderText("Search Semantic Memory (PGVector)...");
+
+    await user.type(input, "test query{enter}");
+
+    await waitFor(() => expect(fetchMock).toHaveBeenCalledTimes(1));
+    expect(fetchMock.mock.calls[0][0]).toContain("/v1/memory/search");
+    expect(fetchMock.mock.calls[0][1]).toMatchObject({
+      method: "POST",
+      headers: expect.objectContaining({
+        Authorization: "Bearer my-jwt",
+        "Content-Type": "application/json"
+      })
+    });
+    const body = JSON.parse(fetchMock.mock.calls[0][1].body);
+    expect(body.query).toBe("test query");
+  });
+
+  it("renders search results", async () => {
+    const user = userEvent.setup();
+    const fetchMock = vi.fn().mockResolvedValue({
+      json: () =>
+        Promise.resolve({
+          results: [
+            { content: "Result one content here that is important", token_estimate: 42, level: "full" },
+            { content: "Result two content here that is also important", token_estimate: 20, level: "summary" }
+          ]
+        })
+    });
+    vi.stubGlobal("fetch", fetchMock);
+
+    render(<GlobalSearch token="tok" />);
+    const input = screen.getByPlaceholderText("Search Semantic Memory (PGVector)...");
+    await user.type(input, "search{enter}");
+
+    await waitFor(() => {
+      expect(screen.getByText("Memory Results")).toBeInTheDocument();
+    });
+    expect(screen.getByText(/Result one content/)).toBeInTheDocument();
+    expect(screen.getByText(/Result two content/)).toBeInTheDocument();
+  });
+
+  it("shows no results message when search returns empty", async () => {
+    const user = userEvent.setup();
+    const fetchMock = vi.fn().mockResolvedValue({
+      json: () => Promise.resolve({ results: [] })
+    });
+    vi.stubGlobal("fetch", fetchMock);
+
+    render(<GlobalSearch token="tok" />);
+    const input = screen.getByPlaceholderText("Search Semantic Memory (PGVector)...");
+    await user.type(input, "nothing{enter}");
+
+    await waitFor(() => {
+      expect(screen.getByText("No results found.")).toBeInTheDocument();
+    });
+  });
+
+  it("closes results panel when close button is clicked", async () => {
+    const user = userEvent.setup();
+    const fetchMock = vi.fn().mockResolvedValue({
+      json: () => Promise.resolve({ results: [] })
+    });
+    vi.stubGlobal("fetch", fetchMock);
+
+    render(<GlobalSearch token="tok" />);
+    const input = screen.getByPlaceholderText("Search Semantic Memory (PGVector)...");
+    await user.type(input, "test{enter}");
+
+    await waitFor(() => {
+      expect(screen.getByText("No results found.")).toBeInTheDocument();
+    });
+
+    // The close button renders as a special character
+    const closeBtn = screen.getByRole("button", { name: /✕/ });
+    await user.click(closeBtn);
+
+    expect(screen.queryByText("No results found.")).not.toBeInTheDocument();
+  });
+});
