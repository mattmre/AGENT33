+
+    def _record_event(self, run_id: str, seq: int, event: WorkflowEvent) -> None:
+        """Store an event in the bounded ring buffer for *run_id*."""
+        buf = self._event_buffers.get(run_id)
+        if buf is None:
+            buf = collections.deque(maxlen=self._event_buffer_size)
+            self._event_buffers[run_id] = buf
+        buf.append((seq, event))
